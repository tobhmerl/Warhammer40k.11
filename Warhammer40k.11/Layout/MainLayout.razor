@inherits LayoutComponentBase
@implements IDisposable
@using Warhammer40k.Core
@inject SettingsState Settings
@inject NavigationManager Navigation
@inject IApiClient Api

<div class="shell @(_immersive ? "shell--immersive" : null)">
    @if (!_immersive)
    {
        <nav class="appbar" aria-label="Primary">
            <NavLink class="navlink" href="catalogue">Catalogue</NavLink>
            <NavLink class="navlink" href="rosters">Rosters</NavLink>
            <NavLink class="navlink" href="play">Play</NavLink>
            <NavLink class="navlink" href="settings">Settings</NavLink>
        </nav>
    }

    <main class="content">
        @Body
    </main>

    <footer class="foot">
        <span class="foot-auth @(_user is { IsAuthenticated: true } ? "in" : "out")">
            @if (_user is { IsAuthenticated: true } signedIn)
            {
                <span class="foot-dot" aria-hidden="true"></span>
                <span>Signed in as <strong>@signedIn.UserName</strong></span>
            }
            else
            {
                <span class="foot-dot" aria-hidden="true"></span>
                <a href="settings">Not signed in &middot; sign in</a>
            }
        </span>
    </footer>
</div>

@code {
    private bool _immersive;
    private UserInfo? _user;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        _immersive = IsImmersiveRoute();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Settings.InitializeAsync();
            _user = await Api.GetCurrentUserAsync();
            StateHasChanged();
        }
    }

    // The active play session (/play/{id}) is an immersive screen: hide the app bar.
    // That page carries its own "← Play" exit link, so navigation isn't lost.
    private bool IsImmersiveRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri);
        var cut = path.IndexOfAny(new[] { '?', '#' });
        if (cut >= 0)
            path = path[..cut];

        return path.StartsWith("play/", StringComparison.OrdinalIgnoreCase);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var immersive = IsImmersiveRoute();
        if (immersive != _immersive)
        {
            _immersive = immersive;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
