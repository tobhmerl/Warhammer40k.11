{
  "routes": [
    { "route": "/.auth/login/aad", "statusCode": 404 },
    { "route": "/api/whoami", "allowedRoles": [ "anonymous", "authenticated" ] },
    { "route": "/api/catalogue", "methods": [ "GET" ], "allowedRoles": [ "anonymous", "authenticated" ] },
    { "route": "/api/*", "allowedRoles": [ "authenticated" ] }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_framework/*",
      "/css/*",
      "/*.{png,jpg,gif,svg,ico,webmanifest,wasm,dll,pdb,dat,blat,br,json}"
    ]
  },
  "mimeTypes": {
    ".json": "application/json",
    ".webmanifest": "application/manifest+json",
    ".wasm": "application/wasm",
    ".dll": "application/octet-stream",
    ".dat": "application/octet-stream",
    ".blat": "application/octet-stream"
  }
}
