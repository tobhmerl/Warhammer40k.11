@page "/play/{Id}"
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Play
@using Warhammer40k.Core.Rosters
@using Warhammer40k._11.Components
@using System.Text.Json
@using System.Text.RegularExpressions
@implements IAsyncDisposable
@inject IApiClient Api
@inject IJSRuntime JS
@inject SettingsState Settings

<PageTitle>TombWorld — @(_roster?.Name ?? "Play")</PageTitle>

@if (_loading)
{
	<div class="play">
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Loading roster&hellip;</p>
		</div>
	</div>
}
else if (!_authenticated)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">Sign in to play with your rosters.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	</div>
}
else if (_notFound || _roster is null || _battle is null)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">That roster could not be found.</p>
			<a class="btn ghost" href="play">&larr; Back to play</a>
		</div>
	</div>
}
else
{
	<div class="play">
		@if (_cardSwipe && OrderedUnits.Count > 0)
		{
			var ordered = OrderedUnits;
			var activeIdx = Math.Clamp(_activeCard, 0, ordered.Count - 1);
			<div class="deck-bar" role="group" aria-label="Current unit">
				<span class="deck-pos">
					<span class="deck-name">@ordered[activeIdx].Name</span>
				</span>
			</div>
			@if (ordered.Count > 1)
			{
				<div class="deck-dots" role="tablist" aria-label="Jump to unit — hold a pill to reorder" @ref="_dotsRef">
					@for (var i = 0; i < ordered.Count; i++)
					{
						var index = i;
						var u = ordered[index];
						var dUsable = IsDead(u) ? 0 : AvailableNowCount(u);
						var dStrat = IsDead(u) ? 0 : StratagemsNowCount(u);
						var dShock = MyCommandPhase && NeedsBattleShock(u);
						var dReanim = MyCommandPhase && !dShock && NeedsReanimation(u);
						var dState = dShock ? " · battle-shock" : dReanim ? " · can reanimate" : "";
						var dCounts = (dUsable > 0 || dStrat > 0) ? $" · {dUsable} ability/{dStrat} stratagem usable now" : "";
						<button type="button" class="deck-dot @(index == _activeCard ? "on" : "") @(IsDead(u) ? "dead" : "") @(dShock ? "shocked" : "") @(dReanim ? "reanimate" : "")"
								role="tab" aria-selected="@(index == _activeCard)" data-reorder-index="@index"
								title="@($"{u.Name}{dCounts}{dState}")" @onclick="() => SelectCard(index)">
							<span class="dd-label">@DeckLabel(u)</span>
							@if (dUsable > 0 || dStrat > 0)
							{
								<span class="dd-badge" aria-hidden="true">
									<span class="dd-ability @(dUsable > 0 ? "" : "none")">@(dUsable > 0 ? dUsable.ToString() : "–")</span>
									<span class="dd-sep">|</span>
									<span class="dd-strat @(dStrat > 0 ? "" : "none")">@(dStrat > 0 ? dStrat.ToString() : "–")</span>
								</span>
							}
						</button>
					}
				</div>
			}
		}
		<div class="play-rail">
			@if (!_cardSwipe)
			{
				<div class="scroll-nav" aria-label="Scroll">
					<button class="scroll-btn" type="button" @onclick="ScrollTop" aria-label="Scroll to top" title="Top">↑</button>
					<button class="scroll-btn" type="button" @onclick="ScrollBottom" aria-label="Scroll to bottom" title="Bottom">↓</button>
				</div>
			}
		</div>

		@* Minimal in-game HUD: resources, turn ownership, and direct phase selection. *@
		<div class="hud @(_hudSticky ? "sticky" : null)">
			<div class="hud-top">
				<div class="cp" aria-label="Command points">
					<button class="cp-btn" type="button" @onclick="() => StepCp(-1)" aria-label="Spend command point">−</button>
					<span class="cp-val"><span class="cp-num">@_cp</span><span class="cp-label">CP</span></span>
					<button class="cp-btn" type="button" @onclick="() => StepCp(1)" aria-label="Gain command point">+</button>
				</div>

				<div class="turn-toggle" role="group" aria-label="Whose turn it is">
					<button type="button" class="turn @(_turn == BattleTurn.Player ? "on" : "")"
							aria-pressed="@(_turn == BattleTurn.Player)" @onclick="() => SetTurn(BattleTurn.Player)" title="Your turn">
						YOU
					</button>
					<button type="button" class="turn opp @(_turn == BattleTurn.Opponent ? "on" : "")"
							aria-pressed="@(_turn == BattleTurn.Opponent)" @onclick="() => SetTurn(BattleTurn.Opponent)" title="Opponent's turn">
						OPP
					</button>
				</div>
			</div>

			<nav class="phases" aria-label="Battle phases">
				@foreach (var phase in BattlePhases.Ordered)
				{
					<button type="button" class="phase @(phase == _phase ? "on" : "")" @onclick="() => SelectPhase(phase)" title="@BattlePhases.Label(phase)">
						<span class="ph-name">@BattlePhases.ShortLabel(phase)</span>
					</button>
				}
			</nav>
		</div>

		@{
			var nowReminders = NowReminders;
			var nowAbilities = NowAbilities;
			var nowBuffs = NowBuffs;
			var nowRules = UsableArmyRules;
			var nowStrats = AffordableNowStratagems;
		}
		<section class="now-ribbon" aria-label="Available now">
			<div class="now-head">
				<span class="now-kicker">Now</span>
				<strong>@NowContextLabel</strong>
				<span class="now-count">@AvailableNowTotal</span>
			</div>
			@if (AvailableNowTotal == 0)
			{
				<p class="now-empty">Nothing scheduled for this battle window.</p>
			}
			else
			{
				<div class="now-actions" style="@($"--now-columns: {Math.Min(AvailableNowTotal, 3)}")">
					@foreach (var reminder in nowReminders)
					{
						<button type="button" class="now-action must" @onclick="() => FocusReminder(reminder.Unit)">
							<span class="na-type">Must resolve</span>
							<strong>@reminder.Label</strong>
							<small>@reminder.Unit.Name</small>
						</button>
					}
					@foreach (var action in nowAbilities)
					{
						var modelContext = AbilityModelContext(action.Unit, action.Ability);
						<button type="button" class="now-action ability" @onclick="() => OpenAbilityCard(action.Unit, action.Ability)">
							<span class="na-type">@(HasEffectKeywords(action.Ability) ? "Effect" : action.Ability.IsEnhancement ? "Enhancement" : "Ability")</span>
							<strong>@action.Ability.Ability.Name</strong>
							@if (modelContext is not null)
							{
								<small>@modelContext</small>
							}
						</button>
					}
					@foreach (var action in nowBuffs)
					{
						<button type="button" class="now-action ability" @onclick="() => OpenBuffCard(action.Unit, action.Buff)">
							<span class="na-type">Detachment</span>
							<strong>@action.Buff.Label</strong>
						</button>
					}
					@foreach (var rule in nowRules)
					{
						<button type="button" class="now-action rule" @onclick="() => OpenNowRule(rule)">
							<span class="na-type">Army rule</span>
							<strong>@rule.Name</strong>
						</button>
					}
					@foreach (var strat in nowStrats)
					{
						var cost = EffectiveCost(strat, StratContextUnit);
						var modelContext = StratagemModelContext(strat);
						<button type="button" class="now-action stratagem" @onclick="() => OpenNowStratagem(strat)">
							<span class="na-type">Stratagem · @cost CP</span>
							<strong>@strat.Name</strong>
							@if (modelContext is not null)
							{
								<small>@modelContext</small>
							}
						</button>
					}
				</div>
			}
		</section>

		@{ var usableRules = UsableArmyRules; }
		@if (usableRules.Count > 0)
		{
			<section class="army-now" aria-label="Army rules usable now">
				<span class="an-head">Army rules — usable now</span>
				<ul class="an-list">
					@foreach (var rule in usableRules)
					{
						var ruleOpen = _openArmyRules.Contains(rule.Name);
						<li class="an-item @(ruleOpen ? "open" : "")" @key="rule.Name">
							<button type="button" class="an-toggle" @onclick="() => ToggleArmyRule(rule.Name)" aria-expanded="@ruleOpen">
								<span class="chev" aria-hidden="true">@(ruleOpen ? "▾" : "▸")</span>
								<span class="an-name">@rule.Name</span>
							</button>
							@if (ruleOpen)
							{
								<p class="a-text">@rule.Text</p>
							}
						</li>
					}
				</ul>
			</section>
		}

		@if (_battle.Units.Count == 0)
		{
			<div class="card empty">
				<p>This roster has no units yet.</p>
			</div>
		}
		else
		{
			<div class="@(_cardSwipe ? "deck" : null)" @ref="_deckRef" @onkeydown="OnDeckKeyDown" tabindex="@(_cardSwipe ? 0 : -1)">
			<ul class="unit-list">
				@foreach (var unit in UnitsToRender)
				{
					var dead = IsDead(unit);
					var collapsed = IsCollapsed(unit);
					var reanimate = MyCommandPhase && NeedsReanimation(unit);
					var battleShock = MyCommandPhase && NeedsBattleShock(unit);
					var effectAlways = unit.CombinedAbilities.Where(IsEffectAlways).ToList();
					var keywordAbilities = unit.CombinedAbilities.Where(a => !HasEffectKeywords(a) && a.HasManualKeyword).ToList();
					var alwaysAbilities = unit.CombinedAbilities.Where(a => !HasEffectKeywords(a) && !a.HasManualKeyword && a.IsAlwaysAvailable).ToList();
					var coreAbilities = unit.CoreAbilities;
					var warlordShown = unit.IsWarlord;
					var hasAbilityLine = !dead && (keywordAbilities.Count > 0 || alwaysAbilities.Count > 0 || coreAbilities.Count > 0 || effectAlways.Count > 0);
					<li class="unit @(dead ? "dead" : "") @((reanimate || battleShock) ? "attention" : "")" @key="unit.Id">
						<div class="u-head">
							<button class="u-toggle" type="button" @onclick="() => ToggleCard(unit)"
									aria-expanded="@(!collapsed)" aria-label="@($"Toggle {unit.Name}")">
								<span class="chev" aria-hidden="true">@(collapsed ? "▸" : "▾")</span>
								<span class="u-titles">
									@if (!_cardSwipe)
									{
										<span class="u-name">@unit.Name</span>
									}
									<span class="u-chips">
											@* Line 1 — Invulnerable, Feel No Pain, then Warlord (fixed slots; "-" placeholder when absent) *@
											<span class="chip-line">
												@if (unit.InvulnerableSaves.Count > 0)
												{
													@foreach (var inv in unit.InvulnerableSaves)
													{
														<span class="chip inv @(inv.UnitWide ? "scope-unit" : "scope-model")" title="@(inv.UnitWide ? "Whole unit" : inv.ModelName + " only")">
															@inv.Value inv<span class="scope">@(inv.UnitWide ? "unit" : inv.ModelName)</span>
														</span>
													}
												}
												else
												{
													<span class="chip ph" aria-hidden="true">— inv</span>
												}
												@if (unit.FeelNoPains.Count > 0)
												{
													@foreach (var fnp in unit.FeelNoPains)
													{
														<span class="chip fnp @(fnp.UnitWide ? "scope-unit" : "scope-model")" title="@(fnp.UnitWide ? "Whole unit" : fnp.ModelName + " only")">
															FNP @fnp.Value<span class="scope">@(fnp.UnitWide ? "unit" : fnp.ModelName)</span>
														</span>
													}
												}
												else
												{
													<span class="chip ph" aria-hidden="true">— FNP</span>
												}
												@if (warlordShown)
												{
													<span class="chip warlord">Warlord</span>
												}
											</span>
										@* Line 2 — always-available abilities and keywords; current-window actions live only in the Now ribbon. *@
											<span class="chip-line">
												@if (hasAbilityLine)
												{
													@foreach (var a in keywordAbilities)
													{
														<span class="chip keyword" role="button" tabindex="0"
															  title="@($"{a.Ability.Name} — tap to read its rules")"
															  @onclick="() => OpenAbilityCard(unit, a)" @onclick:stopPropagation="true"
															  @onkeydown="e => OnAbilityChipKey(e, unit, a)" @onkeydown:stopPropagation="true">
															@a.ManualKeyword
														</span>
													}
													@foreach (var a in alwaysAbilities)
													{
														<span class="chip ability @(a.IsEnhancement ? "enh" : "")" role="button" tabindex="0"
															  title="@($"{a.Ability.Name} — tap to read its rules")"
															  @onclick="() => OpenAbilityCard(unit, a)" @onclick:stopPropagation="true"
															  @onkeydown="e => OnAbilityChipKey(e, unit, a)" @onkeydown:stopPropagation="true">
															@a.Ability.Name
														</span>
													}
													@foreach (var a in effectAlways)
													{
														<span class="chip effect toggle @(IsEffectActive(unit, a) ? "on" : "")" role="button" tabindex="0"
															  title="@($"{a.Ability.Name} — tap; switch on to apply {EffectLabel(a)} to this unit's weapons")"
															  @onclick="() => OpenAbilityCard(unit, a)" @onclick:stopPropagation="true"
															  @onkeydown="e => OnAbilityChipKey(e, unit, a)" @onkeydown:stopPropagation="true">
															@a.Ability.Name
														</span>
													}
													@foreach (var a in coreAbilities)
													{
														<span class="chip ability" role="button" tabindex="0"
															  title="@($"{a.Ability.Name} — tap to read its rules")"
															  @onclick="() => OpenAbilityCard(unit, a)" @onclick:stopPropagation="true"
															  @onkeydown="e => OnAbilityChipKey(e, unit, a)" @onkeydown:stopPropagation="true">
															@a.Ability.Name
														</span>
													}
												}
												else
												{
													<span class="chip ph" aria-hidden="true">— always-on</span>
												}
											</span>
										</span>
								</span>
							</button>
							@if (unit.Parts.Count == 1 && unit.Primary.TracksWounds)
							{
								<span class="u-models" title="Wounds remaining">
									<span class="um-value @(dead ? "gone" : "")">@PartCurrent(unit.Primary)<span class="um-max">/@unit.Primary.TrackMax</span></span>
									<span class="um-label">wounds</span>
								</span>
							}
							else
							{
								<span class="u-models" title="Models remaining">
									<span class="um-value @(dead ? "gone" : "")">@GroupModels(unit)</span>
									<span class="um-label">@(GroupModels(unit) == 1 ? "model" : "models")</span>
								</span>
							}
						</div>

						@if (!collapsed)
						{
							<div class="u-body">
								@* Per-member statline (M/T/SV/W/LD/OC) as wrapping chips — fits any width, never side-scrolls. *@
								<div class="statlines">
									@foreach (var part in unit.Parts)
									{
										var p = part.Profile;
										<div class="statline @(PartDown(part) ? "down" : "") @(IsMemberSelected(unit, part) ? "member-on" : "") @(MemberDimmed(unit, part) ? "member-off" : "")" @key="part.Unit.Id">
											<div class="sl-top">
												@if (unit.Parts.Count > 1)
												{
													<button type="button" class="sname-btn @(IsMemberSelected(unit, part) ? "on" : "")" @onclick="() => ToggleMember(unit, part)" title="@($"{part.Datasheet.Name}{(part.IsLeader ? " (Leader)" : "")} — highlight this model's weapons; tap again to clear")">
														@(ShortName(part.Datasheet.Name) + (part.IsLeader ? " *" : ""))
													</button>
												}
												else
												{
													<span class="sname" title="@part.Datasheet.Name">@ShortName(part.Datasheet.Name)</span>
												}
												<span class="counter" title="@(part.TracksWounds ? "Wounds remaining" : "Models remaining")">
													<button type="button" @onclick="() => StepPart(part, -1)" aria-label="@(part.TracksWounds ? "Lose a wound" : "Remove a model")">−</button>
													<span class="c-value">@PartCurrent(part)<span class="c-max">/@part.TrackMax</span></span>
													<button type="button" @onclick="() => StepPart(part, 1)" aria-label="@(part.TracksWounds ? "Restore a wound" : "Add a model")">+</button>
													@if (part.TracksWounds)
													{
														<span class="c-tag" title="Wounds">W</span>
													}
												</span>
											</div>
											@{ var uMods = _battle.UnitStatModifiers(unit, part); }
											<div class="statgrid">
												<div class="st @(StatBuffed(p?.Move, uMods, StatTarget.Move) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Move)"><span class="lab">M</span><span class="val">@StatCell(p?.Move, uMods, StatTarget.Move)</span></div>
												<div class="st @(StatBuffed(p?.Toughness, uMods, StatTarget.Toughness) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Toughness)"><span class="lab">T</span><span class="val">@StatCell(p?.Toughness, uMods, StatTarget.Toughness)</span></div>
												<div class="st @(StatBuffed(p?.Save, uMods, StatTarget.Save) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Save)"><span class="lab">SV</span><span class="val">@StatCell(p?.Save, uMods, StatTarget.Save)</span></div>
												<div class="st @(StatBuffed(p?.Wounds, uMods, StatTarget.Wounds) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Wounds)"><span class="lab">W</span><span class="val">@StatCell(p?.Wounds, uMods, StatTarget.Wounds)</span></div>
												<div class="st @(StatBuffed(p?.Leadership, uMods, StatTarget.Leadership) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Leadership)"><span class="lab">LD</span><span class="val">@StatCell(p?.Leadership, uMods, StatTarget.Leadership)</span></div>
												<div class="st @(StatBuffed(p?.ObjectiveControl, uMods, StatTarget.ObjectiveControl) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.ObjectiveControl)"><span class="lab">OC</span><span class="val">@StatCell(p?.ObjectiveControl, uMods, StatTarget.ObjectiveControl)</span></div>
											</div>
										</div>
									}
								</div>

								@{
									var ranged = unit.Parts.SelectMany(p => p.RangedWeapons.Select(w => (Part: p, Weapon: w))).ToList();
									var melee = unit.Parts.SelectMany(p => p.MeleeWeapons.Select(w => (Part: p, Weapon: w))).ToList();
									var shootChoices = _battle.WeaponChoicesFor(unit);
									var shootOptions = shootChoices.SelectMany(c => c.Options)
										.Concat(_battle.ExtraShootingOptions(unit))
										.Distinct(StringComparer.OrdinalIgnoreCase)
										.ToList();
								}
								@if (_phase == BattlePhase.Shooting && shootOptions.Count > 0)
								{
									<div class="shoot-choice">
										<span class="sc-label">@(shootChoices.Count > 0 ? shootChoices[0].Name : "Shooting ability")</span>
										<div class="sc-opts">
											@foreach (var opt in shootOptions)
											{
												<button type="button" class="sc-opt @(IsChoiceSelected(unit, opt) ? "on" : "")" @onclick="() => ToggleChoice(unit, opt)">@opt</button>
											}
										</div>
									</div>
								}
								@if (ranged.Count > 0)
								{
									<div class="weapon-block ranged @(_phase == BattlePhase.Shooting ? "phase-on" : "")">
										<div class="wb-head">
											<span class="wb-title">Ranged</span>
											@if (_phase == BattlePhase.Shooting)
											{
												<span class="wb-now">Current phase</span>
											}
										</div>
										<ul class="weapon-list">
											@foreach (var row in ranged)
											{
												<li class="weapon @(IsMemberSelected(unit, row.Part) ? "member-on" : "") @(MemberDimmed(unit, row.Part) ? "member-off" : "")" @key="row.Weapon">
													@{
														var rwMods = _battle.WeaponStatModifiers(unit, row.Part, ranged: true).Concat(ActiveBuffModifiers(unit, ranged: true)).ToList();
														var rGrants = _battle.GrantedWeaponAbilities(unit, row.Part, ranged: true).Concat(ActiveWeaponEffects(unit, row.Weapon)).Distinct(StringComparer.OrdinalIgnoreCase).ToList();
														var rChosen = _phase == BattlePhase.Shooting ? SelectedChoice(unit) : null; var rCarry = WeaponModelsAlive(row.Part, row.Weapon);
													}
													<div class="w-top">
														<span class="wname">@(row.Weapon.Count > 1 ? $"{row.Weapon.Count}× " : "")@row.Weapon.Name</span>
														<span class="w-total" title="Total attacks at current model count">@TotalAttacks(row.Part, row.Weapon, rwMods) A</span>
													</div>
													@if (row.Part.IsPerModelWeapon(row.Weapon) || unit.Parts.Count > 1 || row.Weapon.Keywords.Count > 0 || rGrants.Count > 0 || rChosen is not null)
													{
														<div class="w-meta">
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc" title="@row.Part.Datasheet.Name">@ShortName(row.Part.Datasheet.Name)</span>
															}
															@foreach (var kw in row.Weapon.Keywords)
															{
																<span class="wkw">@kw</span>
															}
															@if (row.Part.IsPerModelWeapon(row.Weapon)){<span class="wcarry" title="Models carrying this weapon">@rCarry @(rCarry == 1 ? "model" : "models")</span>} @foreach (var g in rGrants)
															{
																<span class="wkw granted" title="Conferred by your detachment or an attached leader">@g</span>
															}
															@if (rChosen is not null)
															{
																<span class="wkw chosen" title="Selected this Shooting phase">@rChosen</span>
															}
														</div>
													}
													<div class="statgrid weapongrid">
														<div class="st clickable @(IsCellSelected(row.Weapon, KRng) ? "selected" : "") @(StatBuffed(row.Weapon.Range, rwMods, StatTarget.Range) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Range)" @onclick="() => ToggleCell(row.Weapon, KRng)"><span class="lab">Rng</span><span class="val">@StatCell(row.Weapon.Range, rwMods, StatTarget.Range)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KA) ? "selected" : "") @(StatBuffed(row.Weapon.Attacks, rwMods, StatTarget.Attacks) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Attacks)" @onclick="() => ToggleCell(row.Weapon, KA)"><span class="lab">A</span><span class="val">@StatCell(row.Weapon.Attacks, rwMods, StatTarget.Attacks)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KBs) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KBs)"><span class="lab">BS</span><span class="val">@Dash(row.Weapon.Skill)</span>@if (!AutoHits(row.Weapon.Skill)){@if (HitModifier(rwMods) is var rh && rh != 0){<span class="hitmod @(rh > 0 ? "up" : "down")" title="@(SignedMod(rh)) to the Hit roll">(@(SignedMod(rh)))</span>}@if (_battle.CriticalHitOn(unit, row.Part, ranged: true) is { } rc){<span class="crit" title="Critical Hit on @(rc)+">(@(rc)+)</span>}}</div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KS) ? "selected" : "") @(StatBuffed(row.Weapon.Strength, rwMods, StatTarget.Strength) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Strength)" @onclick="() => ToggleCell(row.Weapon, KS)"><span class="lab">S</span><span class="val">@StatCell(row.Weapon.Strength, rwMods, StatTarget.Strength)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KAp) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KAp)"><span class="lab">AP</span><span class="val">@Dash(row.Weapon.ArmourPenetration)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KD) ? "selected" : "") @(StatBuffed(row.Weapon.Damage, rwMods, StatTarget.Damage) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Damage)" @onclick="() => ToggleCell(row.Weapon, KD)"><span class="lab">D</span><span class="val">@StatCell(row.Weapon.Damage, rwMods, StatTarget.Damage)</span></div>
													</div>
												</li>
											}
										</ul>
									</div>
								}
								@if (melee.Count > 0)
								{
									<div class="weapon-block melee @(_phase == BattlePhase.Fight ? "phase-on" : "")">
										<div class="wb-head">
											<span class="wb-title">Melee</span>
											@if (_phase == BattlePhase.Fight)
											{
												<span class="wb-now">Current phase</span>
											}
										</div>
										<ul class="weapon-list">
											@foreach (var row in melee)
											{
												<li class="weapon @(IsMemberSelected(unit, row.Part) ? "member-on" : "") @(MemberDimmed(unit, row.Part) ? "member-off" : "")" @key="row.Weapon">
													@{
														var mwMods = _battle.WeaponStatModifiers(unit, row.Part, ranged: false).Concat(ActiveBuffModifiers(unit, ranged: false)).ToList();
														var mGrants = _battle.GrantedWeaponAbilities(unit, row.Part, ranged: false).Concat(ActiveWeaponEffects(unit, row.Weapon)).Distinct(StringComparer.OrdinalIgnoreCase).ToList(); var mCarry = WeaponModelsAlive(row.Part, row.Weapon);
													}
													<div class="w-top">
														<span class="wname">@(row.Weapon.Count > 1 ? $"{row.Weapon.Count}× " : "")@row.Weapon.Name</span>
														<span class="w-total" title="Total attacks at current model count">@TotalAttacks(row.Part, row.Weapon, mwMods) A</span>
													</div>
													@if (row.Part.IsPerModelWeapon(row.Weapon) || unit.Parts.Count > 1 || row.Weapon.Keywords.Count > 0 || mGrants.Count > 0)
													{
														<div class="w-meta">
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc" title="@row.Part.Datasheet.Name">@ShortName(row.Part.Datasheet.Name)</span>
															}
															@foreach (var kw in row.Weapon.Keywords)
															{
																<span class="wkw">@kw</span>
															}
															@if (row.Part.IsPerModelWeapon(row.Weapon)){<span class="wcarry" title="Models carrying this weapon">@mCarry @(mCarry == 1 ? "model" : "models")</span>} @foreach (var g in mGrants)
															{
																<span class="wkw granted" title="Conferred by your detachment or an attached leader">@g</span>
															}
														</div>
													}
													<div class="statgrid weapongrid">
														<div class="st clickable @(IsCellSelected(row.Weapon, KRng) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KRng)"><span class="lab">Rng</span><span class="val">@Dash(row.Weapon.Range)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KA) ? "selected" : "") @(StatBuffed(row.Weapon.Attacks, mwMods, StatTarget.Attacks) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Attacks)" @onclick="() => ToggleCell(row.Weapon, KA)"><span class="lab">A</span><span class="val">@StatCell(row.Weapon.Attacks, mwMods, StatTarget.Attacks)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KWs) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KWs)"><span class="lab">WS</span><span class="val">@Dash(row.Weapon.Skill)</span>@if (!AutoHits(row.Weapon.Skill)){@if (HitModifier(mwMods) is var mh && mh != 0){<span class="hitmod @(mh > 0 ? "up" : "down")" title="@(SignedMod(mh)) to the Hit roll">(@(SignedMod(mh)))</span>}@if (_battle.CriticalHitOn(unit, row.Part, ranged: false) is { } mc){<span class="crit" title="Critical Hit on @(mc)+">(@(mc)+)</span>}}</div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KS) ? "selected" : "") @(StatBuffed(row.Weapon.Strength, mwMods, StatTarget.Strength) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Strength)" @onclick="() => ToggleCell(row.Weapon, KS)"><span class="lab">S</span><span class="val">@StatCell(row.Weapon.Strength, mwMods, StatTarget.Strength)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KAp) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KAp)"><span class="lab">AP</span><span class="val">@Dash(row.Weapon.ArmourPenetration)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KD) ? "selected" : "") @(StatBuffed(row.Weapon.Damage, mwMods, StatTarget.Damage) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Damage)" @onclick="() => ToggleCell(row.Weapon, KD)"><span class="lab">D</span><span class="val">@StatCell(row.Weapon.Damage, mwMods, StatTarget.Damage)</span></div>
													</div>
												</li>
											}
										</ul>
									</div>
								}

								@{
										// The card body lists only genuine reference abilities: unscheduled rules text (no phase window,
										// not always-on, not a manual keyword) such as Resurrection orb. Abilities whose effect is
										// already surfaced above — applied conferrals/enhancements (shown as inv/FNP chips or buffed
										// stat cells) and phase-scheduled actions (shown in the Now ribbon) — are intentionally excluded.
										var referenceAbilities = unit.CombinedAbilities
											.Where(a => a.AppliedSummary is null
												&& !a.IsAlwaysAvailable && !a.HasManualKeyword && a.Windows.Count == 0)
											.ToList();
									}
								@if (referenceAbilities.Count > 0)
								{
									<ul class="abilities">
										@foreach (var a in referenceAbilities)
											{
												var hasText = !string.IsNullOrWhiteSpace(a.Ability.Text);
												var activeNow = BattleUnit.IsAbilityActiveInPhase(a, _phase, _turn);
												var open = IsAbilityOpen(unit, a);
												<li class="ability @(a.IsEnhancement ? "enh" : "") @(activeNow ? "now" : "") @(open ? "open" : "")" @key="a.Ability.Name">
													@if (hasText)
												{
													<button type="button" class="a-toggle" @onclick="() => ToggleAbility(unit, a)" aria-expanded="@open">
														<span class="chev" aria-hidden="true">@(open ? "▾" : "▸")</span>
														<span class="a-name">
															@a.Ability.Name
															@if (a.IsEnhancement)
															{
																<span class="a-tag enh">Enhancement</span>
															}
															@if (activeNow)
															{
																<span class="a-tag now" title="@($"Usable in the {BattlePhases.Label(_phase)} phase")">Usable now</span>
															}
															@if (unit.Parts.Count > 1)
															{
																<span class="a-src">@a.Source</span>
															}
														</span>
													</button>
													@if (open)
													{
														<p class="a-text">@Clean(a.Ability.Text)</p>
													}
												}
												else
												{
													<div class="a-row">
														<span class="a-name">
															@a.Ability.Name
															@if (a.IsEnhancement)
															{
																<span class="a-tag enh">Enhancement</span>
															}
															@if (unit.Parts.Count > 1)
															{
																<span class="a-src">@a.Source</span>
															}
														</span>
													</div>
												}
											</li>
									}
								</ul>
							}

								@if (!_cardSwipe)
									{
										<div class="u-foot">
											<button class="ds-link" type="button" @onclick="() => OpenDetail(unit)">Full datasheet →</button>
										</div>
									}
						</div>
					}
					</li>
				}
			</ul>
			</div>
		}
		<div class="topbar">
			<div class="topbar-actions">
				@if (!_cardSwipe)
				{
					<button class="btn small ghost" type="button" @onclick="ToggleCollapseAll" title="Collapse or expand all cards">
						@(AllCollapsed ? "Expand all" : "Collapse all")
					</button>
				}
				else if (ActiveUnit is { } focused)
				{
					<button class="btn small ghost" type="button" @onclick="() => OpenDetail(focused)" title="Full datasheet for the focused unit">Datasheet</button>
				}
				@if (ArmyRules.Count > 0 || _battle.Detachments.Count > 0)
				{
					<button class="btn small ghost" type="button" @onclick="OpenRules" title="Army &amp; detachment rules">Rules</button>
				}
				<button class="btn small ghost" type="button" @onclick="OpenRulebook" title="Core Rules lookup">Rulebook</button>
				<button class="btn small ghost" type="button" @onclick="OpenVp" title="Victory points">VPs</button>
				@if (_activeEffects.Count > 0)
				{
					<button class="btn small ghost reset" type="button" @onclick="ResetAbilities" title="Switch off all activated abilities (keeps CP, VP, models)">Reset abilities</button>
				}
				<button class="btn small ghost reset" type="button" @onclick="RequestReset" title="Reset CP, VP and models">Reset</button>
			</div>
		</div>
			<a class="back" href="@($"rosters/{Id}")">&larr; Edit army</a>
		</div>
	}

	<Sheet Open="_rulebookOpen" Eyebrow="Core Rules" Title="Rules lookup" OnCloseRequested="CloseRulebook">
		<RulesAssistantPanel />
	</Sheet>

	<Sheet Open="_vpOpen" Eyebrow="Score" Title="Victory points" OnCloseRequested="CloseVp">
		<div class="vp" aria-label="Victory points">
			<div class="vp-grid">
				<span class="vp-corner">VP</span>
				<span class="vp-h">You</span>
				<span class="vp-h">Opp</span>

				<span class="vp-rl">Primary</span>
				<span class="vp-cell">
					<button type="button" @onclick="() => StepVp(0, -1)" aria-label="Your primary minus">−</button>
					<span class="vp-n">@_vpYouPrimary</span>
					<button type="button" @onclick="() => StepVp(0, 1)" aria-label="Your primary plus">+</button>
				</span>
				<span class="vp-cell">
					<button type="button" @onclick="() => StepVp(1, -1)" aria-label="Opponent primary minus">−</button>
					<span class="vp-n">@_vpOppPrimary</span>
					<button type="button" @onclick="() => StepVp(1, 1)" aria-label="Opponent primary plus">+</button>
				</span>

				<span class="vp-rl">Second.</span>
				<span class="vp-cell">
					<button type="button" @onclick="() => StepVp(2, -1)" aria-label="Your secondary minus">−</button>
					<span class="vp-n">@_vpYouSecondary</span>
					<button type="button" @onclick="() => StepVp(2, 1)" aria-label="Your secondary plus">+</button>
				</span>
				<span class="vp-cell">
					<button type="button" @onclick="() => StepVp(3, -1)" aria-label="Opponent secondary minus">−</button>
					<span class="vp-n">@_vpOppSecondary</span>
					<button type="button" @onclick="() => StepVp(3, 1)" aria-label="Opponent secondary plus">+</button>
				</span>

				<span class="vp-rl total">Total</span>
				<span class="vp-total">@(_vpYouPrimary + _vpYouSecondary)</span>
				<span class="vp-total">@(_vpOppPrimary + _vpOppSecondary)</span>
			</div>
		</div>
	</Sheet>

	<Sheet Open="_confirmReset" Eyebrow="Confirm" Title="Reset this game?" OnCloseRequested="CancelReset">
		<div class="reset-confirm">
			<p class="rc-text">This clears command points, victory points, model counts and the current phase back to the start. This can't be undone.</p>
			<div class="rc-actions">
				<button class="btn danger" type="button" @onclick="ConfirmReset">Reset everything</button>
				<button class="btn ghost" type="button" @onclick="CancelReset">Cancel</button>
			</div>
		</div>
	</Sheet>

	<Sheet Open="@(_loadoutPart is not null)"
		   Eyebrow="@(_loadoutDelta < 0 ? "Casualty" : "Reinforce")"
		   Title="@(_loadoutDelta < 0 ? "Remove which model?" : "Return which model?")"
		   OnCloseRequested="CancelLoadoutChoice">
		@if (_loadoutPart is { } lp)
		{
			<div class="loadout-pick">
				@foreach (var opt in LoadoutOptions(lp, _loadoutDelta))
				{
					<button class="btn loadout-opt" type="button" @onclick="() => ApplyLoadoutChoice(opt.Weapon)">
						<span class="lo-name">@opt.Weapon.Name</span>
						<span class="lo-count">@opt.Alive / @opt.Setup</span>
					</button>
				}
			</div>
		}
	</Sheet>

	<Sheet Open="_detail is not null" Eyebrow="Datasheet" Title="@_detail?.Name" OnCloseRequested="CloseDetail">
	@if (_detail is { } d)
	{
		<DatasheetDetail Datasheet="d.Primary.Datasheet" Catalogue="_catalogue" />
		@foreach (var part in d.Parts.Skip(1))
		{
			<div class="detail-extra">
				<h3 class="detail-extra-title">@part.Datasheet.Name (Leader)</h3>
				<DatasheetDetail Datasheet="part.Datasheet" Catalogue="_catalogue" />
			</div>
		}
	}
</Sheet>

	<Sheet Open="_abilityCard is not null"
		   Eyebrow="@(_abilityCard is { } e0 && HasEffectKeywords(e0) ? "Effect" : _abilityCard?.IsEnhancement == true ? "Enhancement" : _abilityCard?.HasManualKeyword == true ? "Keyword" : _abilityCard is { } e1 && BattleUnit.IsAbilityActiveInPhase(e1, _phase, _turn) ? "Usable now" : "Always available")"
		   Title="@_abilityCard?.Ability.Name" OnCloseRequested="CloseAbilityCard">
		@if (_abilityCard is { } ac)
		{
			@if (!string.IsNullOrWhiteSpace(ac.Source) && !string.Equals(ac.Source, ac.Ability.Name, StringComparison.OrdinalIgnoreCase))
			{
				<p class="a-src">@ac.Source</p>
			}
			@if (HasEffectKeywords(ac) && _abilityCardUnit is { } acu)
			{
				<label class="ac-toggle">
					<input type="checkbox" checked="@IsEffectActive(acu, ac)" @onchange="e => ToggleEffect(acu, ac, (bool)e.Value!)" />
					<span>Active now — apply @EffectLabel(ac) to this unit's weapons</span>
				</label>
			}
			@if (IsOncePerBattleAbility(ac) && _abilityCardUnit is { } opbu)
			{
				<label class="ac-toggle">
					<input type="checkbox" checked="@IsOncePerBattleUsed(OncePerBattleAbilityKey(opbu, ac))"
						   @onchange="e => SetOncePerBattleUsed(OncePerBattleAbilityKey(opbu, ac), (bool)e.Value!)" />
					<span>Used this battle — hide from currently-usable actions (once per battle)</span>
				</label>
			}
			<p class="a-text">@Clean(ac.Ability.Text)</p>
		}
	</Sheet>

	<Sheet Open="_buffCard is not null" Eyebrow="Detachment" Title="@_buffCard?.Label" OnCloseRequested="CloseBuffCard">
		@if (_buffCard is { } bc && _buffCardUnit is { } bcu)
		{
			<label class="ac-toggle">
				<input type="checkbox" checked="@IsBuffActive(bcu, bc)" @onchange="e => ToggleBuff(bcu, bc, (bool)e.Value!)" />
				<span>Active now — apply @BuffModifierLabel(bc) to this unit's weapons</span>
			</label>
			<p class="a-text">@bc.Effect</p>
		}
	</Sheet>

	<Sheet Open="_nowRule is not null" Eyebrow="Army rule" Title="@_nowRule?.Name" OnCloseRequested="CloseNowRule">
		@if (_nowRule is { } nowRule)
		{
			<p class="a-text">@nowRule.Text</p>
			@if (nowRule.HasExample)
			{
				<p class="ar-example"><span class="ar-label">Example</span> @nowRule.Example</p>
			}
		}
	</Sheet>

	<Sheet Open="_nowStratagem is not null" Eyebrow="Stratagem" Title="@_nowStratagem?.Name" OnCloseRequested="CloseNowStratagem">
		@if (_nowStratagem is { } nowStratagem)
		{
			<dl class="s-body now-detail">
				@if (!string.IsNullOrWhiteSpace(nowStratagem.When))
				{
					<dt>When</dt>
					<dd>@nowStratagem.When</dd>
				}
				@if (!string.IsNullOrWhiteSpace(nowStratagem.Target))
				{
					<dt>Target</dt>
					<dd>@nowStratagem.Target</dd>
				}
				@if (!string.IsNullOrWhiteSpace(nowStratagem.Effect))
				{
					<dt>Effect</dt>
					<dd>@nowStratagem.Effect</dd>
				}
				@if (!string.IsNullOrWhiteSpace(nowStratagem.Restrictions))
				{
					<dt>Restrictions</dt>
					<dd>@nowStratagem.Restrictions</dd>
				}
			</dl>
			@if (IsOncePerBattleStrat(nowStratagem))
			{
				<label class="ac-toggle">
					<input type="checkbox" checked="@IsOncePerBattleUsed(OncePerBattleStratKey(nowStratagem))"
						   @onchange="e => SetOncePerBattleUsed(OncePerBattleStratKey(nowStratagem), (bool)e.Value!)" />
					<span>Used this battle — hide from currently-usable actions (once per battle)</span>
				</label>
			}
			<button class="btn primary" type="button" @onclick="UseNowStratagem">
				Use · @EffectiveCost(nowStratagem, StratContextUnit) CP
			</button>
		}
	</Sheet>

<Sheet Open="_rulesOpen" Eyebrow="Reference" Title="Army &amp; detachment rules" OnCloseRequested="CloseRules">
	@if (ArmyRules.Count > 0)
	{
		<ul class="ar-list">
			@foreach (var rule in ArmyRules)
			{
				<li class="ar" @key="rule.Name">
					<div class="ar-name-row">
						<span class="ar-name">@rule.Name</span>
					</div>
					<p class="ar-text">@rule.Text</p>
					@if (rule.HasExample)
					{
						<p class="ar-example"><span class="ar-label">Example</span> @rule.Example</p>
					}
					@if (rule.HasLore)
					{
						<p class="ar-lore">@rule.Lore</p>
					}
				</li>
			}
		</ul>
	}
	@if (_battle is not null && _battle.Detachments.Count > 0)
	{
		<ul class="ar-list">
			@foreach (var det in _battle.Detachments)
			{
				@foreach (var rule in det.Rules)
				{
					<li class="ar" @key="(det.Id + rule.Name)">
						<div class="ar-name-row">
							<span class="ar-name">@rule.Name</span>
							<span class="ar-now">@det.Name · @det.DetachmentPoints DP</span>
						</div>
						<p class="ar-text">@rule.Text</p>
					</li>
				}
			}
		</ul>
	}
</Sheet>

@code {
	[Parameter] public string Id { get; set; } = "";

	private CatalogueData _catalogue = new();
	private Roster? _roster;
	private BattleRoster? _battle;

	private string? _loadedId;
	private bool _loading = true;
	private bool _authenticated;
	private bool _notFound;

	private BattlePhase _phase = BattlePhase.Command;
	private BattleTurn _turn = BattleTurn.Player;
	private BattleTurn _firstTurn = BattleTurn.Player;
	private int _round = 1;
	private int _cp;
	// Victory points: primary + secondary for each side (in-memory trackers).
	private int _vpYouPrimary;
	private int _vpYouSecondary;
	private int _vpOppPrimary;
	private int _vpOppSecondary;
	// Per-part current tracked value (models for multi-model units, wounds for single multi-wound models),
	// keyed by roster-unit id (in-memory, like the round/CP trackers).
	private readonly Dictionary<string, int> _track = new(StringComparer.Ordinal);

	// Models killed per weapon for a per-model loadout part (Lokhust Heavy Destroyers), keyed "partId|weaponName".
	// Kept in lock-step with _track (its sum of kills = the part's lost models) so each weapon's attacks reflect
	// which models the player chose to remove.
	private readonly Dictionary<string, int> _weaponKills = new(StringComparer.Ordinal);
	// Cards collapsed by the user, keyed by group id.
	private readonly HashSet<string> _collapsed = new(StringComparer.Ordinal);
	// Abilities expanded by the user (collapsed by default), keyed by unit id + ability name.
	private readonly HashSet<string> _openAbilities = new(StringComparer.Ordinal);
	// Per-unit selected detachment weapon-ability for the current Shooting phase (e.g. "Anti-INFANTRY 3+").
	private readonly Dictionary<string, string> _shootingChoice = new(StringComparer.Ordinal);
	private BattleUnit? _detail;
	// The always-available ability whose rules text is shown in a popup (tapped from its head chip). Null = closed.
	private BattleAbility? _abilityCard;
	private BattleUnit? _abilityCardUnit;
	// The conditional detachment buff whose rule text is shown in a popup (tapped from its toggle chip). Null = closed.
	private ConditionalUnitBuff? _buffCard;
	private BattleUnit? _buffCardUnit;
	private ArmyRule? _nowRule;
	private StratView? _nowStratagem;

	// Single-cell highlight on a weapon stat ("Rng", "A", "BS"…) so you can mark the exact spot you're on while
	// resolving an attack. Only the one cell you clicked lights up; click it again to clear.
	private const string KRng = "Rng";
	private const string KA = "A";
	private const string KBs = "BS";
	private const string KWs = "WS";
	private const string KS = "S";
	private const string KAp = "AP";
	private const string KD = "D";
	private (object Weapon, string Stat)? _selectedCell;

	// Per-card focus on a single member's weapons/statline (e.g. the Lychguard within Imotekh + Lychguard),
	// keyed by unit id -> selected part's roster-unit id. Click the member name again to clear.
	private readonly Dictionary<string, string> _selectedMember = new(StringComparer.Ordinal);

	// Whether the bottom control HUD is pinned (always visible) instead of floating/auto-hiding. User preference.
	private bool _hudSticky;

	// Swipe-deck layout: show one unit card at a time and page through them (vs the default vertical scroll list).
	private bool _cardSwipe;
	private int _activeCard;
	private ElementReference _deckRef;
	private ElementReference _dotsRef;
	private DotNetObjectReference<PlaySession>? _deckSelf;
	private bool _deckBound;
	private bool _reorderBound;
	// Set when the active card changes so OnAfterRenderAsync re-centres the active pill in the scrollable strip.
	private bool _centerActivePill;

	// Display order of the unit cards + their deck pills, by BattleUnit.Id (== RosterUnit.Id). Reordered by
	// long-press drag on the pills, mirrored into roster.Units, and persisted. _byId resolves an id to its
	// tracker-stable BattleUnit; _ordered is the cached materialised view rebuilt whenever _order changes.
	private readonly List<string> _order = [];
	private readonly List<BattleUnit> _ordered = [];
	private Dictionary<string, BattleUnit> _byId = new(StringComparer.Ordinal);
	private CancellationTokenSource? _saveCts;
	private bool _orderDirty;
	private CancellationTokenSource? _battleSaveCts;
	private DotNetObjectReference<PlaySession>? _sessionSelf;
	private bool _restorePending;
	private bool _battleStateReady;

	protected override async Task OnParametersSetAsync()
	{
		if (_loadedId == Id)
			return;
		_loadedId = Id;
		await LoadAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await JS.InvokeVoidAsync("tombworld.initScroll");
			_sessionSelf = DotNetObjectReference.Create(this);
			await JS.InvokeVoidAsync("tombworld.flushOnHide", _sessionSelf);
		}

		if (_restorePending)
		{
			_restorePending = false;
			await RestoreBattleStateAsync();
			StateHasChanged();
		}

		// Bind the touch-swipe handler once the deck element exists (swipe mode, roster loaded).
		if (_cardSwipe && _battle is { Units.Count: > 0 } && !_deckBound)
		{
			_deckBound = true;
			_deckSelf ??= DotNetObjectReference.Create(this);
			await JS.InvokeVoidAsync("tombworld.deck.attach", _deckRef, _deckSelf);
		}

		// Bind long-press drag-to-reorder once the deck pills exist (swipe mode, more than one unit).
		if (_cardSwipe && _ordered.Count > 1 && !_reorderBound)
		{
			_reorderBound = true;
			_deckSelf ??= DotNetObjectReference.Create(this);
			await JS.InvokeVoidAsync("tombworld.reorder.attach", _dotsRef, _deckSelf);
		}

		// Keep the active unit's pill in view as you page through cards.
		if (_centerActivePill && _cardSwipe && _ordered.Count > 1)
		{
			_centerActivePill = false;
			await JS.InvokeVoidAsync("tombworld.deck.center", _dotsRef);
		}
	}

	[JSInvokable]
	public void SwipeNext()
	{
		if (GoToCard(_activeCard + 1))
			StateHasChanged();
	}

	[JSInvokable]
	public void SwipePrev()
	{
		if (GoToCard(_activeCard - 1))
			StateHasChanged();
	}

	// Invoked from the long-press drag helper when a deck pill is dropped at a new slot. Moves the unit in the
	// display order (cards follow), keeps the unit you were viewing in view, mirrors the order into the roster,
	// and persists it.
	[JSInvokable]
	public void ReorderUnit(int from, int to)
	{
		if (_battle is null || from < 0 || from >= _order.Count)
			return;
		to = Math.Clamp(to, 0, _order.Count - 1);
		if (from == to)
			return;

		// Remember the unit currently on screen so it stays visible after the move.
		var activeId = _activeCard >= 0 && _activeCard < _ordered.Count ? _ordered[_activeCard].Id : null;

		var moved = _order[from];
		_order.RemoveAt(from);
		_order.Insert(to, moved);
		RebuildOrdered();

		if (activeId is not null)
		{
			var idx = _order.IndexOf(activeId);
			if (idx >= 0)
				_activeCard = idx;
		}

		MirrorOrderIntoRoster();
		ScheduleSave();
		StateHasChanged();
	}

	// Reorders roster.Units to match the displayed order so the choice persists with the roster. Units present
	// in the deck follow _order; any others (e.g. a unit whose datasheet is missing) keep their relative order
	// after them. OrderBy is stable, so equal-rank items preserve their original sequence.
	private void MirrorOrderIntoRoster()
	{
		if (_roster is null)
			return;
		var rank = new Dictionary<string, int>(StringComparer.Ordinal);
		for (var i = 0; i < _order.Count; i++)
			rank[_order[i]] = i;
		_roster.Units = _roster.Units
			.OrderBy(u => rank.TryGetValue(u.Id, out var r) ? r : int.MaxValue)
			.ToList();
	}

	// Persists the reordered roster after a short debounce so a flurry of drags coalesces into a single save.
	// The new order applies in-session immediately regardless; this just remembers it for next time.
	private void ScheduleSave()
	{
		_orderDirty = true;
		_saveCts?.Cancel();
		_saveCts?.Dispose();
		_saveCts = new CancellationTokenSource();
		_ = SaveOrderAsync(_saveCts.Token);
	}

	private async Task SaveOrderAsync(CancellationToken token)
	{
		try
		{
			await Task.Delay(700, token);
			if (_roster is not null)
			{
				await Api.SaveRosterAsync(_roster, token);
				_orderDirty = false;
			}
		}
		catch (OperationCanceledException)
		{
			// Superseded by a newer reorder or the page is going away; a later save (or dispose flush) covers it.
		}
		catch (Exception)
		{
			// Best-effort persistence — the order still applies for this session.
		}
	}

	private async Task LoadAsync()
	{
		_loading = true;
		_notFound = false;

		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
		{
			await Settings.InitializeAsync();
			_hudSticky = Settings.PlayHudSticky;
			_cardSwipe = Settings.PlayCardSwipe;

			if (_catalogue.Datasheets.Count == 0)
				_catalogue = await Api.GetCatalogueAsync();

			var roster = await Api.GetRosterAsync(Id);
			if (roster is null)
			{
				_notFound = true;
			}
			else
			{
				// Scheduling lives in the user's cross-roster library now: merge it over anything the roster still
				// carries (library wins) so timing is consistent everywhere, then build the battle from that.
				var library = await Api.GetScheduleLibraryAsync();
				roster.AbilitySchedules = library.EffectiveFor(roster);

				_roster = roster;
				_battle = BattleRoster.Build(roster, _catalogue);
				_byId = _battle.Units.ToDictionary(u => u.Id, StringComparer.Ordinal);
				_order.Clear();
				_order.AddRange(_battle.Units.Select(u => u.Id));
				RebuildOrdered();
				ResetTrackers();
				_restorePending = true;
			}
		}

		_loading = false;
	}

	private async Task RestoreBattleStateAsync()
	{
		if (_battle is null)
			return;
		try
		{
			var json = await JS.InvokeAsync<string?>("tombworld.battleState.get", Id);
			if (!string.IsNullOrWhiteSpace(json))
			{
				var state = JsonSerializer.Deserialize<BattleSessionState>(json);
				if (state is not null)
					ApplyBattleState(state);
			}
		}
		catch (Exception ex) when (ex is JsonException or JSException or InvalidOperationException)
		{
			// Invalid/stale storage and unavailable browser storage both degrade to the fresh in-memory state.
		}
		_battleStateReady = true;
	}

	private void ApplyBattleState(BattleSessionState state)
	{
		if (_battle is null)
			return;
		state.Normalize();
		_round = state.Round;
		_firstTurn = state.FirstTurn;
		_turn = state.Turn;
		_phase = state.Phase;
		_cp = state.CommandPoints;
		_vpYouPrimary = state.YourPrimaryVp;
		_vpYouSecondary = state.YourSecondaryVp;
		_vpOppPrimary = state.OpponentPrimaryVp;
		_vpOppSecondary = state.OpponentSecondaryVp;
		_cardSwipe = state.FocusMode;

		var parts = _battle.Units.SelectMany(u => u.Parts).ToDictionary(p => p.Unit.Id, StringComparer.Ordinal);
		foreach (var (id, value) in state.PartTracks)
			if (parts.TryGetValue(id, out var part))
				_track[id] = Math.Clamp(value, 0, part.TrackMax);

		var weaponKeys = _battle.Units.SelectMany(u => u.Parts)
			.SelectMany(p => p.Weapons.Where(p.IsPerModelWeapon).Select(w => (Key: WeaponKillKey(p, w), Max: p.ModelsCarrying(w))))
			.ToDictionary(x => x.Key, x => x.Max, StringComparer.Ordinal);
		_weaponKills.Clear();
		foreach (var (key, value) in state.WeaponKills)
			if (weaponKeys.TryGetValue(key, out var max) && value > 0)
				_weaponKills[key] = Math.Clamp(value, 0, max);

		var unitPrefixes = _battle.Units.Select(u => u.Id + "|").ToList();
		_activeEffects.Clear();
		foreach (var key in state.ActiveEffects)
			if (unitPrefixes.Any(prefix => key.StartsWith(prefix, StringComparison.Ordinal)))
				_activeEffects.Add(key);

		_shootingChoice.Clear();
		foreach (var (unitId, choice) in state.ShootingChoices)
			if (_byId.ContainsKey(unitId) && !string.IsNullOrWhiteSpace(choice))
				_shootingChoice[unitId] = choice;

		_usedOncePerBattle.Clear();
		foreach (var key in state.UsedOncePerBattle)
			if (!string.IsNullOrWhiteSpace(key))
				_usedOncePerBattle.Add(key);
		if (state.ActiveUnitId is not null)
		{
			var index = _order.IndexOf(state.ActiveUnitId);
			if (index >= 0)
				_activeCard = index;
		}
		if (_cardSwipe && _ordered.Count > 0)
			_collapsed.Remove(_ordered[Math.Clamp(_activeCard, 0, _ordered.Count - 1)].Id);
	}

	private BattleSessionState CaptureBattleState() => new()
	{
		Round = _round,
		FirstTurn = _firstTurn,
		Turn = _turn,
		Phase = _phase,
		CommandPoints = _cp,
		YourPrimaryVp = _vpYouPrimary,
		YourSecondaryVp = _vpYouSecondary,
		OpponentPrimaryVp = _vpOppPrimary,
		OpponentSecondaryVp = _vpOppSecondary,
		FocusMode = _cardSwipe,
		ActiveUnitId = ActiveUnit?.Id,
		PartTracks = new Dictionary<string, int>(_track, StringComparer.Ordinal),
		WeaponKills = new Dictionary<string, int>(_weaponKills, StringComparer.Ordinal),
		ActiveEffects = new HashSet<string>(_activeEffects, StringComparer.Ordinal),
		ShootingChoices = new Dictionary<string, string>(_shootingChoice, StringComparer.Ordinal),
		UsedOncePerBattle = new HashSet<string>(_usedOncePerBattle, StringComparer.Ordinal),
	};

	private void ScheduleBattleSave()
	{
		if (!_battleStateReady)
			return;
		_battleSaveCts?.Cancel();
		_battleSaveCts?.Dispose();
		_battleSaveCts = new CancellationTokenSource();
		_ = SaveBattleStateAsync(_battleSaveCts.Token);
	}

	private async Task SaveBattleStateAsync(CancellationToken token)
	{
		try
		{
			await Task.Delay(250, token);
			await PersistBattleStateAsync();
		}
		catch (OperationCanceledException)
		{
			// A newer state superseded this snapshot.
		}
		catch (Exception ex) when (ex is JSException or InvalidOperationException)
		{
			// Browser storage is best-effort; play remains fully functional in memory.
		}
	}

	private async Task PersistBattleStateAsync()
	{
		if (!_battleStateReady || _battle is null)
			return;
		var json = JsonSerializer.Serialize(CaptureBattleState());
		await JS.InvokeVoidAsync("tombworld.battleState.set", Id, json);
	}

	[JSInvokable]
	public Task FlushSave() => PersistBattleStateAsync();

	private void SelectPhase(BattlePhase phase)
	{
		// Detachment shooting picks last "until the end of the phase", so clear them when the phase changes.
		if (phase != _phase)
			_shootingChoice.Clear();
		_phase = phase;
		ScheduleBattleSave();
	}

	private void SetTurn(BattleTurn turn)
	{
		_turn = turn;
		ScheduleBattleSave();
	}

