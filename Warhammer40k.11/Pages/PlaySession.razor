	private static string? AbilityModelContext(BattleUnit unit, BattleAbility ability)
	{
		if (unit.Parts.Count <= 1 || ability.ApplyToUnit)
			return null;

		var text = ability.Ability.Text ?? "";
		if (text.Contains("this unit", StringComparison.OrdinalIgnoreCase)
			|| text.Contains("bearer's unit", StringComparison.OrdinalIgnoreCase)
			|| text.Contains("bearer’s unit", StringComparison.OrdinalIgnoreCase))
			return null;

		return text.Contains("this model", StringComparison.OrdinalIgnoreCase)
			|| text.Contains("bearer", StringComparison.OrdinalIgnoreCase)
			? ability.Source
			: null;
	}

	private string? StratagemModelContext(StratView stratagem)
	{
		if (NowUnit is not { Parts.Count: > 1 } unit
			|| string.IsNullOrWhiteSpace(stratagem.Target)
			|| !stratagem.Target.Contains("model", StringComparison.OrdinalIgnoreCase)
			|| stratagem.Target.Contains("unit", StringComparison.OrdinalIgnoreCase))
			return null;

		var (include, exclude) = TargetKeywords(stratagem.Target);
		var matches = unit.Parts
			.Where(p => !exclude.Any(kw => p.Datasheet.Keywords.Any(k => KeywordMatches(k, kw))))
			.Where(p => include.Count == 0 || include.Any(kw => p.Datasheet.Keywords.Any(k => KeywordMatches(k, kw))))
			.ToList();
		return matches.Count == 1 ? matches[0].Datasheet.Name : null;
	}

	private void UseNowStratagem()
	{
		if (_nowStratagem is not { } stratagem)
			return;
		UseStratagem(stratagem, StratContextUnit);
		// A once-per-battle stratagem is consumed when used, so mark it used automatically.
		if (IsOncePerBattleStrat(stratagem))
			SetOncePerBattleUsed(OncePerBattleStratKey(stratagem), true);
		_nowStratagem = null;
	}

