	// ---- Command-phase cues (your turn): which units must act this Command phase ----
	private bool MyCommandPhase => _phase == BattlePhase.Command && _turn == BattleTurn.Player;

	// A unit that has lost wounds or models (but isn't destroyed) should run Reanimation Protocols.
	private bool NeedsReanimation(BattleUnit unit) => !IsDead(unit) && unit.Parts.Any(PartHasLosses);

	// A unit Below Half-strength must take a Battle-shock test: by wounds for a lone single-model unit
	// (e.g. a Character), by models otherwise.
	private bool NeedsBattleShock(BattleUnit unit)
	{
		if (IsDead(unit))
			return false;
		if (unit.ModelCount == 1)
		{
			var only = unit.Primary;
			return only.TracksWounds && 2 * PartCurrent(only) < only.TrackMax;
		}
		return BattleStatus.BelowHalfStrength(unit.ModelCount, GroupModels(unit));
	}

	// Core Stratagems usable "in the actual second": filtered by the current phase + whose turn it is.
	// Core Stratagems (always available) plus the selected detachments' stratagems, filtered "in the actual
	// second" by phase + whose turn it is. You can hold stratagems from more than one detachment.
	private sealed record StratView(string Id, string Name, string Source, string Type, int Cost,
		string Flavour, string When, string Target, string Effect, string? Restrictions);

	// A run of ALL-CAPS keyword words, possibly joined by spaces or "/" (e.g. CRYPTEK, MONSTER/VEHICLE,
	// IMMORTALS/NECRON WARRIORS, NECRONS VEHICLE). Title-case words like "One"/"That" never match.
	private static readonly Regex KeywordRun = new(@"[A-Z][A-Z'\u2019]+(?:[ /][A-Z][A-Z'\u2019]+)*", RegexOptions.Compiled);
	// A "(excluding …)" qualifier in a Target clause; the captured group holds the excluded keywords.
	private static readonly Regex ExcludeClause = new(@"\((?:excluding|excludes|except|but not)\s+([^)]*)\)", RegexOptions.Compiled | RegexOptions.IgnoreCase);

	// Pulls the unit keywords a stratagem can affect from its "Target" clause: the ALL-CAPS keyword phrases it
	// targets, plus any "(excluding …)" keywords — so the row shows at a glance whether it's for a vehicle,
	// infantry, a Cryptek, etc., and which units are carved out.
	private static (IReadOnlyList<string> Include, IReadOnlyList<string> Exclude) TargetKeywords(string? target)
	{
		if (string.IsNullOrWhiteSpace(target))
			return ([], []);
		var exclude = new List<string>();
		foreach (Match m in ExcludeClause.Matches(target))
			foreach (Match k in KeywordRun.Matches(m.Groups[1].Value))
				AddKeyword(exclude, k.Value);
		var remainder = ExcludeClause.Replace(target, " ");
		var include = new List<string>();
		foreach (Match k in KeywordRun.Matches(remainder))
			AddKeyword(include, k.Value);
		return (include, exclude);
	}

	private static void AddKeyword(List<string> list, string value)
	{
		if (!list.Contains(value, StringComparer.OrdinalIgnoreCase))
			list.Add(value);
	}

	private IReadOnlyList<StratView> UsableStratagems
	{
		get
		{
			var list = PhaseTurnStratagems();
			// In swipe mode, narrow the list to stratagems the unit you're viewing can actually use, by matching
			// its keywords against the Target's required/excluded keywords. (List mode shows them all.)
			if (_cardSwipe && ActiveUnit is { } unit)
				list = list.Where(s => StratagemAppliesTo(unit, s.Target)).ToList();
			return list;
		}
	}

	// All stratagems usable in the current phase + turn (Core plus every selected detachment), before any
	// per-unit keyword narrowing or CP-affordability filtering. Shared by the panel and the per-pill counter.
	private List<StratView> PhaseTurnStratagems()
	{
		var list = new List<StratView>();
		if (_battle is not null)
		{
			foreach (var s in CoreStratagemCatalogue.All)
				if (_battle.CoreStratagemUsable(s, _phase, _turn))
					list.Add(new StratView(s.Id, s.Name, "Core", "", s.Cost, s.Flavour, s.When, s.Target, s.Effect, s.Restrictions));
			foreach (var det in _battle.Detachments)
				foreach (var s in det.Stratagems)
					if (_battle.DetachmentStratagemUsable(det, s, _phase, _turn))
						list.Add(new StratView(s.Id, s.Name, det.Name, s.Type, s.CpCost, "", s.When, s.Target, s.Effect, null));
		}
		return list;
	}

	// Stratagems available to this unit right now: usable in the phase/turn, affordable (respecting the CP
	// discount), and applicable to the unit by keyword. Drives the deck-pill stratagem badge so you can spot a
	// unit a stratagem applies to without flipping through every card.
	private int StratagemsNowCount(BattleUnit unit) =>
		PhaseTurnStratagems().Count(s => CanAfford(s, unit) && StratagemAppliesTo(unit, s.Target));

	private BattleUnit? ActiveUnit =>
		_ordered.Count > 0 ? _ordered[Math.Clamp(_activeCard, 0, _ordered.Count - 1)] : null;

	// A stratagem applies to a unit when the unit has at least one of the Target's required keywords (or there
	// are none) and none of its excluded keywords. CAPS keywords are parsed from the Target text (TargetKeywords).
	private bool StratagemAppliesTo(BattleUnit unit, string? target)
	{
		var (include, exclude) = TargetKeywords(target);
		bool Has(string kw) => unit.Parts.Any(p => p.Datasheet.Keywords.Any(k => KeywordMatches(k, kw)));
		if (exclude.Any(Has))
			return false;
		return include.Count == 0 || include.Any(Has);
	}

	// "My Will Be Done" (Overlord / Overlord with Translocation Shroud) reduces a Stratagem's cost by 1 CP, but
	// ONLY when that Stratagem is used to target the bearer's own unit, and ONLY when the player ticked
	// "Apply to unit" for it in setup. So the discount is scoped to that specific target unit; other units pay
	// the normal cost even while an Overlord leads a different unit.
	private bool UnitHasCpDiscount(BattleUnit unit) =>
		unit.Parts.Any(p => !PartDown(p) && p.ReducesStratagemCpCost
			&& unit.IsAbilityAppliedToUnit(p, BattlePart.MyWillBeDoneAbility));

	// The unit the Stratagem panel is currently scoped to: in swipe mode the active card (the target), otherwise
	// none — list mode isn't unit-targeted, so a row is discounted only when some eligible bearer unit exists.
	private BattleUnit? StratContextUnit => _cardSwipe ? ActiveUnit : null;

	private int EffectiveCost(StratView stratagem, BattleUnit? forUnit)
	{
		var discount = forUnit is not null
			? UnitHasCpDiscount(forUnit)
			: _battle is not null && _battle.Units.Any(u => !IsDead(u) && UnitHasCpDiscount(u) && StratagemAppliesTo(u, stratagem.Target));
		return Math.Max(0, stratagem.Cost - (discount ? 1 : 0));
	}

	private bool CanAfford(StratView stratagem, BattleUnit? forUnit) => _cp >= EffectiveCost(stratagem, forUnit);

	private void UseStratagem(StratView stratagem, BattleUnit? forUnit) => StepCp(-EffectiveCost(stratagem, forUnit));

	private void StepCp(int delta)
	{
		_cp = Math.Max(0, _cp + delta);
		ScheduleBattleSave();
	}

	private async Task ScrollTop() => await JS.InvokeVoidAsync("tombworld.scrollTop");

	private async Task ScrollBottom() => await JS.InvokeVoidAsync("tombworld.scrollBottom");

	// Victory points: 0 = your primary, 1 = opponent primary, 2 = your secondary, 3 = opponent secondary.
	private void StepVp(int which, int delta)
	{
		switch (which)
		{
			case 0: _vpYouPrimary = Math.Max(0, _vpYouPrimary + delta); break;
			case 1: _vpOppPrimary = Math.Max(0, _vpOppPrimary + delta); break;
			case 2: _vpYouSecondary = Math.Max(0, _vpYouSecondary + delta); break;
			case 3: _vpOppSecondary = Math.Max(0, _vpOppSecondary + delta); break;
		}
		ScheduleBattleSave();
	}

	// ---- Weapon stat selection (mark the exact cell you're on while resolving an attack) ----
	private bool IsCellSelected(object weapon, string stat) =>
		_selectedCell is { } c && ReferenceEquals(c.Weapon, weapon) && string.Equals(c.Stat, stat, StringComparison.Ordinal);

	private void ToggleCell(object weapon, string stat) =>
		_selectedCell = IsCellSelected(weapon, stat) ? null : (weapon, stat);

	// ---- Per-member weapon focus (distinguish models inside an attached unit) ----
	private bool IsMemberSelected(BattleUnit unit, BattlePart part) =>
		_selectedMember.TryGetValue(unit.Id, out var id) && string.Equals(id, part.Unit.Id, StringComparison.Ordinal);

	private bool MemberDimmed(BattleUnit unit, BattlePart part) =>
		_selectedMember.TryGetValue(unit.Id, out var id) && !string.Equals(id, part.Unit.Id, StringComparison.Ordinal);

	private void ToggleMember(BattleUnit unit, BattlePart part)
	{
		if (IsMemberSelected(unit, part))
			_selectedMember.Remove(unit.Id);
		else
			_selectedMember[unit.Id] = part.Unit.Id;
	}

	// ---- Detachment shooting choice (e.g. Cryptek "Technosorcerous Augmentations") ----
	private string? SelectedChoice(BattleUnit unit) =>
		_shootingChoice.TryGetValue(unit.Id, out var s) ? s : null;

	private bool IsChoiceSelected(BattleUnit unit, string option) =>
		string.Equals(SelectedChoice(unit), option, StringComparison.Ordinal);

	private void ToggleChoice(BattleUnit unit, string option)
	{
