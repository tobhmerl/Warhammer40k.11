@page "/play/{Id}"
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Play
@using Warhammer40k.Core.Rosters
@using Warhammer40k._11.Components
@inject IApiClient Api

<PageTitle>TombForge — @(_roster?.Name ?? "Play")</PageTitle>

@if (_loading)
{
	<div class="play">
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Loading roster&hellip;</p>
		</div>
	</div>
}
else if (!_authenticated)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">Sign in to play with your rosters.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	</div>
}
else if (_notFound || _roster is null || _battle is null)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">That roster could not be found.</p>
			<a class="btn ghost" href="play">&larr; Back to play</a>
		</div>
	</div>
}
else
{
	<div class="play">
		<a class="back" href="play">&larr; Play</a>

		<header class="sticky">
			<div class="title-row">
				<h1 class="rname">@_roster.Name</h1>
				<button class="btn small ghost" type="button" @onclick="ToggleCollapseAll" title="Collapse or expand all cards">
					@(AllCollapsed ? "Expand all" : "Collapse all")
				</button>
				<button class="btn small ghost" type="button" @onclick="ResetTrackers" title="Reset round, CP and models">Reset</button>
			</div>
			<div class="trackers">
				<div class="tracker">
					<span class="t-label">Round</span>
					<div class="stepper">
						<button type="button" @onclick="() => StepRound(-1)" aria-label="Previous round">−</button>
						<span class="t-value">@_round</span>
						<button type="button" @onclick="() => StepRound(1)" aria-label="Next round">+</button>
					</div>
				</div>
				<div class="tracker">
					<span class="t-label">CP</span>
					<div class="stepper">
						<button type="button" @onclick="() => StepCp(-1)" aria-label="Spend command point">−</button>
						<span class="t-value">@_cp</span>
						<button type="button" @onclick="() => StepCp(1)" aria-label="Gain command point">+</button>
					</div>
				</div>
				<div class="tracker units-left">
					<span class="t-label">Units</span>
					<span class="t-value">@AliveCount/@_battle.Units.Count</span>
				</div>
			</div>
		</header>

		<nav class="phases" aria-label="Battle phases">
			@foreach (var phase in BattlePhases.Ordered)
			{
				<button type="button" class="phase @(phase == _phase ? "on" : "")" @onclick="() => SelectPhase(phase)">
					<span class="ph-name">@BattlePhases.Label(phase)</span>
				</button>
			}
		</nav>

		@if (_battle.Units.Count == 0)
		{
			<div class="card empty">
				<p>This roster has no units yet.</p>
			</div>
		}
		else
		{
			<ul class="unit-list">
				@foreach (var unit in _battle.Units)
				{
					var dead = IsDead(unit);
					var collapsed = IsCollapsed(unit);
					<li class="unit @(dead ? "dead" : "")" @key="unit.Id">
						<div class="u-head">
							<button class="u-toggle" type="button" @onclick="() => ToggleCard(unit)"
									aria-expanded="@(!collapsed)" aria-label="@($"Toggle {unit.Name}")">
								<span class="chev" aria-hidden="true">@(collapsed ? "▸" : "▾")</span>
								<span class="u-titles">
									<span class="u-name">@unit.Name</span>
									<span class="u-chips">
										@if (unit.IsWarlord)
										{
											<span class="chip warlord">Warlord</span>
										}
										@if (unit.InvulnerableSave is { } inv)
										{
											<span class="chip inv">@inv inv</span>
										}
										@if (unit.FeelNoPain is { } fnp)
										{
											<span class="chip fnp">FNP @fnp</span>
										}
									</span>
								</span>
							</button>
							<span class="u-models" title="Models remaining">
								<span class="um-value @(dead ? "gone" : "")">@GroupModels(unit)</span>
								<span class="um-label">@(GroupModels(unit) == 1 ? "model" : "models")</span>
							</span>
						</div>

						@if (!collapsed)
						{
							<div class="u-body">
								@* Per-member statlines (M/T/SV/W/LD/OC) with an inline model counter at the end of each line. *@
								<div class="table-wrap">
									<table class="stats">
										<thead>
											<tr>
												<th class="lcell">Model</th>
												<th>M</th><th>T</th><th>SV</th><th>W</th><th>LD</th><th>OC</th>
												<th class="ccell">Models</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var part in unit.Parts)
											{
												var p = part.Profile;
												<tr class="@(PartDown(part) ? "down" : "")" @key="part.Unit.Id">
													<td class="lcell">
														<span class="sname">@part.Datasheet.Name@(part.IsLeader ? " (Leader)" : "")</span>
													</td>
													<td>@Dash(p?.Move)</td><td>@Dash(p?.Toughness)</td><td>@Dash(p?.Save)</td>
													<td>@Dash(p?.Wounds)</td><td>@Dash(p?.Leadership)</td><td>@Dash(p?.ObjectiveControl)</td>
													<td class="ccell">
														<span class="counter">
															<button type="button" @onclick="() => StepModels(part, -1)" aria-label="Remove a model">−</button>
															<span class="c-value">@PartModels(part)<span class="c-max">/@part.ModelCount</span></span>
															<button type="button" @onclick="() => StepModels(part, 1)" aria-label="Add a model">+</button>
														</span>
													</td>
												</tr>
											}
										</tbody>
									</table>
								</div>

								@{
									var ranged = unit.Parts.SelectMany(p => p.RangedWeapons.Select(w => (Part: p, Weapon: w))).ToList();
									var melee = unit.Parts.SelectMany(p => p.MeleeWeapons.Select(w => (Part: p, Weapon: w))).ToList();
								}
								@if (ranged.Count > 0)
								{
									<div class="table-wrap @(_phase == BattlePhase.Shooting ? "phase-on" : "")">
										<table class="weapons">
											<thead>
												<tr>
													<th class="lcell">Ranged</th>
													<th>Range</th><th>A</th><th class="acell">Total A</th><th>BS</th><th>S</th><th>AP</th><th>D</th>
												</tr>
											</thead>
											<tbody>
												@foreach (var row in ranged)
												{
													<tr @key="row.Weapon">
														<td class="lcell">
															<span class="wname">@row.Weapon.Name</span>
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc">@row.Part.Datasheet.Name</span>
															}
															@if (row.Weapon.Keywords.Count > 0)
															{
																<span class="wkw">@string.Join(", ", row.Weapon.Keywords)</span>
															}
														</td>
														<td>@Dash(row.Weapon.Range)</td><td>@Dash(row.Weapon.Attacks)</td>
														<td class="acell">@TotalAttacks(row.Part, row.Weapon)</td>
														<td>@Dash(row.Weapon.Skill)</td>
														<td>@Dash(row.Weapon.Strength)</td><td>@Dash(row.Weapon.ArmourPenetration)</td><td>@Dash(row.Weapon.Damage)</td>
													</tr>
												}
											</tbody>
										</table>
									</div>
								}
								@if (melee.Count > 0)
								{
									<div class="table-wrap @(_phase == BattlePhase.Fight ? "phase-on" : "")">
										<table class="weapons">
											<thead>
												<tr>
													<th class="lcell">Melee</th>
													<th>Rng</th><th>A</th><th class="acell">Total A</th><th>WS</th><th>S</th><th>AP</th><th>D</th>
												</tr>
											</thead>
											<tbody>
												@foreach (var row in melee)
												{
													<tr @key="row.Weapon">
														<td class="lcell">
															<span class="wname">@row.Weapon.Name</span>
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc">@row.Part.Datasheet.Name</span>
															}
															@if (row.Weapon.Keywords.Count > 0)
															{
																<span class="wkw">@string.Join(", ", row.Weapon.Keywords)</span>
															}
														</td>
														<td>@Dash(row.Weapon.Range)</td><td>@Dash(row.Weapon.Attacks)</td>
														<td class="acell">@TotalAttacks(row.Part, row.Weapon)</td>
														<td>@Dash(row.Weapon.Skill)</td>
														<td>@Dash(row.Weapon.Strength)</td><td>@Dash(row.Weapon.ArmourPenetration)</td><td>@Dash(row.Weapon.Damage)</td>
													</tr>
												}
											</tbody>
										</table>
									</div>
								}

								@if (unit.CombinedAbilities.Count > 0)
								{
									<ul class="abilities">
										@foreach (var a in unit.CombinedAbilities)
										{
											<li @key="a">
												<span class="a-name">
													@a.Ability.Name
													@if (unit.Parts.Count > 1)
													{
														<span class="a-src">@a.Source</span>
													}
											</span>
											<span class="a-text">@Clean(a.Ability.Text)</span>
										</li>
									}
								</ul>
							}

								<div class="u-foot">
									<button class="ds-link" type="button" @onclick="() => OpenDetail(unit)">Full datasheet →</button>
								</div>
						</div>
					}
					</li>
				}
			</ul>
		}
	</div>
}

<Sheet Open="_detail is not null" Eyebrow="Datasheet" Title="@_detail?.Name" OnCloseRequested="CloseDetail">
	@if (_detail is { } d)
	{
		<DatasheetDetail Datasheet="d.Primary.Datasheet" Catalogue="_catalogue" />
		@foreach (var part in d.Parts.Skip(1))
		{
			<div class="detail-extra">
				<h3 class="detail-extra-title">@part.Datasheet.Name (Leader)</h3>
				<DatasheetDetail Datasheet="part.Datasheet" Catalogue="_catalogue" />
			</div>
		}
	}
</Sheet>

@code {
	[Parameter] public string Id { get; set; } = "";

	private CatalogueData _catalogue = new();
	private Roster? _roster;
	private BattleRoster? _battle;

	private string? _loadedId;
	private bool _loading = true;
	private bool _authenticated;
	private bool _notFound;

	private BattlePhase _phase = BattlePhase.Command;
	private int _round = 1;
	private int _cp;
	// Per-part current model count, keyed by roster-unit id (in-memory, like the round/CP trackers).
	private readonly Dictionary<string, int> _models = new(StringComparer.Ordinal);
	// Cards collapsed by the user, keyed by group id.
	private readonly HashSet<string> _collapsed = new(StringComparer.Ordinal);
	private BattleUnit? _detail;

	protected override async Task OnParametersSetAsync()
	{
		if (_loadedId == Id)
			return;
		_loadedId = Id;
		await LoadAsync();
	}

	private async Task LoadAsync()
	{
		_loading = true;
		_notFound = false;

		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
		{
			if (_catalogue.Datasheets.Count == 0)
				_catalogue = await Api.GetCatalogueAsync();

			var roster = await Api.GetRosterAsync(Id);
			if (roster is null)
			{
				_notFound = true;
			}
			else
			{
				_roster = roster;
				_battle = BattleRoster.Build(roster, _catalogue);
				ResetTrackers();
			}
		}

		_loading = false;
	}

	private void SelectPhase(BattlePhase phase) => _phase = phase;

	private void StepRound(int delta) => _round = Math.Max(1, _round + delta);

	private void StepCp(int delta) => _cp = Math.Max(0, _cp + delta);

	private void ResetTrackers()
	{
		_round = 1;
		_cp = 0;
		_phase = BattlePhase.Command;
		_models.Clear();
		_collapsed.Clear();
		if (_battle is null)
			return;
		foreach (var unit in _battle.Units)
			foreach (var part in unit.Parts)
				_models[part.Unit.Id] = part.ModelCount;
	}

	// ---- Per-part model tracking ----
	private int PartModels(BattlePart part) =>
		_models.TryGetValue(part.Unit.Id, out var m) ? m : part.ModelCount;

	private void StepModels(BattlePart part, int delta)
	{
		var next = Math.Clamp(PartModels(part) + delta, 0, Math.Max(1, part.ModelCount));
		_models[part.Unit.Id] = next;
	}

	private bool PartDown(BattlePart part) => PartModels(part) == 0;

	private int GroupModels(BattleUnit unit) => unit.Parts.Sum(PartModels);

	private bool IsDead(BattleUnit unit) => unit.Parts.All(PartDown);

	private string TotalAttacks(BattlePart part, WeaponProfile weapon) =>
		WeaponMath.TotalAttacks(PartModels(part), weapon.Attacks);

	private int AliveCount => _battle is null ? 0 : _battle.Units.Count(u => !IsDead(u));

	// ---- Collapse ----
	private bool IsCollapsed(BattleUnit unit) => _collapsed.Contains(unit.Id);

	private void ToggleCard(BattleUnit unit)
	{
		if (!_collapsed.Remove(unit.Id))
			_collapsed.Add(unit.Id);
	}

	private void CollapseAll()
	{
		if (_battle is null)
			return;
		foreach (var unit in _battle.Units)
			_collapsed.Add(unit.Id);
	}

	private void ExpandAll() => _collapsed.Clear();

	private bool AllCollapsed => _battle is not null && _battle.Units.All(u => _collapsed.Contains(u.Id));

	private void ToggleCollapseAll()
	{
		if (AllCollapsed)
			ExpandAll();
		else
			CollapseAll();
	}

	private void OpenDetail(BattleUnit unit) => _detail = unit;

	private void CloseDetail() => _detail = null;

	private static string Clean(string text) =>
		text.Replace("^^**", " ", StringComparison.Ordinal)
			.Replace("^^", " ", StringComparison.Ordinal)
			.Replace("**", " ", StringComparison.Ordinal)
			.Replace("■", "•", StringComparison.Ordinal);

	private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "–" : value;
}
