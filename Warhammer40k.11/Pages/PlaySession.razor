	// ---- Swipe deck navigation (one card at a time) ----
	private int CardCount => _ordered.Count;

	// The units in the player's chosen display order — drives both the deck pills and the card list.
	private IReadOnlyList<BattleUnit> OrderedUnits => _ordered;

	// Rebuilds the cached ordered view from _order (skipping any id no longer present).
	private void RebuildOrdered()
	{
		_ordered.Clear();
		foreach (var id in _order)
			if (_byId.TryGetValue(id, out var u))
				_ordered.Add(u);
	}

	// In swipe mode only the active card is rendered (one at a time); otherwise the whole list.
	private IEnumerable<BattleUnit> UnitsToRender
	{
		get
		{
			if (_battle is null || _ordered.Count == 0)
				return [];
			if (!_cardSwipe)
				return _ordered;
			var index = Math.Clamp(_activeCard, 0, _ordered.Count - 1);
			return [_ordered[index]];
		}
	}

	private bool GoToCard(int index)
	{
		var count = CardCount;
		if (count == 0)
			return false;
		var clamped = Math.Clamp(index, 0, count - 1);
		if (clamped == _activeCard)
			return false;
		_activeCard = clamped;
		_centerActivePill = true;
		// Each card is shown expanded in the deck, so make sure the active unit isn't collapsed.
		if (_activeCard < _ordered.Count)
			_collapsed.Remove(_ordered[_activeCard].Id);
		ScheduleBattleSave();
		return true;
	}

	private void NextCard()
	{
		if (GoToCard(_activeCard + 1))
			StateHasChanged();
	}

	private void PrevCard()
	{
		if (GoToCard(_activeCard - 1))
			StateHasChanged();
	}

	private void SelectCard(int index)
	{
		if (GoToCard(index))
			StateHasChanged();
	}

	// The deck button's label: one meaningful word. For an attached (led) unit we label by the bodyguard — the
	// part the leader joined — not the character. "Necron Warriors" → "Warriors"; "Imotekh the Stormlord" → "Imotekh".
	private static string DeckLabel(BattleUnit unit)
	{
		var bodyguard = unit.Parts.FirstOrDefault(p => !p.IsLeader) ?? unit.Parts.FirstOrDefault();
		var name = bodyguard?.Datasheet.Name;
		return ShortName(string.IsNullOrWhiteSpace(name) ? unit.Name : name);
	}

	private static readonly string[] DeckNoiseWords = ["the", "of", "and", "a", "an"];

	// Hand-picked abbreviations for units whose one-word label would be ambiguous or too long.
	private static readonly Dictionary<string, string> ShortNames = new(StringComparer.OrdinalIgnoreCase)
	{
		["Lokhust Heavy Destroyer"] = "LHD",
		["Lokhust Heavy Destroyers"] = "LHD",
		["Doomsday Ark"] = "DDA",
		// Several units share the trailing "Destroyer(s)" word, so label them by their distinguishing first word.
		["Skorpekh Destroyers"] = "Skorpekh",
		["Ophydian Destroyers"] = "Ophydian",
		["Hexmark Destroyer"] = "Hexmark",
	};

	// The compact label for a unit/model name used in deck pills and weapon source tags: a hand-picked acronym
	// when defined, otherwise the single most identifying word (see MeaningfulWord).
	private static string ShortName(string? name)
	{
		var n = (name ?? "").Trim();
		return ShortNames.TryGetValue(n, out var s) ? s : MeaningfulWord(n);
	}

	// Picks the single most identifying word from a unit name. An "X the Y" epithet (no "of") reads as a proper
	// name, so we keep the leading name ("Imotekh the Stormlord" → "Imotekh", "Trazyn the Infinite" → "Trazyn").
	// Otherwise the distinguishing word is the last significant one ("Necron Warriors" → "Warriors",
	// "C'tan Shard of the Nightbringer" → "Nightbringer").
	private static string MeaningfulWord(string? name)
	{
		var words = (name ?? "").Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
		if (words.Length == 0)
			return "?";
		var hasThe = words.Any(w => string.Equals(w, "the", StringComparison.OrdinalIgnoreCase));
		var hasOf = words.Any(w => string.Equals(w, "of", StringComparison.OrdinalIgnoreCase));
		if (hasThe && !hasOf)
			return words[0];
		var significant = words.Where(w => !DeckNoiseWords.Contains(w, StringComparer.OrdinalIgnoreCase)).ToList();
		return significant.Count > 0 ? significant[^1] : words[^1];
	}

	private void OnDeckKeyDown(KeyboardEventArgs e)
	{
		if (!_cardSwipe)
			return;
		if (e.Key == "ArrowRight")
			NextCard();
		else if (e.Key == "ArrowLeft")
			PrevCard();
	}

	public async ValueTask DisposeAsync()
	{
		_battleSaveCts?.Cancel();
		_battleSaveCts?.Dispose();
		try
		{
			await PersistBattleStateAsync();
			await JS.InvokeVoidAsync("tombworld.cancelFlushOnHide");
		}
		catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException)
		{
			// Browser already detached; the last completed debounce remains persisted.
		}
		if (_deckBound || _reorderBound)
		{
			try
			{
				if (_deckBound)
					await JS.InvokeVoidAsync("tombworld.deck.detach");
				if (_reorderBound)
					await JS.InvokeVoidAsync("tombworld.reorder.detach");
			}
			catch (JSDisconnectedException)
			{
				// Circuit already gone — nothing to detach.
			}
			catch (InvalidOperationException)
			{
				// Prerendering / no JS runtime — safe to ignore.
			}
		}
		_saveCts?.Cancel();
		_saveCts?.Dispose();
		if (_orderDirty && _roster is not null)
		{
			try
			{
				await Api.SaveRosterAsync(_roster);
			}
			catch (Exception)
			{
				// Best-effort persistence on teardown.
			}
		}
		_sessionSelf?.Dispose();
		_deckSelf?.Dispose();
	}

	private static string Clean(string text) =>
		text.Replace("^^**", " ", StringComparison.Ordinal)
			.Replace("^^", " ", StringComparison.Ordinal)
			.Replace("**", " ", StringComparison.Ordinal)
			.Replace("■", "•", StringComparison.Ordinal);

	private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "–" : value;
}
