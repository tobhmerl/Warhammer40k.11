			_shootingChoice.Remove(unit.Id);
		else
			_shootingChoice[unit.Id] = option;
		ScheduleBattleSave();
	}

	private void ResetTrackers()
	{
		_round = 1;
		_cp = 0;
		_vpYouPrimary = _vpYouSecondary = _vpOppPrimary = _vpOppSecondary = 0;
		_phase = BattlePhase.Command;
		_turn = BattleTurn.Player;
		_firstTurn = BattleTurn.Player;
		_track.Clear();
		_weaponKills.Clear();
		_collapsed.Clear();
		_openAbilities.Clear();
		_shootingChoice.Clear();
		_activeEffects.Clear();
		_selectedMember.Clear();
		_selectedCell = null;
		_usedOncePerBattle.Clear();
		if (_battle is null)
			return;
		foreach (var unit in _battle.Units)
		{
			_collapsed.Add(unit.Id); // collapsed is the default; expand the cards you're working with
			foreach (var part in unit.Parts)
				_track[part.Unit.Id] = part.TrackMax;
		}
		// In swipe mode you view one card at a time, so start the visible (first) card expanded.
		if (_cardSwipe && _ordered.Count > 0)
		{
			_activeCard = 0;
			_collapsed.Remove(_ordered[0].Id);
		}
	}

	// ---- Per-part tracking: models for multi-model units, wounds for single multi-wound models ----
	private int PartCurrent(BattlePart part) =>
		_track.TryGetValue(part.Unit.Id, out var v) ? v : part.TrackMax;

	private void StepPart(BattlePart part, int delta)
	{
		// A per-model loadout part (each model carries Gauss or Enmitic) needs to know WHICH model leaves, so that
		// weapon's attacks reduce correctly. When there's a genuine choice we ask; otherwise apply it directly.
		if (delta != 0 && part.IsPerModel)
		{
			var options = LoadoutOptions(part, delta);
			if (options.Count >= 2)
			{
				_loadoutPart = part;
				_loadoutDelta = delta;
				return;
			}
			if (options.Count == 1)
				AdjustWeapon(part, options[0].Weapon, delta);
			return;
		}
		_track[part.Unit.Id] = Math.Clamp(PartCurrent(part) + delta, 0, part.TrackMax);
		ScheduleBattleSave();
	}

	private static string WeaponKillKey(BattlePart part, WeaponProfile weapon) => part.Unit.Id + "|" + weapon.Name;

	// How many models in this part currently wield the weapon: for a per-model loadout it's the setup count minus
	// the casualties the player assigned to it; otherwise it follows the part's live model count.
	private int WeaponModelsAlive(BattlePart part, WeaponProfile weapon)
	{
		if (part.IsPerModelWeapon(weapon))
			return Math.Max(0, part.ModelsCarrying(weapon) - _weaponKills.GetValueOrDefault(WeaponKillKey(part, weapon)));
		return part.ModelsCarrying(weapon, PartModelsAlive(part));
	}

	// Apply one casualty (delta -1) or restoration (delta +1) to a specific per-model weapon, keeping the part's
	// total model count (_track) in step with the per-weapon kill tally.
	private void AdjustWeapon(BattlePart part, WeaponProfile weapon, int delta)
	{
		var key = WeaponKillKey(part, weapon);
		var setup = part.ModelsCarrying(weapon);
		var kills = _weaponKills.GetValueOrDefault(key);
		var newKills = Math.Clamp(kills - delta, 0, setup); // delta -1 → +1 kill; delta +1 → -1 kill
		if (newKills == kills)
			return;
		if (newKills <= 0)
			_weaponKills.Remove(key);
		else
			_weaponKills[key] = newKills;
		_track[part.Unit.Id] = Math.Clamp(PartCurrent(part) + delta, 0, part.TrackMax);
		ScheduleBattleSave();
	}

	// The per-model weapons eligible for a casualty (delta -1: those with a live model) or a restore (delta +1:
	// those below their setup count), each with its current live count, for the chooser.
	private IReadOnlyList<(WeaponProfile Weapon, int Alive, int Setup)> LoadoutOptions(BattlePart part, int delta)
	{
		var result = new List<(WeaponProfile, int, int)>();
		foreach (var weapon in part.Weapons)
		{
			if (!part.IsPerModelWeapon(weapon))
				continue;
			var setup = part.ModelsCarrying(weapon);
			var alive = WeaponModelsAlive(part, weapon);
			if (delta < 0 ? alive > 0 : alive < setup)
				result.Add((weapon, alive, setup));
		}
		return result;
	}

	// ---- Per-model loadout casualty chooser (which weapon's model leaves / returns) ----
	private BattlePart? _loadoutPart;
	private int _loadoutDelta;

	private void ApplyLoadoutChoice(WeaponProfile weapon)
	{
		if (_loadoutPart is { } part)
			AdjustWeapon(part, weapon, _loadoutDelta);
		_loadoutPart = null;
	}

	private void CancelLoadoutChoice() => _loadoutPart = null;

	private bool PartDown(BattlePart part) => PartCurrent(part) == 0;

	// Live models this part still contributes (a wounded-but-alive single model is still 1 model).
	private int PartModelsAlive(BattlePart part) =>
		part.TracksWounds ? (PartCurrent(part) > 0 ? 1 : 0) : PartCurrent(part);

	// True when this part has lost wounds/models but is not destroyed (drives the Reanimation cue).
	private bool PartHasLosses(BattlePart part) => PartCurrent(part) < part.TrackMax;

	private int GroupModels(BattleUnit unit) => unit.Parts.Sum(PartModelsAlive);

	private bool IsDead(BattleUnit unit) => unit.Parts.All(PartDown);

	private string TotalAttacks(BattlePart part, WeaponProfile weapon, IReadOnlyList<StatModifier> weaponMods) =>
		WeaponMath.TotalAttacks(WeaponModelsAlive(part, weapon), BuffedRaw(weapon.Attacks, weaponMods, StatTarget.Attacks));

	// ---- Applied stat buffs (leader conferrals + detachment buffs) shown directly on the stat cells ----
	private static string BuffedRaw(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target)
	{
		if (string.IsNullOrWhiteSpace(raw))
			return raw ?? "";
		var applicable = mods.Where(m => m.Target == target).ToList();
		return applicable.Count == 0 ? raw : StatMath.ApplyAll(raw, applicable);
	}

	private static string StatCell(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target) =>
		Dash(BuffedRaw(raw, mods, target));

	private static bool StatBuffed(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target) =>
		!string.IsNullOrWhiteSpace(raw)
		&& !string.Equals(raw, BuffedRaw(raw, mods, target), StringComparison.Ordinal);

	private static string StatTitle(IReadOnlyList<StatModifier> mods, StatTarget target)
	{
		var applicable = mods.Where(m => m.Target == target).ToList();
		return applicable.Count == 0 ? "" : "Buffed " + string.Join(", ", applicable.Select(m => m.Describe()));
	}

	// A Hit-roll modifier (a detachment's "+1 to Hit while a Character leads", a leader conferral, or a toggled
	// buff) is shown as a small "(+1)"/"(−1)" badge on the BS/WS cell rather than baked into the characteristic, so
	// it reads as a roll modifier and stays separate from the base BS/WS (which the Cover rule lowers).
	private static int HitModifier(IReadOnlyList<StatModifier> mods) =>
		mods.Where(m => m.Target == StatTarget.Skill && !m.IsSet).Sum(m => m.Delta);

	private static string SignedMod(int delta) => (delta > 0 ? "+" : "−") + Math.Abs(delta);

	// A weapon whose BS/WS is "N/A" auto-hits — there is no Hit roll, so neither a Hit-roll modifier nor a
	// Critical-Hit threshold means anything for it; both badges are suppressed on such a cell.
	private static bool AutoHits(string? skill) =>
		string.IsNullOrWhiteSpace(skill) || skill.Trim().Equals("N/A", StringComparison.OrdinalIgnoreCase);

	private int AliveCount => _battle is null ? 0 : _battle.Units.Count(u => !IsDead(u));

