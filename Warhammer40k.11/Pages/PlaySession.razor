@page "/play/{Id}"
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Play
@using Warhammer40k.Core.Rosters
@using Warhammer40k._11.Components
@inject IApiClient Api
@inject IJSRuntime JS

<PageTitle>TombWorld — @(_roster?.Name ?? "Play")</PageTitle>

@if (_loading)
{
	<div class="play">
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Loading roster&hellip;</p>
		</div>
	</div>
}
else if (!_authenticated)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">Sign in to play with your rosters.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	</div>
}
else if (_notFound || _roster is null || _battle is null)
{
	<div class="play">
		<div class="card pad signin">
			<p class="status">That roster could not be found.</p>
			<a class="btn ghost" href="play">&larr; Back to play</a>
		</div>
	</div>
}
else
{
	<div class="play">
		<a class="back" href="play">&larr; Play</a>

		<div class="topbar">
			<h1 class="rname">@_roster.Name</h1>
			<div class="topbar-actions">
				<button class="btn small ghost" type="button" @onclick="ToggleCollapseAll" title="Collapse or expand all cards">
					@(AllCollapsed ? "Expand all" : "Collapse all")
				</button>
				<button class="btn small ghost" type="button" @onclick="ResetTrackers" title="Reset CP, VP and models">Reset</button>
				@if (ArmyRules.Count > 0 || _battle.Detachments.Count > 0)
				{
					<button class="btn small ghost" type="button" @onclick="OpenRules" title="Army &amp; detachment rules">Rules</button>
				}
			</div>
		</div>

		<div class="play-rail">
			<div class="cp-float" aria-label="Command points">
				<span class="cp-label">CP</span>
				<button class="cp-btn" type="button" @onclick="() => StepCp(1)" aria-label="Gain command point">+</button>
				<span class="cp-num">@_cp</span>
				<button class="cp-btn" type="button" @onclick="() => StepCp(-1)" aria-label="Spend command point">−</button>
			</div>
			<div class="scroll-nav" aria-label="Scroll">
				<button class="scroll-btn" type="button" @onclick="ScrollTop" aria-label="Scroll to top" title="Top">↑</button>
				<button class="scroll-btn" type="button" @onclick="ScrollBottom" aria-label="Scroll to bottom" title="Bottom">↓</button>
			</div>
		</div>

		@* Floating control HUD: sticks to the bottom, hides while scrolling up, reappears while scrolling down. *@
		<div class="hud">
			<div class="turn-toggle" role="group" aria-label="Whose turn it is">
				<button type="button" class="turn @(_turn == BattleTurn.Player ? "on" : "")"
						aria-pressed="@(_turn == BattleTurn.Player)" @onclick="() => SetTurn(BattleTurn.Player)">
					Your turn
				</button>
				<button type="button" class="turn opp @(_turn == BattleTurn.Opponent ? "on" : "")"
						aria-pressed="@(_turn == BattleTurn.Opponent)" @onclick="() => SetTurn(BattleTurn.Opponent)">
					Opponent's turn
				</button>
			</div>

			<nav class="phases" aria-label="Battle phases">
				@foreach (var phase in BattlePhases.Ordered)
				{
					var usable = PhaseAbilityCount(phase);
					<button type="button" class="phase @(phase == _phase ? "on" : "")" @onclick="() => SelectPhase(phase)">
						<span class="ph-name">@BattlePhases.Label(phase)</span>
						@if (usable > 0)
						{
							<span class="ph-badge" title="@($"{usable} usable {(usable == 1 ? "ability" : "abilities")} this phase")">@usable</span>
						}
					</button>
				}
			</nav>
		</div>

		@if (MyCommandPhase && (ReanimateCount > 0 || BattleShockCount > 0))
		{
			<div class="command-cue" role="status">
				<span class="cue-title">Your Command phase</span>
				@if (ReanimateCount > 0)
				{
					<span class="cue reanimate">@ReanimateCount to reanimate</span>
				}
				@if (BattleShockCount > 0)
				{
					<span class="cue shock">@BattleShockCount Battle-shock test@(BattleShockCount == 1 ? "" : "s")</span>
				}
			</div>
		}

		@{
			var strats = UsableStratagems;
		}
		<section class="strats" aria-label="Stratagems usable now">
			<button type="button" class="strats-head" @onclick="ToggleStrats" aria-expanded="@_stratsOpen">
				<span class="chev" aria-hidden="true">@(_stratsOpen ? "▾" : "▸")</span>
				<span class="strats-title">Stratagems</span>
				<span class="strats-sub">@BattlePhases.Label(_phase) · @(_turn == BattleTurn.Player ? "your turn" : "opponent's turn")</span>
				<span class="strats-count">@strats.Count</span>
			</button>
			@if (_stratsOpen)
			{
			@if (strats.Count == 0)
			{
				<p class="strats-empty">No stratagems for this phase and turn.</p>
			}
			else
			{
				<ul class="strat-list">
					@foreach (var s in strats)
					{
						<li class="strat @(CanAfford(s) ? "" : "broke")" @key="(s.Source + s.Id)">
							<div class="s-head">
								<span class="s-name">@s.Name</span>
								<span class="s-id">@s.Source</span>
								@if (!string.IsNullOrEmpty(s.Type))
								{
									<span class="s-type">@s.Type</span>
								}
								<span class="s-cp">@s.Cost CP</span>
								<button class="btn small s-use" type="button"
										disabled="@(!CanAfford(s))" @onclick="() => UseStratagem(s)"
										title="@(CanAfford(s) ? $"Spend {s.Cost} CP" : "Not enough CP")">
									Use
								</button>
							</div>
							@if (!string.IsNullOrWhiteSpace(s.Flavour))
							{
								<p class="s-flavour">@s.Flavour</p>
							}
							<dl class="s-body">
								@if (!string.IsNullOrWhiteSpace(s.When))
								{
									<dt>When</dt>
									<dd>@s.When</dd>
								}
								@if (!string.IsNullOrWhiteSpace(s.Target))
								{
									<dt>Target</dt>
									<dd>@s.Target</dd>
								}
								@if (!string.IsNullOrWhiteSpace(s.Effect))
								{
									<dt>Effect</dt>
									<dd>@s.Effect</dd>
								}
								@if (!string.IsNullOrWhiteSpace(s.Restrictions))
								{
									<dt>Restrictions</dt>
									<dd>@s.Restrictions</dd>
								}
							</dl>
						</li>
					}
				</ul>
			}
			}
		</section>

		@if (_battle.Units.Count == 0)
		{
			<div class="card empty">
				<p>This roster has no units yet.</p>
			</div>
		}
		else
		{
			<ul class="unit-list">
				@foreach (var unit in _battle.Units)
				{
					var dead = IsDead(unit);
					var collapsed = IsCollapsed(unit);
					var reanimate = MyCommandPhase && NeedsReanimation(unit);
					var battleShock = MyCommandPhase && NeedsBattleShock(unit);
					<li class="unit @(dead ? "dead" : "") @((reanimate || battleShock) ? "attention" : "")" @key="unit.Id">
						<div class="u-head">
							<button class="u-toggle" type="button" @onclick="() => ToggleCard(unit)"
									aria-expanded="@(!collapsed)" aria-label="@($"Toggle {unit.Name}")">
								<span class="chev" aria-hidden="true">@(collapsed ? "▸" : "▾")</span>
								<span class="u-titles">
									<span class="u-name">@unit.Name</span>
									<span class="u-chips">
											@if (unit.IsWarlord)
											{
												<span class="chip warlord">Warlord</span>
											}
											@{ var usableNow = unit.ActiveAbilityCount(_phase, _turn); }
											@if (usableNow > 0)
											{
												<span class="chip usable" title="@($"{usableNow} abilit{(usableNow == 1 ? "y" : "ies")} usable in the {BattlePhases.Label(_phase)} phase — expand to see")">@usableNow usable</span>
											}
											@foreach (var inv in unit.InvulnerableSaves)
											{
												<span class="chip inv @(inv.UnitWide ? "scope-unit" : "scope-model")" title="@(inv.UnitWide ? "Whole unit" : inv.ModelName + " only")">
													@inv.Value inv<span class="scope">@(inv.UnitWide ? "unit" : inv.ModelName)</span>
												</span>
											}
											@foreach (var fnp in unit.FeelNoPains)
											{
												<span class="chip fnp @(fnp.UnitWide ? "scope-unit" : "scope-model")" title="@(fnp.UnitWide ? "Whole unit" : fnp.ModelName + " only")">
													FNP @fnp.Value<span class="scope">@(fnp.UnitWide ? "unit" : fnp.ModelName)</span>
												</span>
											}
											@if (reanimate)
											{
												<span class="chip reanimate" title="Lost models - run Reanimation Protocols this phase">Reanimate</span>
											}
											@if (battleShock)
											{
												<span class="chip shock" title="Below Half-strength - take a Battle-shock test">Battle-shock</span>
											}
										</span>
								</span>
							</button>
							@if (unit.Parts.Count == 1 && unit.Primary.TracksWounds)
							{
								<span class="u-models" title="Wounds remaining">
									<span class="um-value @(dead ? "gone" : "")">@PartCurrent(unit.Primary)<span class="um-max">/@unit.Primary.TrackMax</span></span>
									<span class="um-label">wounds</span>
								</span>
							}
							else
							{
								<span class="u-models" title="Models remaining">
									<span class="um-value @(dead ? "gone" : "")">@GroupModels(unit)</span>
									<span class="um-label">@(GroupModels(unit) == 1 ? "model" : "models")</span>
								</span>
							}
						</div>

						@if (!collapsed)
						{
							<div class="u-body">
								@* Per-member statline (M/T/SV/W/LD/OC) as wrapping chips — fits any width, never side-scrolls. *@
								<div class="statlines">
									@foreach (var part in unit.Parts)
									{
										var p = part.Profile;
										<div class="statline @(PartDown(part) ? "down" : "") @(IsMemberSelected(unit, part) ? "member-on" : "") @(MemberDimmed(unit, part) ? "member-off" : "")" @key="part.Unit.Id">
											<div class="sl-top">
												@if (unit.Parts.Count > 1)
												{
													<button type="button" class="sname-btn @(IsMemberSelected(unit, part) ? "on" : "")" @onclick="() => ToggleMember(unit, part)" title="Highlight this model's weapons; tap again to clear">
														@part.Datasheet.Name@(part.IsLeader ? " (Leader)" : "")
													</button>
												}
												else
												{
													<span class="sname">@part.Datasheet.Name</span>
												}
												<span class="counter" title="@(part.TracksWounds ? "Wounds remaining" : "Models remaining")">
													<button type="button" @onclick="() => StepPart(part, -1)" aria-label="@(part.TracksWounds ? "Lose a wound" : "Remove a model")">−</button>
													<span class="c-value">@PartCurrent(part)<span class="c-max">/@part.TrackMax</span></span>
													<button type="button" @onclick="() => StepPart(part, 1)" aria-label="@(part.TracksWounds ? "Restore a wound" : "Add a model")">+</button>
													@if (part.TracksWounds)
													{
														<span class="c-tag" title="Wounds">W</span>
													}
												</span>
											</div>
											@{ var uMods = _battle.UnitStatModifiers(unit, part); }
											<div class="statgrid">
												<div class="st @(StatBuffed(p?.Move, uMods, StatTarget.Move) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Move)"><span class="lab">M</span><span class="val">@StatCell(p?.Move, uMods, StatTarget.Move)</span></div>
												<div class="st @(StatBuffed(p?.Toughness, uMods, StatTarget.Toughness) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Toughness)"><span class="lab">T</span><span class="val">@StatCell(p?.Toughness, uMods, StatTarget.Toughness)</span></div>
												<div class="st @(StatBuffed(p?.Save, uMods, StatTarget.Save) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Save)"><span class="lab">SV</span><span class="val">@StatCell(p?.Save, uMods, StatTarget.Save)</span></div>
												<div class="st @(StatBuffed(p?.Wounds, uMods, StatTarget.Wounds) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Wounds)"><span class="lab">W</span><span class="val">@StatCell(p?.Wounds, uMods, StatTarget.Wounds)</span></div>
												<div class="st @(StatBuffed(p?.Leadership, uMods, StatTarget.Leadership) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.Leadership)"><span class="lab">LD</span><span class="val">@StatCell(p?.Leadership, uMods, StatTarget.Leadership)</span></div>
												<div class="st @(StatBuffed(p?.ObjectiveControl, uMods, StatTarget.ObjectiveControl) ? "buffed" : "")" title="@StatTitle(uMods, StatTarget.ObjectiveControl)"><span class="lab">OC</span><span class="val">@StatCell(p?.ObjectiveControl, uMods, StatTarget.ObjectiveControl)</span></div>
											</div>
										</div>
									}
								</div>

								@{
									var ranged = unit.Parts.SelectMany(p => p.RangedWeapons.Select(w => (Part: p, Weapon: w))).ToList();
									var melee = unit.Parts.SelectMany(p => p.MeleeWeapons.Select(w => (Part: p, Weapon: w))).ToList();
									var shootChoices = _battle.WeaponChoicesFor(unit);
								}
								@if (_phase == BattlePhase.Shooting && shootChoices.Count > 0)
								{
									<div class="shoot-choice">
										<span class="sc-label">@shootChoices[0].Name</span>
										<div class="sc-opts">
											@foreach (var opt in shootChoices.SelectMany(c => c.Options).Distinct())
											{
												<button type="button" class="sc-opt @(IsChoiceSelected(unit, opt) ? "on" : "")" @onclick="() => ToggleChoice(unit, opt)">@opt</button>
											}
										</div>
									</div>
								}
								@if (ranged.Count > 0)
								{
									<div class="weapon-block @(_phase == BattlePhase.Shooting ? "phase-on" : "")">
										<div class="wb-head"><span class="wb-title">Ranged</span></div>
										<ul class="weapon-list">
											@foreach (var row in ranged)
											{
												<li class="weapon @(IsMemberSelected(unit, row.Part) ? "member-on" : "") @(MemberDimmed(unit, row.Part) ? "member-off" : "")" @key="row.Weapon">
													@{
														var rwMods = _battle.WeaponStatModifiers(unit, row.Part, ranged: true);
														var rGrants = _battle.GrantedWeaponAbilities(unit, row.Part, ranged: true);
														var rChosen = _phase == BattlePhase.Shooting ? SelectedChoice(unit) : null;
													}
													<div class="w-top">
														<span class="wname">@row.Weapon.Name</span>
														<span class="w-total" title="Total attacks at current model count">@TotalAttacks(row.Part, row.Weapon, rwMods) A</span>
													</div>
													@if (unit.Parts.Count > 1 || row.Weapon.Keywords.Count > 0 || rGrants.Count > 0 || rChosen is not null)
													{
														<div class="w-meta">
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc">@row.Part.Datasheet.Name</span>
															}
															@foreach (var kw in row.Weapon.Keywords)
															{
																<span class="wkw">@kw</span>
															}
															@foreach (var g in rGrants)
															{
																<span class="wkw granted" title="Conferred by your detachment or an attached leader">@g</span>
															}
															@if (rChosen is not null)
															{
																<span class="wkw chosen" title="Selected this Shooting phase">@rChosen</span>
															}
														</div>
													}
													<div class="statgrid weapongrid">
														<div class="st clickable @(IsCellSelected(row.Weapon, KRng) ? "selected" : "") @(StatBuffed(row.Weapon.Range, rwMods, StatTarget.Range) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Range)" @onclick="() => ToggleCell(row.Weapon, KRng)"><span class="lab">Rng</span><span class="val">@StatCell(row.Weapon.Range, rwMods, StatTarget.Range)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KA) ? "selected" : "") @(StatBuffed(row.Weapon.Attacks, rwMods, StatTarget.Attacks) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Attacks)" @onclick="() => ToggleCell(row.Weapon, KA)"><span class="lab">A</span><span class="val">@StatCell(row.Weapon.Attacks, rwMods, StatTarget.Attacks)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KBs) ? "selected" : "") @(StatBuffed(row.Weapon.Skill, rwMods, StatTarget.Skill) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Skill)" @onclick="() => ToggleCell(row.Weapon, KBs)"><span class="lab">BS</span><span class="val">@StatCell(row.Weapon.Skill, rwMods, StatTarget.Skill)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KS) ? "selected" : "") @(StatBuffed(row.Weapon.Strength, rwMods, StatTarget.Strength) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Strength)" @onclick="() => ToggleCell(row.Weapon, KS)"><span class="lab">S</span><span class="val">@StatCell(row.Weapon.Strength, rwMods, StatTarget.Strength)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KAp) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KAp)"><span class="lab">AP</span><span class="val">@Dash(row.Weapon.ArmourPenetration)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KD) ? "selected" : "") @(StatBuffed(row.Weapon.Damage, rwMods, StatTarget.Damage) ? "buffed" : "")" title="@StatTitle(rwMods, StatTarget.Damage)" @onclick="() => ToggleCell(row.Weapon, KD)"><span class="lab">D</span><span class="val">@StatCell(row.Weapon.Damage, rwMods, StatTarget.Damage)</span></div>
													</div>
												</li>
											}
										</ul>
									</div>
								}
								@if (melee.Count > 0)
								{
									<div class="weapon-block @(_phase == BattlePhase.Fight ? "phase-on" : "")">
										<div class="wb-head"><span class="wb-title">Melee</span></div>
										<ul class="weapon-list">
											@foreach (var row in melee)
											{
												<li class="weapon @(IsMemberSelected(unit, row.Part) ? "member-on" : "") @(MemberDimmed(unit, row.Part) ? "member-off" : "")" @key="row.Weapon">
													@{
														var mwMods = _battle.WeaponStatModifiers(unit, row.Part, ranged: false);
														var mGrants = _battle.GrantedWeaponAbilities(unit, row.Part, ranged: false);
													}
													<div class="w-top">
														<span class="wname">@row.Weapon.Name</span>
														<span class="w-total" title="Total attacks at current model count">@TotalAttacks(row.Part, row.Weapon, mwMods) A</span>
													</div>
													@if (unit.Parts.Count > 1 || row.Weapon.Keywords.Count > 0 || mGrants.Count > 0)
													{
														<div class="w-meta">
															@if (unit.Parts.Count > 1)
															{
																<span class="wsrc">@row.Part.Datasheet.Name</span>
															}
															@foreach (var kw in row.Weapon.Keywords)
															{
																<span class="wkw">@kw</span>
															}
															@foreach (var g in mGrants)
															{
																<span class="wkw granted" title="Conferred by your detachment or an attached leader">@g</span>
															}
														</div>
													}
													<div class="statgrid weapongrid">
														<div class="st clickable @(IsCellSelected(row.Weapon, KRng) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KRng)"><span class="lab">Rng</span><span class="val">@Dash(row.Weapon.Range)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KA) ? "selected" : "") @(StatBuffed(row.Weapon.Attacks, mwMods, StatTarget.Attacks) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Attacks)" @onclick="() => ToggleCell(row.Weapon, KA)"><span class="lab">A</span><span class="val">@StatCell(row.Weapon.Attacks, mwMods, StatTarget.Attacks)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KWs) ? "selected" : "") @(StatBuffed(row.Weapon.Skill, mwMods, StatTarget.Skill) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Skill)" @onclick="() => ToggleCell(row.Weapon, KWs)"><span class="lab">WS</span><span class="val">@StatCell(row.Weapon.Skill, mwMods, StatTarget.Skill)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KS) ? "selected" : "") @(StatBuffed(row.Weapon.Strength, mwMods, StatTarget.Strength) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Strength)" @onclick="() => ToggleCell(row.Weapon, KS)"><span class="lab">S</span><span class="val">@StatCell(row.Weapon.Strength, mwMods, StatTarget.Strength)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KAp) ? "selected" : "")" @onclick="() => ToggleCell(row.Weapon, KAp)"><span class="lab">AP</span><span class="val">@Dash(row.Weapon.ArmourPenetration)</span></div>
														<div class="st clickable @(IsCellSelected(row.Weapon, KD) ? "selected" : "") @(StatBuffed(row.Weapon.Damage, mwMods, StatTarget.Damage) ? "buffed" : "")" title="@StatTitle(mwMods, StatTarget.Damage)" @onclick="() => ToggleCell(row.Weapon, KD)"><span class="lab">D</span><span class="val">@StatCell(row.Weapon.Damage, mwMods, StatTarget.Damage)</span></div>
													</div>
												</li>
											}
										</ul>
									</div>
								}

								@if (unit.CombinedAbilities.Count > 0)
								{
									<ul class="abilities">
										@foreach (var a in unit.CombinedAbilities)
										{
											var applied = a.AppliedSummary;
											var hasText = !string.IsNullOrWhiteSpace(a.Ability.Text);
											var activeNow = BattleUnit.IsAbilityActiveInPhase(a, _phase, _turn);
											var open = IsAbilityOpen(unit, a);
											<li class="ability @(applied is not null ? "applied" : "") @(a.IsEnhancement ? "enh" : "") @(activeNow ? "now" : "") @(open ? "open" : "")" @key="a.Ability.Name">
												@if (applied is not null)
												{
													<div class="a-row">
														<span class="a-name">
															@a.Ability.Name
															@if (a.IsEnhancement)
															{
																<span class="a-tag enh">Enhancement</span>
															}
															@if (unit.Parts.Count > 1)
															{
																<span class="a-src">@a.Source</span>
															}
														</span>
														<span class="a-applied" title="Applied to this unit's stats or weapons">Applied: @applied</span>
													</div>
												}
												else if (hasText)
												{
													<button type="button" class="a-toggle" @onclick="() => ToggleAbility(unit, a)" aria-expanded="@open">
														<span class="chev" aria-hidden="true">@(open ? "▾" : "▸")</span>
														<span class="a-name">
															@a.Ability.Name
															@if (a.IsEnhancement)
															{
																<span class="a-tag enh">Enhancement</span>
															}
															@if (activeNow)
															{
																<span class="a-tag now" title="@($"Usable in the {BattlePhases.Label(_phase)} phase")">Usable now</span>
															}
															@if (unit.Parts.Count > 1)
															{
																<span class="a-src">@a.Source</span>
															}
														</span>
													</button>
													@if (open)
													{
														<p class="a-text">@Clean(a.Ability.Text)</p>
													}
												}
												else
												{
													<div class="a-row">
														<span class="a-name">
															@a.Ability.Name
															@if (a.IsEnhancement)
															{
																<span class="a-tag enh">Enhancement</span>
															}
															@if (unit.Parts.Count > 1)
															{
																<span class="a-src">@a.Source</span>
															}
														</span>
													</div>
												}
											</li>
									}
								</ul>
							}

								<div class="u-foot">
									<button class="ds-link" type="button" @onclick="() => OpenDetail(unit)">Full datasheet →</button>
								</div>
						</div>
					}
					</li>
				}
			</ul>
		}
			<section class="page-meta" aria-label="Victory points">
				<div class="vp" aria-label="Victory points">
					<div class="vp-grid">
						<span class="vp-corner">VP</span>
						<span class="vp-h">You</span>
						<span class="vp-h">Opp</span>

						<span class="vp-rl">Primary</span>
						<span class="vp-cell">
							<button type="button" @onclick="() => StepVp(0, -1)" aria-label="Your primary minus">−</button>
							<span class="vp-n">@_vpYouPrimary</span>
							<button type="button" @onclick="() => StepVp(0, 1)" aria-label="Your primary plus">+</button>
						</span>
						<span class="vp-cell">
							<button type="button" @onclick="() => StepVp(1, -1)" aria-label="Opponent primary minus">−</button>
							<span class="vp-n">@_vpOppPrimary</span>
							<button type="button" @onclick="() => StepVp(1, 1)" aria-label="Opponent primary plus">+</button>
						</span>

						<span class="vp-rl">Second.</span>
						<span class="vp-cell">
							<button type="button" @onclick="() => StepVp(2, -1)" aria-label="Your secondary minus">−</button>
							<span class="vp-n">@_vpYouSecondary</span>
							<button type="button" @onclick="() => StepVp(2, 1)" aria-label="Your secondary plus">+</button>
						</span>
						<span class="vp-cell">
							<button type="button" @onclick="() => StepVp(3, -1)" aria-label="Opponent secondary minus">−</button>
							<span class="vp-n">@_vpOppSecondary</span>
							<button type="button" @onclick="() => StepVp(3, 1)" aria-label="Opponent secondary plus">+</button>
						</span>

						<span class="vp-rl total">Total</span>
						<span class="vp-total">@(_vpYouPrimary + _vpYouSecondary)</span>
						<span class="vp-total">@(_vpOppPrimary + _vpOppSecondary)</span>
					</div>
				</div>
			</section>
		</div>
	}

	<Sheet Open="_detail is not null" Eyebrow="Datasheet" Title="@_detail?.Name" OnCloseRequested="CloseDetail">
	@if (_detail is { } d)
	{
		<DatasheetDetail Datasheet="d.Primary.Datasheet" Catalogue="_catalogue" />
		@foreach (var part in d.Parts.Skip(1))
		{
			<div class="detail-extra">
				<h3 class="detail-extra-title">@part.Datasheet.Name (Leader)</h3>
				<DatasheetDetail Datasheet="part.Datasheet" Catalogue="_catalogue" />
			</div>
		}
	}
</Sheet>

<Sheet Open="_rulesOpen" Eyebrow="Reference" Title="Army &amp; detachment rules" OnCloseRequested="CloseRules">
	@if (ArmyRules.Count > 0)
	{
		<ul class="ar-list">
			@foreach (var rule in ArmyRules)
			{
				<li class="ar" @key="rule.Name">
					<div class="ar-name-row">
						<span class="ar-name">@rule.Name</span>
					</div>
					<p class="ar-text">@rule.Text</p>
					@if (rule.HasExample)
					{
						<p class="ar-example"><span class="ar-label">Example</span> @rule.Example</p>
					}
					@if (rule.HasLore)
					{
						<p class="ar-lore">@rule.Lore</p>
					}
				</li>
			}
		</ul>
	}
	@if (_battle is not null && _battle.Detachments.Count > 0)
	{
		<ul class="ar-list">
			@foreach (var det in _battle.Detachments)
			{
				@foreach (var rule in det.Rules)
				{
					<li class="ar" @key="(det.Id + rule.Name)">
						<div class="ar-name-row">
							<span class="ar-name">@rule.Name</span>
							<span class="ar-now">@det.Name · @det.DetachmentPoints DP</span>
						</div>
						<p class="ar-text">@rule.Text</p>
					</li>
				}
			}
		</ul>
	}
</Sheet>

@code {
	[Parameter] public string Id { get; set; } = "";

	private CatalogueData _catalogue = new();
	private Roster? _roster;
	private BattleRoster? _battle;

	private string? _loadedId;
	private bool _loading = true;
	private bool _authenticated;
	private bool _notFound;

	private BattlePhase _phase = BattlePhase.Command;
	private BattleTurn _turn = BattleTurn.Player;
	private int _cp;
	// Victory points: primary + secondary for each side (in-memory trackers).
	private int _vpYouPrimary;
	private int _vpYouSecondary;
	private int _vpOppPrimary;
	private int _vpOppSecondary;
	// Whether the Stratagems panel is expanded (collapsible like the unit cards).
	private bool _stratsOpen = false;
	// Per-part current tracked value (models for multi-model units, wounds for single multi-wound models),
	// keyed by roster-unit id (in-memory, like the round/CP trackers).
	private readonly Dictionary<string, int> _track = new(StringComparer.Ordinal);
	// Cards collapsed by the user, keyed by group id.
	private readonly HashSet<string> _collapsed = new(StringComparer.Ordinal);
	// Abilities expanded by the user (collapsed by default), keyed by unit id + ability name.
	private readonly HashSet<string> _openAbilities = new(StringComparer.Ordinal);
	// Per-unit selected detachment weapon-ability for the current Shooting phase (e.g. "Anti-INFANTRY 3+").
	private readonly Dictionary<string, string> _shootingChoice = new(StringComparer.Ordinal);
	private BattleUnit? _detail;

	// Single-cell highlight on a weapon stat ("Rng", "A", "BS"…) so you can mark the exact spot you're on while
	// resolving an attack. Only the one cell you clicked lights up; click it again to clear.
	private const string KRng = "Rng";
	private const string KA = "A";
	private const string KBs = "BS";
	private const string KWs = "WS";
	private const string KS = "S";
	private const string KAp = "AP";
	private const string KD = "D";
	private (object Weapon, string Stat)? _selectedCell;

	// Per-card focus on a single member's weapons/statline (e.g. the Lychguard within Imotekh + Lychguard),
	// keyed by unit id -> selected part's roster-unit id. Click the member name again to clear.
	private readonly Dictionary<string, string> _selectedMember = new(StringComparer.Ordinal);

	protected override async Task OnParametersSetAsync()
	{
		if (_loadedId == Id)
			return;
		_loadedId = Id;
		await LoadAsync();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
			await JS.InvokeVoidAsync("tombworld.initScroll");
	}

	private async Task LoadAsync()
	{
		_loading = true;
		_notFound = false;

		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
		{
			if (_catalogue.Datasheets.Count == 0)
				_catalogue = await Api.GetCatalogueAsync();

			var roster = await Api.GetRosterAsync(Id);
			if (roster is null)
			{
				_notFound = true;
			}
			else
			{
				_roster = roster;
				_battle = BattleRoster.Build(roster, _catalogue);
				ResetTrackers();
			}
		}

		_loading = false;
	}

	private void SelectPhase(BattlePhase phase)
	{
		// Detachment shooting picks last "until the end of the phase", so clear them when the phase changes.
		if (phase != _phase)
			_shootingChoice.Clear();
		_phase = phase;
	}

	private void SetTurn(BattleTurn turn) => _turn = turn;

	// ---- Army rules (faction-wide, e.g. Reanimation Protocols) — shown on demand via a Sheet ----
	private IReadOnlyList<ArmyRule> ArmyRules =>
		_roster is null ? [] : ArmyRuleCatalogue.ForFaction(_roster.Faction);

	private bool _rulesOpen;

	private void OpenRules() => _rulesOpen = true;

	private void CloseRules() => _rulesOpen = false;

	// ---- Command-phase cues (your turn): which units must act this Command phase ----
	private bool MyCommandPhase => _phase == BattlePhase.Command && _turn == BattleTurn.Player;

	// A unit that has lost wounds or models (but isn't destroyed) should run Reanimation Protocols.
	private bool NeedsReanimation(BattleUnit unit) => !IsDead(unit) && unit.Parts.Any(PartHasLosses);

	// A unit Below Half-strength must take a Battle-shock test: by wounds for a lone single-model unit
	// (e.g. a Character), by models otherwise.
	private bool NeedsBattleShock(BattleUnit unit)
	{
		if (IsDead(unit))
			return false;
		if (unit.ModelCount == 1)
		{
			var only = unit.Primary;
			return only.TracksWounds && 2 * PartCurrent(only) < only.TrackMax;
		}
		return BattleStatus.BelowHalfStrength(unit.ModelCount, GroupModels(unit));
	}

	private int ReanimateCount => _battle is null ? 0 : _battle.Units.Count(NeedsReanimation);

	private int BattleShockCount => _battle is null ? 0 : _battle.Units.Count(NeedsBattleShock);

	// Core Stratagems usable "in the actual second": filtered by the current phase + whose turn it is.
	// Core Stratagems (always available) plus the selected detachments' stratagems, filtered "in the actual
	// second" by phase + whose turn it is. You can hold stratagems from more than one detachment.
	private sealed record StratView(string Id, string Name, string Source, string Type, int Cost,
		string Flavour, string When, string Target, string Effect, string? Restrictions);

	private IReadOnlyList<StratView> UsableStratagems
	{
		get
		{
			var list = new List<StratView>();
			foreach (var s in CoreStratagemCatalogue.Usable(_phase, _turn))
				list.Add(new StratView(s.Id, s.Name, "Core", "", s.Cost, s.Flavour, s.When, s.Target, s.Effect, s.Restrictions));
			if (_battle is not null)
				foreach (var det in _battle.Detachments)
					foreach (var s in det.Stratagems)
						if (s.UsableNow(_phase, _turn))
							list.Add(new StratView(s.Id, s.Name, det.Name, s.Type, s.CpCost, "", s.When, s.Target, s.Effect, null));
			return list;
		}
	}

	private bool CanAfford(StratView stratagem) => _cp >= stratagem.Cost;

	private void UseStratagem(StratView stratagem) => StepCp(-stratagem.Cost);

	private void StepCp(int delta) => _cp = Math.Max(0, _cp + delta);

	private async Task ScrollTop() => await JS.InvokeVoidAsync("tombworld.scrollTop");

	private async Task ScrollBottom() => await JS.InvokeVoidAsync("tombworld.scrollBottom");

	// Victory points: 0 = your primary, 1 = opponent primary, 2 = your secondary, 3 = opponent secondary.
	private void StepVp(int which, int delta)
	{
		switch (which)
		{
			case 0: _vpYouPrimary = Math.Max(0, _vpYouPrimary + delta); break;
			case 1: _vpOppPrimary = Math.Max(0, _vpOppPrimary + delta); break;
			case 2: _vpYouSecondary = Math.Max(0, _vpYouSecondary + delta); break;
			case 3: _vpOppSecondary = Math.Max(0, _vpOppSecondary + delta); break;
		}
	}

	private void ToggleStrats() => _stratsOpen = !_stratsOpen;

	// ---- Weapon stat selection (mark the exact cell you're on while resolving an attack) ----
	private bool IsCellSelected(object weapon, string stat) =>
		_selectedCell is { } c && ReferenceEquals(c.Weapon, weapon) && string.Equals(c.Stat, stat, StringComparison.Ordinal);

	private void ToggleCell(object weapon, string stat) =>
		_selectedCell = IsCellSelected(weapon, stat) ? null : (weapon, stat);

	// ---- Per-member weapon focus (distinguish models inside an attached unit) ----
	private bool IsMemberSelected(BattleUnit unit, BattlePart part) =>
		_selectedMember.TryGetValue(unit.Id, out var id) && string.Equals(id, part.Unit.Id, StringComparison.Ordinal);

	private bool MemberDimmed(BattleUnit unit, BattlePart part) =>
		_selectedMember.TryGetValue(unit.Id, out var id) && !string.Equals(id, part.Unit.Id, StringComparison.Ordinal);

	private void ToggleMember(BattleUnit unit, BattlePart part)
	{
		if (IsMemberSelected(unit, part))
			_selectedMember.Remove(unit.Id);
		else
			_selectedMember[unit.Id] = part.Unit.Id;
	}

	// ---- Detachment shooting choice (e.g. Cryptek "Technosorcerous Augmentations") ----
	private string? SelectedChoice(BattleUnit unit) =>
		_shootingChoice.TryGetValue(unit.Id, out var s) ? s : null;

	private bool IsChoiceSelected(BattleUnit unit, string option) =>
		string.Equals(SelectedChoice(unit), option, StringComparison.Ordinal);

	private void ToggleChoice(BattleUnit unit, string option)
	{
		if (IsChoiceSelected(unit, option))
			_shootingChoice.Remove(unit.Id);
		else
			_shootingChoice[unit.Id] = option;
	}

	private void ResetTrackers()
	{
		_cp = 0;
		_vpYouPrimary = _vpYouSecondary = _vpOppPrimary = _vpOppSecondary = 0;
		_phase = BattlePhase.Command;
		_turn = BattleTurn.Player;
		_track.Clear();
		_collapsed.Clear();
		_openAbilities.Clear();
		_shootingChoice.Clear();
		_selectedMember.Clear();
		_selectedCell = null;
		if (_battle is null)
			return;
		foreach (var unit in _battle.Units)
		{
			_collapsed.Add(unit.Id); // collapsed is the default; expand the cards you're working with
			foreach (var part in unit.Parts)
				_track[part.Unit.Id] = part.TrackMax;
		}
	}

	// ---- Per-part tracking: models for multi-model units, wounds for single multi-wound models ----
	private int PartCurrent(BattlePart part) =>
		_track.TryGetValue(part.Unit.Id, out var v) ? v : part.TrackMax;

	private void StepPart(BattlePart part, int delta) =>
		_track[part.Unit.Id] = Math.Clamp(PartCurrent(part) + delta, 0, part.TrackMax);

	private bool PartDown(BattlePart part) => PartCurrent(part) == 0;

	// Live models this part still contributes (a wounded-but-alive single model is still 1 model).
	private int PartModelsAlive(BattlePart part) =>
		part.TracksWounds ? (PartCurrent(part) > 0 ? 1 : 0) : PartCurrent(part);

	// True when this part has lost wounds/models but is not destroyed (drives the Reanimation cue).
	private bool PartHasLosses(BattlePart part) => PartCurrent(part) < part.TrackMax;

	private int GroupModels(BattleUnit unit) => unit.Parts.Sum(PartModelsAlive);

	private bool IsDead(BattleUnit unit) => unit.Parts.All(PartDown);

	private string TotalAttacks(BattlePart part, WeaponProfile weapon, IReadOnlyList<StatModifier> weaponMods) =>
		WeaponMath.TotalAttacks(PartModelsAlive(part), BuffedRaw(weapon.Attacks, weaponMods, StatTarget.Attacks));

	// ---- Applied stat buffs (leader conferrals + detachment buffs) shown directly on the stat cells ----
	private static string BuffedRaw(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target)
	{
		if (string.IsNullOrWhiteSpace(raw))
			return raw ?? "";
		var applicable = mods.Where(m => m.Target == target).ToList();
		return applicable.Count == 0 ? raw : StatMath.ApplyAll(raw, applicable);
	}

	private static string StatCell(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target) =>
		Dash(BuffedRaw(raw, mods, target));

	private static bool StatBuffed(string? raw, IReadOnlyList<StatModifier> mods, StatTarget target) =>
		!string.IsNullOrWhiteSpace(raw)
		&& !string.Equals(raw, BuffedRaw(raw, mods, target), StringComparison.Ordinal);

	private static string StatTitle(IReadOnlyList<StatModifier> mods, StatTarget target)
	{
		var applicable = mods.Where(m => m.Target == target).ToList();
		return applicable.Count == 0 ? "" : "Buffed " + string.Join(", ", applicable.Select(m => m.Describe()));
	}

	private int AliveCount => _battle is null ? 0 : _battle.Units.Count(u => !IsDead(u));

	// Across all living groups, the number of text abilities usable in a phase — drives the phase-tab markers.
	// Stat abilities (leader conferrals, detachment buffs, stat-changing enhancements) are excluded: they are
	// always-on and shown via the live stat cells, not as "usable now" prompts.
	private int PhaseAbilityCount(BattlePhase phase) =>
		_battle is null ? 0 : _battle.Units.Where(u => !IsDead(u)).Sum(u => u.ActiveAbilityCount(phase, _turn));

	// ---- Collapse ----
	private bool IsCollapsed(BattleUnit unit) => _collapsed.Contains(unit.Id);

	private void ToggleCard(BattleUnit unit)
	{
		if (!_collapsed.Remove(unit.Id))
			_collapsed.Add(unit.Id);
	}

	// ---- Abilities collapse (each ability's text is hidden until clicked) ----
	private bool IsAbilityOpen(BattleUnit unit, BattleAbility ability) =>
		_openAbilities.Contains(unit.Id + "\u0001" + ability.Ability.Name);

	private void ToggleAbility(BattleUnit unit, BattleAbility ability)
	{
		var key = unit.Id + "\u0001" + ability.Ability.Name;
		if (!_openAbilities.Remove(key))
			_openAbilities.Add(key);
	}

	private void CollapseAll()
	{
		if (_battle is null)
			return;
		foreach (var unit in _battle.Units)
			_collapsed.Add(unit.Id);
	}

	private void ExpandAll() => _collapsed.Clear();

	private bool AllCollapsed => _battle is not null && _battle.Units.All(u => _collapsed.Contains(u.Id));

	private void ToggleCollapseAll()
	{
		if (AllCollapsed)
			ExpandAll();
		else
			CollapseAll();
	}

	private void OpenDetail(BattleUnit unit) => _detail = unit;

	private void CloseDetail() => _detail = null;

	private static string Clean(string text) =>
		text.Replace("^^**", " ", StringComparison.Ordinal)
			.Replace("^^", " ", StringComparison.Ordinal)
			.Replace("**", " ", StringComparison.Ordinal)
			.Replace("■", "•", StringComparison.Ordinal);

	private static string Dash(string? value) => string.IsNullOrWhiteSpace(value) ? "–" : value;
}
