	// ---- Conditional weapon effects ----
	// An ability whose text names a bracketed weapon ability (e.g. [DEVASTATING WOUNDS]) the engine can't auto-
	// apply because it's situational. The player switches it on when its condition is met, and the keyword is
	// stamped onto the unit's weapons. Runtime only — the condition is a per-turn call, not saved.
	private static readonly Regex EffectKeywordRx = new(@"\[([^\]]+)\]", RegexOptions.Compiled);
	private readonly HashSet<string> _activeEffects = new(StringComparer.Ordinal);

	// Keys of "once per battle" abilities/enhancements/stratagems the player has ticked as used this game.
	private readonly HashSet<string> _usedOncePerBattle = new(StringComparer.Ordinal);

	// An item is "once per battle" when its rules text says so — abilities/enhancements by their text, a
	// stratagem across any of its clauses. Such items can be ticked "used" and then drop out of the Now ribbon.
	private static bool IsOncePerBattleText(string? text) =>
		!string.IsNullOrEmpty(text) && text.Contains("once per battle", StringComparison.OrdinalIgnoreCase);

	private static bool IsOncePerBattleAbility(BattleAbility ability) =>
		IsOncePerBattleText(ability.Ability.Text);

	private bool IsOncePerBattleStrat(StratView strat) =>
		IsOncePerBattleText(strat.Effect) || IsOncePerBattleText(strat.When)
		|| IsOncePerBattleText(strat.Restrictions) || IsOncePerBattleText(strat.Target);

	// Stable keys: an ability/enhancement is once-per-battle per bearing unit; a stratagem is army-wide.
	private static string OncePerBattleAbilityKey(BattleUnit unit, BattleAbility ability) =>
		"A|" + unit.Id + "|" + ability.Ability.Name;

	private static string OncePerBattleStratKey(StratView strat) => "S|" + strat.Id;

	private bool IsOncePerBattleUsed(string key) => _usedOncePerBattle.Contains(key);

	private void SetOncePerBattleUsed(string key, bool used)
	{
		if (used)
			_usedOncePerBattle.Add(key);
		else
			_usedOncePerBattle.Remove(key);
		ScheduleBattleSave();
	}

	private static List<string> EffectKeywords(BattleAbility ability)
	{
		var list = new List<string>();
		foreach (Match m in EffectKeywordRx.Matches(ability.Ability.Text ?? ""))
		{
			var kw = m.Groups[1].Value.Trim();
			if (kw.Length > 0 && !list.Contains(kw, StringComparer.OrdinalIgnoreCase))
				list.Add(kw);
		}
		return list;
	}

	private static bool HasEffectKeywords(BattleAbility ability) => EffectKeywords(ability).Count > 0;

	// One rule for the whole ability strip, regardless of origin (unit ability, detachment buff, enhancement,
	// army rule): an item is "available now" — shown highlighted on Line 2 AND counted on the deck pill — when it
	// is scheduled for the current phase + turn. Everything else is "always available" (Line 3, not highlighted).
	private bool IsUsableNow(BattleAbility a) =>
		!HasEffectKeywords(a) && !a.HasManualKeyword && BattleUnit.IsAbilityActiveInPhase(a, _phase, _turn);

	private bool IsEffectNow(BattleAbility a) =>
		HasEffectKeywords(a) && BattleUnit.IsAbilityActiveInPhase(a, _phase, _turn);

	private bool IsEffectAlways(BattleAbility a) =>
		HasEffectKeywords(a) && !BattleUnit.IsAbilityActiveInPhase(a, _phase, _turn);

	// The number of a unit's "available now" items (the Line 2 set): conditional detachment buffs scheduled now,
	// phase-scheduled effects, and phase-scheduled abilities. Drives the deck-pill badge so the count always
	// equals the number of highlighted chips on the card, whatever the ability's origin.
	private int AvailableNowCount(BattleUnit unit) =>
		ConditionalBuffsFor(unit).Count()
		+ unit.CombinedAbilities.Count(a => IsEffectNow(a) && !IsOncePerBattleUsedAbility(unit, a))
		+ unit.CombinedAbilities.Count(a => IsUsableNow(a) && !IsOncePerBattleUsedAbility(unit, a));

	// True when this ability is a once-per-battle item the player has already ticked "used" for this unit.
	private bool IsOncePerBattleUsedAbility(BattleUnit unit, BattleAbility ability) =>
		IsOncePerBattleAbility(ability) && IsOncePerBattleUsed(OncePerBattleAbilityKey(unit, ability));

	private static string EffectLabel(BattleAbility ability) =>
		string.Join(", ", EffectKeywords(ability).Select(k => $"[{k}]"));

	private static string EffectKey(BattleUnit unit, BattleAbility ability) => unit.Id + "|" + ability.Ability.Name;

	private bool IsEffectActive(BattleUnit unit, BattleAbility ability) => _activeEffects.Contains(EffectKey(unit, ability));

	private void ToggleEffect(BattleUnit unit, BattleAbility ability, bool on)
	{
		if (on)
			_activeEffects.Add(EffectKey(unit, ability));
		else
			_activeEffects.Remove(EffectKey(unit, ability));
		ScheduleBattleSave();
	}

	// The bracketed keywords from active conditional effects that apply to THIS weapon. An ability that names a
	// particular weapon in its text (e.g. "its doomsday cannon has [DEVASTATING WOUNDS]") only buffs that weapon;
	// an ability that doesn't single out one of the unit's weapons buffs them all.
	private IEnumerable<string> ActiveWeaponEffects(BattleUnit unit, WeaponProfile weapon)
	{
		foreach (var a in unit.CombinedAbilities)
		{
			if (!IsEffectActive(unit, a))
				continue;
			var text = a.Ability.Text ?? "";
			var named = unit.Parts.SelectMany(p => p.Weapons)
				.Select(w => w.Name)
				.Where(n => !string.IsNullOrWhiteSpace(n) && text.Contains(n, StringComparison.OrdinalIgnoreCase))
				.ToList();
			if (named.Count == 0 || named.Any(n => string.Equals(n, weapon.Name, StringComparison.OrdinalIgnoreCase)))
				foreach (var kw in EffectKeywords(a))
					yield return kw;
		}
	}

	// ---- Conditional detachment buffs (player-toggled) ----
	// Situational detachment-rule buffs the engine can't auto-apply because they depend on board state
	// (e.g. Relentless Onslaught's "+1 to Hit while targeting a unit on an objective"). Every matching unit
	// gets a toggle; switching it on injects the buff's modifiers into that unit's weapon stats. The buff is
	// only offered in the phases/turns the player scheduled for it in Setup (like army rules / stratagems).
	private IEnumerable<ConditionalUnitBuff> ConditionalBuffsFor(BattleUnit unit)
	{
		if (_battle is null)
			yield break;
		foreach (var det in _battle.Detachments)
			foreach (var rule in det.Rules)
				foreach (var buff in rule.ConditionalBuffs)
					if (UnitMatchesBuff(unit, buff)
						&& _battle.Source.IsScheduledNow(AbilityScheduleKeys.ForDetachmentBuff(det.Id, buff.Label), _phase, _turn))
						yield return buff;
	}

	private static bool UnitMatchesBuff(BattleUnit unit, ConditionalUnitBuff buff)
	{
		bool HasKeyword(string kw) => unit.Parts.Any(p => p.Datasheet.Keywords.Any(k => KeywordMatches(k, kw)));
		if (buff.RequiredKeywords.Any(kw => !HasKeyword(kw)))
			return false;
		if (buff.ExcludedKeywords.Any(HasKeyword))
			return false;
		return true;
	}

	// A datasheet keyword matches a wanted keyword when it equals it, or when it's the qualified "Prefix: Value"
	// form and the value matches — the seed stores the faction keyword as "Faction: Necrons", not "Necrons".
	private static bool KeywordMatches(string datasheetKeyword, string wanted)
	{
		if (string.Equals(datasheetKeyword, wanted, StringComparison.OrdinalIgnoreCase))
			return true;
		var colon = datasheetKeyword.IndexOf(':');
		return colon >= 0 && string.Equals(datasheetKeyword[(colon + 1)..].Trim(), wanted, StringComparison.OrdinalIgnoreCase);
	}

	private static string BuffKey(BattleUnit unit, ConditionalUnitBuff buff) => unit.Id + "|buff|" + buff.Label;

	private bool IsBuffActive(BattleUnit unit, ConditionalUnitBuff buff) => _activeEffects.Contains(BuffKey(unit, buff));

	private void ToggleBuff(BattleUnit unit, ConditionalUnitBuff buff, bool on)
	{
		if (on)
			_activeEffects.Add(BuffKey(unit, buff));
		else
			_activeEffects.Remove(BuffKey(unit, buff));
		ScheduleBattleSave();
	}

	private static string BuffModifierLabel(ConditionalUnitBuff buff) =>
		string.Join(", ", buff.Modifiers.Select(m => m.Describe()));

	// The stat modifiers from this unit's active conditional buffs that apply to the given weapon class.
	private IEnumerable<StatModifier> ActiveBuffModifiers(BattleUnit unit, bool ranged)
	{
		foreach (var buff in ConditionalBuffsFor(unit))
		{
			if (!IsBuffActive(unit, buff))
				continue;
			foreach (var mod in buff.Modifiers)
				if (mod.IsWeaponStat &&
					(mod.WeaponClass == WeaponClass.Any || mod.WeaponClass == (ranged ? WeaponClass.Ranged : WeaponClass.Melee)))
					yield return mod;
		}
	}

