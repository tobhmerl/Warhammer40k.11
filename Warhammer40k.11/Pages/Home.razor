@page "/"
@using Warhammer40k.Core
@inject IApiClient Api

<PageTitle>TombForge</PageTitle>

<section class="hero">
    <p class="eyebrow">Necron Tomb Forge</p>
    <h1 class="title">TombForge</h1>
    <p class="tagline">Forge, marshal, and reawaken your Warhammer&nbsp;40k armies.</p>

    <div class="card auth-card">
        @if (_loading)
        {
            <p class="status">
                <span class="pulse" aria-hidden="true"></span> Checking sign-in&hellip;
            </p>
        }
        else if (_user is { IsAuthenticated: true })
        {
            <p class="status ok">
                Signed in as <strong>@_user.UserName</strong>
                @if (!string.IsNullOrWhiteSpace(_user.IdentityProvider))
                {
                    <span class="via">via @_user.IdentityProvider</span>
                }
            </p>
            <div class="cta">
                <a class="btn primary" href="rosters">Open my rosters &rarr;</a>
                <a class="btn ghost" href="/.auth/logout">Sign out</a>
            </div>
            <p class="hint">
                Wrong account? Sign out here, then sign out of
                <a href="https://github.com/logout" target="_blank" rel="noopener">GitHub</a>
                (or use a private window) before signing back in &mdash; GitHub reuses your active session.
            </p>
        }
        else
        {
            <p class="status">Not signed in.</p>
            <div class="cta">
                <a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
            </div>
            <p class="hint">
                You'll sign in with whichever account is active on GitHub. To pick a different one,
                sign out of <a href="https://github.com/logout" target="_blank" rel="noopener">GitHub</a>
                first or use a private window.
            </p>
        }
    </div>

    <ul class="features">
        <li><span class="dot" aria-hidden="true"></span> Per-user rosters, saved to the cloud</li>
        <li><span class="dot" aria-hidden="true"></span> Private to your account</li>
        <li><span class="dot" aria-hidden="true"></span> Fast, offline-ready PWA</li>
    </ul>
</section>

@code {
    private UserInfo? _user;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _user = await Api.GetCurrentUserAsync();
        }
        finally
        {
            _loading = false;
        }
    }
}
