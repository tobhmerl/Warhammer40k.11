@page "/"
@page "/catalogue"
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@inject IApiClient Api

<PageTitle>TombWorld — Catalogue</PageTitle>

<div class="catalogue">
	<header class="head">
		<div>
			<p class="eyebrow">Necron datasheets</p>
			<h1>Catalogue</h1>
		</div>
		@if (!_loading && _catalogue.Datasheets.Count > 0)
		{
			<div class="head-actions">
				<span class="count">@_catalogue.Datasheets.Count units</span>
				@if (_authenticated)
				{
					<a class="edit-link" href="catalogue/edit">Edit catalogue</a>
				}
			</div>
		}
	</header>

	@if (_loading)
	{
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Summoning the catalogue&hellip;</p>
		</div>
	}
	else if (_catalogue.Datasheets.Count == 0)
	{
		<div class="card pad">
			<p class="status">The catalogue could not be loaded. Please reload the page.</p>
		</div>
	}
	else
	{
		<div class="search">
			<span class="search-icon" aria-hidden="true">⌕</span>
			<input class="search-input" type="search" autocomplete="off" spellcheck="false"
				   placeholder="Search units, keywords, rules…"
				   aria-label="Search the catalogue"
				   @bind="_query" @bind:event="oninput" />
			@if (_query.Length > 0)
			{
				<button class="search-clear" type="button" aria-label="Clear search" @onclick="Clear">✕</button>
			}
		</div>

		@if (_filter is not null)
		{
			<div class="filter-banner" role="status">
				<span class="fb-mark" aria-hidden="true"></span>
				<span class="fb-text">
					Highlighting units <strong>@_filter.Name</strong> can attach to
					<span class="fb-count">@PartnerCount</span>
				</span>
				<button class="fb-clear" type="button" @onclick="ClearFilter">Clear ✕</button>
			</div>
		}

		@if (MatchCount == 0)
		{
			<div class="card pad">
				<p class="status">No units match “<strong>@_query</strong>”.</p>
			</div>
		}
		else
		{
			@foreach (var group in Groups())
			{
				<section class="role-group" @key="group.Role">
					<h2 class="role-title">
						@group.Role
						<span class="role-count">@group.Units.Count</span>
					</h2>
					<ul class="unit-grid">
						@foreach (var d in group.Units)
						{
							<li @key="d.Id">
								<div class="unit-card @CardState(d)" role="button" tabindex="0"
									 @onclick="() => FilterBy(d)" @onkeydown="e => OnCardKey(e, d)"
									 aria-pressed="@(IsAnchor(d) ? "true" : "false")"
									 aria-label="@CardLabel(d)">
									<span class="unit-name">@d.Name</span>
									<span class="unit-meta">
										@if (d.IsEpicHero)
										{
											<span class="chip epic">Epic Hero</span>
										}
										@if (d.IsMonster)
										{
											<span class="chip monster">Monster</span>
										}
										<button class="chip sheet-btn" type="button"
												@onclick="() => Open(d)" @onclick:stopPropagation="true">
											Datasheet
										</button>
										<span class="pts">@PointsLabel(d)</span>
									</span>
								</div>
							</li>
						}
					</ul>
				</section>
			}
		}
	}
</div>

<Sheet Open="_selected is not null" Eyebrow="@_selected?.PrimaryRole" Title="@_selected?.Name" OnCloseRequested="Close">
	<DatasheetDetail Datasheet="_selected" Catalogue="_catalogue" />
</Sheet>

@code {
	private static readonly string[] RoleOrder =
	{
		"Epic Hero", "Character", "Battleline", "Infantry",
		"Mounted", "Beast", "Swarm", "Vehicle",
		"Dedicated Transport", "Fortification",
	};

	private CatalogueData _catalogue = new();
	private bool _loading = true;
	private bool _authenticated;
	private string _query = "";
	private Datasheet? _selected;
	private Datasheet? _filter;
	private HashSet<string> _partnerIds = new(StringComparer.OrdinalIgnoreCase);

	protected override async Task OnInitializedAsync()
	{
		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		_catalogue = await Api.GetCatalogueAsync(); // anonymous callers get the default catalogue
		_loading = false;
	}

	private void Open(Datasheet d) => _selected = d;

	private void Close() => _selected = null;

	private void Clear() => _query = "";

	private void FilterBy(Datasheet d)
	{
		// Clicking the anchored unit again clears the highlight; otherwise anchor on the clicked unit
		// and highlight its attachment partners (every other card is dimmed via CardState).
		if (IsAnchor(d))
		{
			ClearFilter();
			return;
		}
		_filter = d;
		_partnerIds = _catalogue.AttachmentPartners(d).Select(p => p.Id).ToHashSet(StringComparer.OrdinalIgnoreCase);
	}

	private void ClearFilter()
	{
		_filter = null;
		_partnerIds = new(StringComparer.OrdinalIgnoreCase);
	}

	private void OnCardKey(KeyboardEventArgs e, Datasheet d)
	{
		if (e.Key is "Enter" or " ")
			FilterBy(d);
	}

	private bool IsAnchor(Datasheet d) =>
		_filter is not null && string.Equals(_filter.Id, d.Id, StringComparison.OrdinalIgnoreCase);

	private bool IsPartner(Datasheet d) => _partnerIds.Contains(d.Id);

	private int PartnerCount => _partnerIds.Count;

	// Card CSS state under an active highlight: the clicked unit is the anchor, its valid
	// attachment targets are highlighted partners, everything else is dimmed.
	private string CardState(Datasheet d)
	{
		if (_filter is null)
			return "";
		if (IsAnchor(d))
			return "anchor";
		return IsPartner(d) ? "partner" : "dimmed";
	}

	private string CardLabel(Datasheet d)
	{
		if (_filter is null)
			return $"Highlight units {d.Name} can be attached to";
		if (IsAnchor(d))
			return $"{d.Name} (selected) — clear highlight";
		return IsPartner(d) ? $"{d.Name} can attach with {_filter.Name}" : d.Name;
	}

	private int MatchCount => _catalogue.Datasheets.Count(d => Matches(d, _query.Trim()));

	private IEnumerable<RoleGroup> Groups()
	{
		var q = _query.Trim();
		return _catalogue.Datasheets
			.Where(d => Matches(d, q))
			.GroupBy(d => string.IsNullOrWhiteSpace(d.PrimaryRole) ? "Other" : d.PrimaryRole)
			.OrderBy(g => RoleRank(g.Key))
			.ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
			.Select(g => new RoleGroup(
				g.Key,
				g.OrderBy(d => d.Name, StringComparer.OrdinalIgnoreCase).ToList()));
	}

	private static int RoleRank(string role)
	{
		var i = Array.FindIndex(RoleOrder, r => string.Equals(r, role, StringComparison.OrdinalIgnoreCase));
		return i < 0 ? RoleOrder.Length : i;
	}

	private static bool Matches(Datasheet d, string q)
	{
		if (q.Length == 0)
			return true;
		return d.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
			|| d.Keywords.Any(k => k.Contains(q, StringComparison.OrdinalIgnoreCase))
			|| d.FactionRules.Any(r => r.Contains(q, StringComparison.OrdinalIgnoreCase));
	}

	private static string PointsLabel(Datasheet d) =>
		d.PointsOptions.Count > 1
			? $"from {d.PointsOptions.Min(p => p.Points)} pts"
			: $"{d.Points} pts";

	private sealed record RoleGroup(string Role, IReadOnlyList<Datasheet> Units);
}
