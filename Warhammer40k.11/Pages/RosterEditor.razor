@page "/rosters/{Id}"
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Play
@using Warhammer40k.Core.Rosters
@using Warhammer40k.Core.Rosters.Validation
@implements IAsyncDisposable
@inject IApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>TombWorld — @(_roster?.Name ?? "Roster")</PageTitle>

@if (_loading)
{
	<div class="editor">
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Loading roster&hellip;</p>
		</div>
	</div>
}
else if (!_authenticated)
{
	<div class="editor">
		<div class="card pad signin">
			<p class="status">Sign in to edit your rosters.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	</div>
}
else if (_notFound || _roster is null)
{
	<div class="editor">
		<div class="card pad signin">
			<p class="status">That roster could not be found.</p>
			<a class="btn ghost" href="rosters">&larr; Back to rosters</a>
		</div>
	</div>
}
else
{
	<div class="editor">
		<a class="back" href="rosters">&larr; Rosters</a>

		<header class="sticky">
			<div class="title-row">
				<input class="name-input" value="@_roster.Name" @oninput="OnNameInput" maxlength="80" aria-label="Roster name" />
				<button class="btn small primary" type="button" disabled="@(_saving || !_dirty)" @onclick="SaveAsync">
					@(_saving ? "Saving…" : _dirty ? "Save" : "Saved")
				</button>
			</div>
			<div class="stats-row">
				<button class="detach detach-btn" type="button" @onclick="OpenDetachInfo" title="Choose detachments">
					@(_detachments.Count == 0 ? "No detachment" : string.Join(", ", _detachments.Select(d => d.Name)))
					<span class="dp-badge @(DpSpent > DpBudget ? "over" : "")">@DpSpent/@DpBudget DP</span>
					<span class="info-dot" aria-hidden="true">ⓘ</span>
				</button>
				<span class="spacer"></span>
				<span class="enh">Enhancements @EnhancementCount/3</span>
				<span class="points @(Over ? "over" : "")"><strong>@_validation.TotalPoints</strong> / @_roster.PointsLimit</span>
				<span class="pill @(_validation.IsReady ? "ready" : "issues")">
					@(_validation.IsReady ? "Ready" : $"{ErrorCount} {(ErrorCount == 1 ? "issue" : "issues")}")
				</span>
			</div>
		</header>

		@if (_validation.Messages.Count > 0)
		{
			<section class="panel @(_panelOpen ? "open" : "")">
				<button class="panel-head" type="button" @onclick="() => _panelOpen = !_panelOpen" aria-expanded="@_panelOpen">
					<span class="panel-title">
						Validation
						<span class="badge @(_validation.IsReady ? "ok" : "bad")">@_validation.Messages.Count</span>
					</span>
					<span class="chev" aria-hidden="true">@(_panelOpen ? "▾" : "▸")</span>
				</button>
				@if (_panelOpen)
				{
					<ul class="messages">
						@foreach (var m in OrderedMessages())
						{
							<li class="msg @Sev(m.Severity)" @key="m">
								<span class="rule">@m.RuleId</span>
								<span class="msg-text">@m.Text</span>
							</li>
						}
					</ul>
				}
			</section>
		}

		@if (_roster.Units.Count == 0)
		{
			<div class="card empty">
				<span class="empty-mark" aria-hidden="true"></span>
				<p>No units yet &mdash; add your first.</p>
				<button class="btn primary" type="button" @onclick="OpenPicker">Add unit</button>
			</div>
		}
		else
		{
			<div class="editor-actions">
				<button class="btn primary add-unit" type="button" @onclick="OpenPicker">+ Add unit</button>
				<button class="btn ghost" type="button" @onclick="OpenTiming">Stratagems</button>
			</div>

			@foreach (var group in UnitGroups())
			{
				<section class="role-group" @key="group.Role">
					<h2 class="role-title">@group.Role <span class="role-count">@group.Units.Count</span></h2>
					<ul class="unit-list">
						@foreach (var entry in group.Units)
						{
							<li @key="entry.Unit.Id">
								@UnitCard(entry, false)
								@{ var attachedLeaders = AttachedLeaders(entry.Unit); }
								@if (attachedLeaders.Count > 0)
								{
									<ul class="attached-list">
										@foreach (var leader in attachedLeaders)
										{
											<li @key="leader.Unit.Id">
												@UnitCard(leader, true)
											</li>
										}
									</ul>
								}
							</li>
						}
					</ul>
				</section>
			}
		}

		@if (_error is not null)
		{
			<p class="error">@_error</p>
		}
	</div>
}

<Sheet Open="_picking" Eyebrow="Add unit" Title="Add a unit" OnCloseRequested="ClosePicker">
	<div class="picker">
		<div class="search">
			<span class="search-icon" aria-hidden="true">⌕</span>
			<input class="search-input" type="search" placeholder="Search units…" aria-label="Search units"
				   @bind="_pickQuery" @bind:event="oninput" autocomplete="off" spellcheck="false" />
		</div>
		@foreach (var group in PickerGroups())
		{
			<section class="pick-group" @key="group.Role">
				<h3 class="pick-role">@group.Role</h3>
				<ul class="pick-list">
					@foreach (var e in group.Units)
					{
						var remaining = Remaining(e.Sheet);
						<li @key="e.Sheet.Id">
							<button class="pick-row" type="button" disabled="@(remaining <= 0)" @onclick="() => AddUnit(e.Sheet)">
								<span class="pick-name">@e.Sheet.Name</span>
								<span class="pick-meta">
									<span class="pick-pts">@PointsLabel(e.Sheet)</span>
									<span class="pick-remain @(remaining <= 0 ? "none" : "")">@remaining left</span>
								</span>
							</button>
						</li>
					}
				</ul>
			</section>
		}
	</div>
</Sheet>

<Sheet Open="_configuring is not null" Eyebrow="Configure"
	   Title="@(_configuring is { } cu ? SheetFor(cu)?.Name : null)" OnCloseRequested="CloseConfig">
	@if (_configuring is { } u && SheetFor(u) is { } sheet)
	{
		<div class="config">
			@if (sheet.PointsOptions.Count > 0)
			{
				<div class="cfg-block">
					<span class="cfg-label">Unit size</span>
					<div class="sizes">
						@foreach (var o in sheet.PointsOptions)
						{
							<button type="button" class="size @(u.ModelCount == o.Models ? "on" : "")" @onclick="() => SetSize(u, o.Models)">
								@o.Models @(o.Models == 1 ? "model" : "models") · @OptionPoints(u, sheet, o) pts
							</button>
						}
					</div>
				</div>
			}

			@foreach (var group in sheet.WargearGroups)
			{
				<div class="cfg-block" @key="group.Id">
					@if (group.PerModel)
					{
						<span class="cfg-label">@group.Name <span class="cfg-hint">one per model · @PerModelAssignedLabel(u, group)</span></span>
						<div class="loadout">
							@foreach (var opt in group.Options)
							{
								var isDefault = ReferenceEquals(opt, group.Options[0]);
								var count = PerModelCount(u, group, opt);
								<div class="loadout-row">
									<span class="loadout-name">@(string.IsNullOrWhiteSpace(opt.Name) ? "(unnamed)" : opt.Name)</span>
									<span class="loadout-step">
										<button type="button" class="lstep" disabled="@(isDefault || count == 0)" @onclick="() => StepPerModel(u, group, opt, -1)" aria-label="Fewer">−</button>
										<span class="loadout-count @(count > 0 ? "has" : "")">@count</span>
										<button type="button" class="lstep" disabled="@(isDefault || PerModelRemaining(u, group) == 0)" @onclick="() => StepPerModel(u, group, opt, 1)" aria-label="More">+</button>
									</span>
								</div>
							}
						</div>
					}
					else
					{
						<span class="cfg-label">@group.Name <span class="cfg-hint">choose @WargearRangeLabel(group)</span></span>
						@foreach (var (cls, opts) in WargearOptionsByClass(sheet, group))
						{
							@if (!string.IsNullOrEmpty(cls))
							{
								<span class="wargear-class">@cls</span>
							}
							<div class="sizes">
								@foreach (var opt in opts)
								{
									<button type="button" class="size @(IsWargearSelected(u, group.Id, opt.Id) ? "on" : "")"
											@onclick="() => ToggleWargear(u, group.Id, opt.Id, group.Max)">
										@(string.IsNullOrWhiteSpace(opt.Name) ? "(unnamed)" : opt.Name)
									</button>
								}
							</div>
						}
					}
				</div>
			}

			@if (sheet.WarlordEligible)
			{
				<div class="cfg-block">
					<span class="cfg-label">Warlord</span>
					<button type="button" class="toggle @(u.IsWarlord ? "on" : "")" @onclick="() => SetWarlord(u, !u.IsWarlord)">
						@(u.IsWarlord ? "Warlord" : "Make Warlord")
					</button>
				</div>
			}

			@if (sheet.HasLeaderAbility)
			{
				<div class="cfg-block">
					<span class="cfg-label">Attach to</span>
					<select class="input" value="@(u.AttachedToRosterUnitId ?? "")" @onchange="e => SetAttachment(u, e.Value?.ToString())">
						<option value="">Not attached</option>
						@foreach (var t in LeaderTargets(u))
						{
							<option value="@t.Id">@t.Name</option>
						}
					</select>
				</div>
			}

			@if (ShowEnhancementBlock(sheet, u))
			{
				<div class="cfg-block">
					<span class="cfg-label">@(sheet.IsCharacter ? "Enhancement" : "Upgrade")</span>
					@if (_detachments.All(d => d.Enhancements.Count == 0))
					{
						<p class="cfg-note">No enhancements available from your detachment(s) yet.</p>
					}
					else if (EligibleEnhancements(sheet, u).Any())
					{
						<select class="input" value="@(u.AssignedEnhancementId ?? "")" @onchange="e => SetEnhancement(u, e.Value?.ToString())">
							<option value="">None</option>
							@foreach (var enh in EligibleEnhancements(sheet, u))
							{
								var taken = IsEnhancementTakenElsewhere(enh.Id, u);
								<option value="@enh.Id" disabled="@taken">@enh.Name (+@enh.Points)@(taken ? " — already taken" : "")</option>
							}
						</select>
					}
					else
					{
						<p class="cfg-note">No eligible enhancements for this character.</p>
					}
				</div>
			}

			@if (u.AppliedBindingId is { } binding)
			{
				<div class="cfg-block">
					<span class="cfg-label">Necrodermal binding</span>
					<p class="cfg-note">@binding · +@u.BindingSurcharge pts (Pantheon of Woe)</p>
				</div>
			}

			@{
				var schedAbilities = CombinedScheduleAbilities(u);
				var schedMulti = GroupMembers(u).Count > 1;
			}
			@if (schedAbilities.Count > 0)
			{
				<div class="cfg-block">
					<span class="cfg-label">Abilities — when usable in Play Mode</span>
					<p class="cfg-hint">@(schedMulti ? "All abilities of this unit and its attached leaders, combined. " : "")Tick the phase + turn each ability is usable in. Nothing shows in Play until you tick it. Tap a name to read its rules.</p>
					@foreach (var ab in schedAbilities)
					{
						var key = ab.Key;
						var textOpen = _openSchedText.Contains(ab.Name);
						var hasText = !string.IsNullOrWhiteSpace(ab.Text);
						<div class="sched" @key="key">
							<div class="sched-head">
								@if (hasText)
								{
									<button type="button" class="sched-name-btn" @onclick="() => ToggleSchedText(ab.Name)" aria-expanded="@textOpen" title="Show this ability's rules text">
										<span class="chev" aria-hidden="true">@(textOpen ? "▾" : "▸")</span>
										<span class="sched-name">@ab.Name</span>
									</button>
								}
								else
								{
									<span class="sched-name">@ab.Name</span>
								}
								@if (schedMulti)
								{
									<span class="sched-member">@ab.Source</span>
								}
								@if (ab.Summary is { } sum)
								{
									<label class="sched-apply" title="Apply @sum to the unit instead of showing the rules text">
										<input type="checkbox" checked="@IsApplied(key)" @onchange="e => SetApplied(key, (bool)e.Value!)" />
										Apply @sum
									</label>
								}
							</div>
							<div class="sched-kw-row">
								<label class="sched-kw" title="Show this ability as a short keyword chip in Play Mode (e.g. Stealth), like Inv/FNP">
									<input type="checkbox" checked="@ShowKeyword(key)" @onchange="e => ToggleKeyword(key, (bool)e.Value!)" />
									Show as keyword
								</label>
								@if (ShowKeyword(key))
								{
									<input class="sched-kw-text" maxlength="40" placeholder="e.g. Stealth (max 3 words)"
										   value="@KeywordText(key)" @onchange="e => SetKeyword(key, e.Value?.ToString())" />
								}
							</div>
							@if (textOpen && hasText)
							{
								<p class="sched-text">@CleanText(ab.Text)</p>
							}
							@ScheduleGrid(key)
						</div>
					}
				</div>
			}

			<div class="cfg-block">
				<button type="button" class="ds-toggle" @onclick="() => _showDatasheet = !_showDatasheet" aria-expanded="@_showDatasheet">
					<span class="cfg-label">Datasheet</span>
					<span class="chev" aria-hidden="true">@(_showDatasheet ? "▾" : "▸")</span>
				</button>
				@if (_showDatasheet)
				{
					<DatasheetDetail Datasheet="sheet" Catalogue="_catalogue" />
				}
			</div>

			<div class="cfg-actions">
				<button class="btn danger" type="button" @onclick="() => RemoveUnit(u)">Remove unit</button>
				<button class="btn ghost" type="button" @onclick="CloseConfig">Done</button>
			</div>
		</div>
	}
</Sheet>

<Sheet Open="_timingOpen" Eyebrow="Play Mode" Title="Stratagems" OnCloseRequested="CloseTiming">
	@if (_roster is not null)
	{
		<div class="config">
			<p class="cfg-note">Tick the phase + turn each army rule, detachment rule and stratagem can be used in. Nothing appears in Play Mode until you tick it. Tap a name to read its rules.</p>

			@{ var armyRules = ArmyRuleCatalogue.ForFaction(_roster.Faction); }
			@if (armyRules.Count > 0)
			{
				<div class="cfg-block">
					<span class="cfg-label">Army rules</span>
					@foreach (var rule in armyRules)
					{
						var key = AbilityScheduleKeys.ForArmyRule(rule.Name);
						<div class="sched" @key="key">
							<div class="sched-head"><span class="sched-name">@rule.Name</span></div>
							@ScheduleGrid(key)
						</div>
					}
				</div>
			}

			@{ var detBuffs = _detachments
				.SelectMany(d => d.Rules.SelectMany(r => r.ConditionalBuffs.Select(b => (Det: d, Buff: b))))
				.ToList(); }
			@if (detBuffs.Count > 0)
			{
				<div class="cfg-block">
					<span class="cfg-label">Detachment rules</span>
					@foreach (var (det, buff) in detBuffs)
					{
						var key = AbilityScheduleKeys.ForDetachmentBuff(det.Id, buff.Label);
						var textOpen = _openSchedText.Contains(key);
						<div class="sched" @key="key">
							<div class="sched-head">
								<button type="button" class="sched-name-btn" @onclick="() => ToggleSchedText(key)" aria-expanded="@textOpen" title="Show this rule's effect">
									<span class="chev" aria-hidden="true">@(textOpen ? "▾" : "▸")</span>
									<span class="sched-name">@buff.Label</span>
								</button>
								<span class="sched-src">@det.Name</span>
							</div>
							@if (textOpen)
							{
								<p class="sched-text">@buff.Effect</p>
							}
							@ScheduleGrid(key)
						</div>
					}
				</div>
			}

			<div class="cfg-block">
				<span class="cfg-label">Core stratagems</span>
				@foreach (var s in CoreStratagemCatalogue.All)
				{
					var key = AbilityScheduleKeys.ForCoreStratagem(s.Id);
					var textOpen = _openSchedText.Contains(key);
					<div class="sched" @key="key">
						<div class="sched-head">
							<button type="button" class="sched-name-btn" @onclick="() => ToggleSchedText(key)" aria-expanded="@textOpen" title="Show this stratagem's rules text">
								<span class="chev" aria-hidden="true">@(textOpen ? "▾" : "▸")</span>
								<span class="sched-name">@s.Name</span>
							</button>
							<span class="sched-src">@s.Cost CP</span>
						</div>
						@if (textOpen)
						{
							@StratRef(s.Flavour, s.When, s.Target, s.Effect, s.Restrictions)
						}
						@ScheduleGrid(key)
					</div>
				}
			</div>

			@foreach (var det in _detachments)
			{
				@if (det.Stratagems.Count > 0)
				{
					<div class="cfg-block" @key="det.Id">
						<span class="cfg-label">@det.Name stratagems</span>
						@foreach (var s in det.Stratagems)
						{
							var key = AbilityScheduleKeys.ForDetachmentStratagem(det.Id, s.Id);
							var textOpen = _openSchedText.Contains(key);
							<div class="sched" @key="key">
								<div class="sched-head">
									<button type="button" class="sched-name-btn" @onclick="() => ToggleSchedText(key)" aria-expanded="@textOpen" title="Show this stratagem's rules text">
										<span class="chev" aria-hidden="true">@(textOpen ? "▾" : "▸")</span>
										<span class="sched-name">@s.Name</span>
									</button>
									<span class="sched-src">@s.CpCost CP</span>
								</div>
								@if (textOpen)
								{
									@StratRef(null, s.When, s.Target, s.Effect, null)
								}
								@ScheduleGrid(key)
							</div>
						}
					</div>
				}
			}
		</div>
	}
</Sheet>

<Sheet Open="_detachInfoOpen" Eyebrow="Detachments" Title="@($"Detachments · {DpSpent}/{DpBudget} DP")" OnCloseRequested="CloseDetachInfo">
	<div class="detach-picker">
		<p class="cfg-note">
			Spend up to <strong>@DpBudget</strong> Detachment Points at @(_roster?.PointsLimit) pts — pick one or more.
			<span class="dp-left">@DpRemaining DP left</span>
		</p>
		@if (DpSpent > DpBudget)
		{
			<p class="dp-warn">Over budget by @(DpSpent - DpBudget) DP.</p>
		}
		@foreach (var d in DetachmentCatalogue.Selectable)
		{
			var selected = IsDetachmentSelected(d);
			var disabled = !CanToggleDetachment(d);
			<div class="dp-item @(selected ? "on" : "") @(disabled ? "disabled" : "")">
				<button type="button" class="dp-toggle" @onclick="() => ToggleDetachment(d)" disabled="@disabled" aria-pressed="@selected">
					<span class="dp-check" aria-hidden="true">@(selected ? "✓" : "")</span>
					<span class="dp-name">@d.Name</span>
					<span class="dp-cost">@d.DetachmentPoints DP</span>
				</button>
				@if (d.Rules.Count > 0)
				{
					<div class="dp-rules">
						@foreach (var r in d.Rules)
						{
							var rkey = $"rule|{d.Id}|{r.Name}";
							var ropen = _openDetachInfo.Contains(rkey);
							<div class="dp-expand" @key="rkey">
								<button type="button" class="dp-expand-btn rule" @onclick="() => ToggleDetachInfo(rkey)" aria-expanded="@ropen" title="Show this rule's text">
									<span class="chev" aria-hidden="true">@(ropen ? "▾" : "▸")</span>
									<span class="dp-rule-name">@r.Name</span>
								</button>
								@if (ropen && !string.IsNullOrWhiteSpace(r.Text))
								{
									<p class="dp-expand-text">@CleanText(r.Text)</p>
								}
							</div>
						}
					</div>
				}
				@if (disabled && !selected)
				{
					<p class="dp-note">@(ClashesWithSelection(d) ? $"Excluded — {string.Join("/", d.Tags).ToUpperInvariant()} detachment already chosen." : "Not enough Detachment Points left.")</p>
				}
				@if (d.Enhancements.Count > 0)
				{
					<div class="dp-enh-list">
						<span class="dp-enh-label">Enhancements</span>
						@foreach (var e in d.Enhancements)
						{
							var ekey = $"enh|{d.Id}|{e.Id}";
							var eopen = _openDetachInfo.Contains(ekey);
							<div class="dp-expand" @key="ekey">
								<button type="button" class="dp-expand-btn" @onclick="() => ToggleDetachInfo(ekey)" aria-expanded="@eopen" title="Show this enhancement's text">
									<span class="chev" aria-hidden="true">@(eopen ? "▾" : "▸")</span>
									<span class="dp-enh-name">@e.Name</span>
									<span class="dp-enh-pts">+@e.Points</span>
								</button>
								@if (eopen)
								{
									<p class="dp-expand-text">@(string.IsNullOrWhiteSpace(e.Text) ? "No rules text yet." : CleanText(e.Text))</p>
								}
							</div>
						}
					</div>
				}
			</div>
		}
	</div>
</Sheet>

@code {
	private static readonly string[] RoleOrder =
	{
		"Epic Hero", "Character", "Battleline", "Infantry",
		"Mounted", "Beast", "Swarm", "Vehicle",
		"Dedicated Transport", "Fortification",
	};

	[Parameter] public string Id { get; set; } = "";

	private readonly RosterValidator _validator = new();
	private CatalogueData _catalogue = new();
	private Roster? _roster;
	private Detachment? _detachment;            // primary (first) selected detachment, for back-compat
	private List<Detachment> _detachments = []; // all selected detachments (11th edition)
	private ValidationResult _validation = new(Array.Empty<ValidationMessage>(), 0);

	private string? _loadedId;
	private bool _loading = true;
	private bool _authenticated;
	private bool _notFound;
	private bool _saving;
	private bool _dirty;
	private bool _panelOpen;
	private string? _error;

	// ---- Auto-save (debounced): a save fires ~2s after the last change, plus a flush on navigation/tab-hide. ----
	private const int AutoSaveDelayMs = 2000;
	private CancellationTokenSource? _autoSaveCts;
	private DotNetObjectReference<RosterEditor>? _selfRef;
	private bool _flushHookInstalled;

	// Sheet state (markup added alongside the editor body).
	private bool _picking;
	private string _pickQuery = "";
	private RosterUnit? _configuring;
	private bool _timingOpen;
	private bool _detachInfoOpen;
	private bool _showDatasheet;

	protected override void OnInitialized()
	{
		// Flush any pending changes before an in-app navigation away from the editor.
		Nav.LocationChanged += OnLocationChanged;
	}

	protected override async Task OnParametersSetAsync()
	{
		if (_loadedId == Id)
			return;
		_loadedId = Id;
		await LoadAsync();

		// Arriving from the New-Roster wizard (rosters/{id}?add=1) → open the unit picker straight away.
		if (_roster is not null && WantsAddOnArrival())
			OpenPicker();
	}

	private bool WantsAddOnArrival()
	{
		var query = new Uri(Nav.Uri).Query;
		return query.Contains("add=1", StringComparison.OrdinalIgnoreCase);
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender && !_flushHookInstalled)
		{
			_flushHookInstalled = true;
			_selfRef ??= DotNetObjectReference.Create(this);
			try
			{
				// Save pending changes when the tab is hidden / closed (visibilitychange + pagehide).
				await JS.InvokeVoidAsync("tombworld.flushOnHide", _selfRef);
			}
			catch (JSException) { }
			catch (InvalidOperationException) { }
		}
	}

	private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
	{
		if (_dirty)
			_ = SaveAsync();
	}

	/// <summary>Invoked from JS when the tab is hidden or closing — persist pending changes immediately.</summary>
	[JSInvokable]
	public async Task FlushSave()
	{
		_autoSaveCts?.Cancel();
		if (_dirty)
			await SaveAsync();
	}

	private async Task LoadAsync()
	{
		_loading = true;
		_notFound = false;
		_error = null;

		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
		{
			if (_catalogue.Datasheets.Count == 0)
				_catalogue = await Api.GetCatalogueAsync();

			var roster = await Api.GetRosterAsync(Id);
			if (roster is null)
			{
				_notFound = true;
			}
			else
			{
				_roster = roster;
				ResolveDetachments();
				_panelOpen = false;
				Recompute();
				_dirty = false;
			}
		}

		_loading = false;
	}

	private void Recompute()
	{
		if (_roster is null)
			return;
		var pantheon = _detachments.FirstOrDefault(d => d.AppliesPantheonBindings) ?? _detachment;
		PantheonBindingApplier.Apply(_roster, _catalogue, pantheon);
		_validation = _validator.Validate(_roster, _catalogue);
	}

	private void MarkChanged()
	{
		Recompute();
		_dirty = true;
		ScheduleAutoSave();
	}

	// Restart the debounce timer: the actual save fires AutoSaveDelayMs after the most recent change, so a
	// burst of edits (e.g. ticking several checkboxes) results in a single save once you pause.
	private void ScheduleAutoSave()
	{
		_autoSaveCts?.Cancel();
		_autoSaveCts?.Dispose();
		var cts = new CancellationTokenSource();
		_autoSaveCts = cts;
		_ = AutoSaveAfterDelayAsync(cts.Token);
	}

	private async Task AutoSaveAfterDelayAsync(CancellationToken token)
	{
		try
		{
			await Task.Delay(AutoSaveDelayMs, token);
		}
		catch (TaskCanceledException)
		{
			return; // a newer change rescheduled the save
		}
		if (token.IsCancellationRequested)
			return;
		await SaveAsync();
		StateHasChanged();
	}

	// ---- Detachments (11th edition: one or more within the Detachment-Points budget) ----
	private void ResolveDetachments()
	{
		_detachments = (_roster?.EffectiveDetachmentIds ?? [])
			.Select(DetachmentCatalogue.FindById)
			.Where(d => d is not null)
			.Select(d => d!)
			.ToList();
		_detachment = _detachments.FirstOrDefault();
	}

	private int DpBudget => _roster is null ? 0 : DetachmentCatalogue.Budget(_roster.PointsLimit);

	private int DpSpent => _detachments.Sum(d => d.DetachmentPoints);

	private int DpRemaining => Math.Max(0, DpBudget - DpSpent);

	private bool IsDetachmentSelected(Detachment d) =>
		_roster is not null && _roster.EffectiveDetachmentIds.Contains(d.Id, StringComparer.OrdinalIgnoreCase);

	// A detachment that shares an exclusivity tag (e.g. DYNASTY) with an already-selected one can't be added.
	private bool ClashesWithSelection(Detachment d) =>
		d.Tags.Count > 0 && _detachments.Any(s =>
			!string.Equals(s.Id, d.Id, StringComparison.OrdinalIgnoreCase)
			&& s.Tags.Any(t => d.Tags.Contains(t, StringComparer.OrdinalIgnoreCase)));

	// You can always deselect; you can only add a detachment that fits the remaining DP and clashes with nothing.
	private bool CanToggleDetachment(Detachment d) =>
		IsDetachmentSelected(d) || (d.DetachmentPoints <= DpRemaining && !ClashesWithSelection(d));

	private void ToggleDetachment(Detachment d)
	{
		if (_roster is null)
			return;

		var ids = _roster.DetachmentIds;
		// Migrate a legacy single id into the list the first time the selection is edited.
		if (ids.Count == 0 && !string.IsNullOrEmpty(_roster.DetachmentId))
			ids.Add(_roster.DetachmentId);

		var removed = ids.RemoveAll(id => string.Equals(id, d.Id, StringComparison.OrdinalIgnoreCase)) > 0;
		if (!removed)
		{
			// Adding: refuse if it would break the DP budget or an exclusivity tag.
			if (d.DetachmentPoints > DpRemaining || ClashesWithSelection(d))
				return;
			ids.Add(d.Id);
		}

		_roster.DetachmentId = ids.FirstOrDefault() ?? "";
		ResolveDetachments();
		// Enhancements are detachment-specific: drop any assignment the new selection no longer offers so it
		// can't trip R6 ("not part of your detachment(s)") and the slot frees up for the new detachment's picks.
		EnhancementReconciler.Revoke(_roster, _detachments);
		MarkChanged();
	}

	private void OnNameInput(ChangeEventArgs e)
	{
		if (_roster is null)
			return;
		_roster.Name = e.Value?.ToString() ?? "";
		_dirty = true;
	}

	private async Task SaveAsync()
	{
		if (_roster is null || _saving || !_dirty)
			return;

		_saving = true;
		_error = null;
		// Clear the flag up front so edits made during the save mark the roster dirty again (and reschedule).
		_dirty = false;
		try
		{
			var saved = await Api.SaveRosterAsync(_roster);
			// Keep our in-memory instance (open sheets reference its units); just sync server-assigned fields.
			_roster.Id = saved.Id;
			_roster.CreatedUtc = saved.CreatedUtc;
			_roster.ModifiedUtc = saved.ModifiedUtc;
		}
		catch (Exception)
		{
			_error = "Could not save the roster. Auto-save will retry on the next change.";
			_dirty = true; // keep it dirty so the next change (or manual Save) retries
		}
		finally
		{
			_saving = false;
		}
	}

	// ---- Sheet open/close ----
	private void OpenPicker()
	{
		_pickQuery = "";
		_picking = true;
	}

	private void ClosePicker() => _picking = false;

	private void OpenConfig(RosterUnit unit)
	{
		_configuring = unit;
		_showDatasheet = false;
	}

	private void CloseConfig() => _configuring = null;

	private void OpenTiming() => _timingOpen = true;

	private void CloseTiming() => _timingOpen = false;

	private void OpenDetachInfo() => _detachInfoOpen = true;

	private void CloseDetachInfo() => _detachInfoOpen = false;

	private static string EligibilityText(Enhancement enhancement)
	{
		var parts = new List<string>();
		if (enhancement.Eligibility.RequiredKeywords.Count > 0)
			parts.Add("requires " + string.Join(", ", enhancement.Eligibility.RequiredKeywords));
		if (enhancement.Eligibility.AnyOfKeywords.Count > 0)
			parts.Add("requires " + string.Join(" or ", enhancement.Eligibility.AnyOfKeywords));
		if (enhancement.Eligibility.ExcludedKeywords.Count > 0)
			parts.Add("not for " + string.Join(", ", enhancement.Eligibility.ExcludedKeywords));
		return string.Join(" · ", parts);
	}

	// ---- Mutations ----
	private void AddUnit(Datasheet sheet)
	{
		if (_roster is null)
			return;
		_roster.Units.Add(RosterUnit.FromDatasheet(sheet));
		MarkChanged();
	}

	private void RemoveUnit(RosterUnit unit)
	{
		if (_roster is null)
			return;

		// Detach any leaders pointing at this unit so no dangling references remain.
		foreach (var other in _roster.Units)
		{
			if (other.AttachedToRosterUnitId == unit.Id)
				other.AttachedToRosterUnitId = null;
		}

		_roster.Units.Remove(unit);
		_configuring = null;
		MarkChanged();
	}

	private void SetSize(RosterUnit unit, int models)
	{
		unit.ModelCount = models;
		MarkChanged();
	}

	private void SetWarlord(RosterUnit unit, bool isWarlord)
	{
		if (isWarlord && _roster is not null)
		{
			foreach (var other in _roster.Units)
				other.IsWarlord = false;
		}
		unit.IsWarlord = isWarlord;
		MarkChanged();
	}

	private void SetAttachment(RosterUnit unit, string? targetId)
	{
		unit.AttachedToRosterUnitId = string.IsNullOrEmpty(targetId) ? null : targetId;
		MarkChanged();
	}

	private void SetEnhancement(RosterUnit unit, string? enhancementId)
	{
		unit.AssignedEnhancementId = string.IsNullOrEmpty(enhancementId) ? null : enhancementId;
		MarkChanged();
	}

	// True when an enhancement is already assigned to a DIFFERENT unit (each may be taken once — R6). Such an
	// option is disabled in the picker so it can't be double-assigned.
	private bool IsEnhancementTakenElsewhere(string enhancementId, RosterUnit unit) =>
		_roster is not null && _roster.Units.Any(u =>
			!ReferenceEquals(u, unit)
			&& string.Equals(u.AssignedEnhancementId, enhancementId, StringComparison.OrdinalIgnoreCase));

	private IEnumerable<Enhancement> EligibleEnhancements(Datasheet sheet, RosterUnit unit) =>
		// Offer Character Enhancements to eligible characters, and unit Upgrades to eligible non-character units
		// (R6); keep any current pick visible even if it became ineligible.
		_detachments.SelectMany(d => d.Enhancements).Where(e => IsOfferable(e, sheet, unit));

	private static bool IsOfferable(Enhancement enhancement, Datasheet sheet, RosterUnit unit)
	{
		if (string.Equals(enhancement.Id, unit.AssignedEnhancementId, StringComparison.OrdinalIgnoreCase))
			return true; // keep the current pick visible
		if (!enhancement.IsAvailableTo(sheet))
			return false;
		return enhancement.Scope == EnhancementScope.Unit ? !sheet.IsCharacter : sheet.CanTakeEnhancements;
	}

	// Show the picker for any Character (so it can read "None"/"no eligible") and for any non-character unit
	// that qualifies for at least one Upgrade.
	private bool ShowEnhancementBlock(Datasheet sheet, RosterUnit unit) =>
		sheet.CanTakeEnhancements || EligibleEnhancements(sheet, unit).Any();

	private static bool IsWargearSelected(RosterUnit unit, string groupId, string optionId)
	{
		var selection = unit.Wargear.FirstOrDefault(w => string.Equals(w.GroupId, groupId, StringComparison.OrdinalIgnoreCase));
		return selection is not null && selection.OptionIds.Contains(optionId, StringComparer.OrdinalIgnoreCase);
	}

	// The weapon class ("Ranged" / "Melee") of a wargear option, resolved by matching the option's name to one
	// of the datasheet's weapons (an option label can name a weapon, e.g. "Gauss reaper"). Returns "" when no
	// weapon matches, so such options render without a class sub-heading.
	private static string OptionWeaponType(Datasheet sheet, Warhammer40k.Core.Catalogue.WargearOption option)
	{
		var name = (option.Name ?? "").Trim();
		if (name.Length == 0)
			return "";
		var weapon = sheet.Weapons.FirstOrDefault(w =>
			string.Equals(w.Name, name, StringComparison.OrdinalIgnoreCase)
			|| name.Contains(w.Name, StringComparison.OrdinalIgnoreCase)
			|| w.Name.Contains(name, StringComparison.OrdinalIgnoreCase));
		if (weapon is null)
			return "";
		return string.Equals(weapon.Type, "Melee", StringComparison.OrdinalIgnoreCase) ? "Melee" : "Ranged";
	}

	// Options of a choice group split by weapon class, in display order: Ranged first, then Melee, then any
	// unmatched options (no class heading).
	private static IEnumerable<(string Label, IReadOnlyList<Warhammer40k.Core.Catalogue.WargearOption> Options)> WargearOptionsByClass(
		Datasheet sheet, Warhammer40k.Core.Catalogue.WargearGroup group)
	{
		foreach (var cls in new[] { "Ranged", "Melee", "" })
		{
			var opts = group.Options.Where(o => OptionWeaponType(sheet, o) == cls).ToList();
			if (opts.Count > 0)
				yield return (cls, opts);
		}
	}

	private void ToggleWargear(RosterUnit unit, string groupId, string optionId, int max)
	{
		var selection = unit.Wargear.FirstOrDefault(w => string.Equals(w.GroupId, groupId, StringComparison.OrdinalIgnoreCase));
		if (selection is null)
		{
			selection = new WargearSelection { GroupId = groupId };
			unit.Wargear.Add(selection);
		}

		if (selection.OptionIds.Contains(optionId, StringComparer.OrdinalIgnoreCase))
		{
			// Re-tapping the selected option clears it (allows deselect-to-none for optional Min=0 groups).
			selection.OptionIds.RemoveAll(id => string.Equals(id, optionId, StringComparison.OrdinalIgnoreCase));
		}
		else
		{
			selection.OptionIds.Add(optionId);
			// Enforce the group's Max: a Max=1 group behaves as radio (new pick replaces the old); a larger Max
			// drops the oldest picks so the group never exceeds Max.
			if (max > 0)
				while (selection.OptionIds.Count > max)
					selection.OptionIds.RemoveAt(0);
		}

		if (selection.OptionIds.Count == 0)
			unit.Wargear.Remove(selection);

		MarkChanged();
	}

	// ---- Per-model loadout groups (e.g. Lokhust Heavy Destroyers: each model takes Gauss or Enmitic) ----

	// Models taking this option: the stored count for a non-default option, or the remaining models (model
	// count minus the others) for the group's first option, which is the default that absorbs the remainder.
	private static int PerModelCount(RosterUnit unit, Warhammer40k.Core.Catalogue.WargearGroup group, Warhammer40k.Core.Catalogue.WargearOption option)
	{
		if (group.Options.Count == 0)
			return 0;
		if (!ReferenceEquals(option, group.Options[0]))
			return StoredPerModelCount(unit, group, option.Id);
		var others = group.Options.Skip(1).Sum(o => StoredPerModelCount(unit, group, o.Id));
		return Math.Max(0, unit.ModelCount - others);
	}

	private static int StoredPerModelCount(RosterUnit unit, Warhammer40k.Core.Catalogue.WargearGroup group, string optionId)
	{
		var selection = unit.Wargear.FirstOrDefault(w => string.Equals(w.GroupId, group.Id, StringComparison.OrdinalIgnoreCase));
		var stored = selection?.Counts.FirstOrDefault(c => string.Equals(c.OptionId, optionId, StringComparison.OrdinalIgnoreCase))?.Models ?? 0;
		return Math.Clamp(stored, 0, unit.ModelCount);
	}

	// Models still on the default (first) option — how many are free to be reassigned to another option.
	private static int PerModelRemaining(RosterUnit unit, Warhammer40k.Core.Catalogue.WargearGroup group) =>
		group.Options.Count == 0 ? 0
		: Math.Max(0, unit.ModelCount - group.Options.Skip(1).Sum(o => StoredPerModelCount(unit, group, o.Id)));

	private static string PerModelAssignedLabel(RosterUnit unit, Warhammer40k.Core.Catalogue.WargearGroup group) =>
		$"{unit.ModelCount} {(unit.ModelCount == 1 ? "model" : "models")}";

	private void StepPerModel(RosterUnit unit, Warhammer40k.Core.Catalogue.WargearGroup group, Warhammer40k.Core.Catalogue.WargearOption option, int delta)
	{
		if (group.Options.Count == 0 || ReferenceEquals(option, group.Options[0]))
			return; // the default (first) option is derived from the others; it is not edited directly

		var selection = unit.Wargear.FirstOrDefault(w => string.Equals(w.GroupId, group.Id, StringComparison.OrdinalIgnoreCase));
		if (selection is null)
		{
			selection = new WargearSelection { GroupId = group.Id };
			unit.Wargear.Add(selection);
		}

		var entry = selection.Counts.FirstOrDefault(c => string.Equals(c.OptionId, option.Id, StringComparison.OrdinalIgnoreCase));
		if (entry is null)
		{
			entry = new WargearOptionCount { OptionId = option.Id };
			selection.Counts.Add(entry);
		}

		// Cap so this option plus the OTHER non-default options never exceed the unit size (default keeps the rest).
		var others = group.Options.Skip(1)
			.Where(o => !string.Equals(o.Id, option.Id, StringComparison.OrdinalIgnoreCase))
			.Sum(o => StoredPerModelCount(unit, group, o.Id));
		entry.Models = Math.Clamp(entry.Models + delta, 0, Math.Max(0, unit.ModelCount - others));

		// Keep storage minimal: drop zero entries, and an empty selection (an all-default unit stores nothing).
		selection.Counts.RemoveAll(c => c.Models <= 0);
		if (selection.OptionIds.Count == 0 && selection.Counts.Count == 0)
			unit.Wargear.Remove(selection);

		MarkChanged();
	}

	private static string WargearRangeLabel(Warhammer40k.Core.Catalogue.WargearGroup group) =>
		group.Min == group.Max ? $"exactly {group.Min}"
		: group.Max > 0 ? $"{group.Min}–{group.Max}"
		: $"{group.Min}+";

	// ---- Ability / stratagem scheduling (manual phase + turn windows) ----

	/// <summary>A datasheet ability (or assigned enhancement) that gets a schedule grid: its key, name, rules text, and conferred-effect summary.</summary>
	private sealed record SchedAbility(string Key, string Name, string Text, string? Summary, string Source);

	// Ability names (and stratagem schedule keys) whose rules text the user expanded in the scheduler (collapsed by default).
	private readonly HashSet<string> _openSchedText = new(StringComparer.Ordinal);

	// Schedule keys whose "Show as keyword" text box is open (UI-only; the keyword itself persists on the
	// schedule). A key is also treated as open when it already has a saved keyword.
	private readonly HashSet<string> _keywordEditing = new(StringComparer.Ordinal);

	private void ToggleSchedText(string id)
	{
		if (!_openSchedText.Remove(id))
			_openSchedText.Add(id);
	}

	// Detachment-picker rule/enhancement rows the user expanded to read their text (UI-only, keyed by
	// "rule|detachmentId|name" / "enh|detachmentId|enhancementId"). Lets you preview what a detachment grants
	// before selecting it.
	private readonly HashSet<string> _openDetachInfo = new(StringComparer.Ordinal);

	private void ToggleDetachInfo(string id)
	{
		if (!_openDetachInfo.Remove(id))
			_openDetachInfo.Add(id);
	}

	// Strips the seed's markdown/bullet artefacts so the rules text reads cleanly (mirrors Play Mode).
	private static string CleanText(string text) =>
		text.Replace("^^**", " ", StringComparison.Ordinal)
			.Replace("^^", " ", StringComparison.Ordinal)
			.Replace("**", " ", StringComparison.Ordinal)
			.Replace("■", "•", StringComparison.Ordinal);

	// The datasheet abilities shown in the scheduler: every printed ability except the setup-only "Leader"
	// entry and a model's / unit's own always-on save rule (that is a chip in Play, not a schedulable ability).
	// Each carries the short summary of any effect it can apply (a leader conferral, or a save a conditional
	// ability confers) so it can offer an "Apply to unit" toggle. The unit's assigned Enhancement is appended
	// the same way (keyed by ForEnhancement) so it can be scheduled / read just like a printed ability.
	private List<SchedAbility> ScheduleAbilities(Datasheet sheet, RosterUnit unit)
	{
		var result = new List<SchedAbility>();
		var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
		foreach (var ability in sheet.Abilities)
		{
			if (string.Equals(ability.Name, "Leader", StringComparison.OrdinalIgnoreCase))
				continue;
			if (PhaseClassifier.IsOwnSaveRule(ability))
				continue;
			if (!seen.Add(ability.Name))
				continue;
			result.Add(new SchedAbility(
				AbilityScheduleKeys.ForUnitAbility(sheet.Id, ability.Name),
				ability.Name, ability.Text ?? "", ApplySummary(sheet, ability), sheet.Name));
		}

		// Append the unit's assigned Enhancement so it is schedulable + readable alongside printed abilities.
		if (!string.IsNullOrEmpty(unit.AssignedEnhancementId)
			&& _detachments.Select(d => d.FindEnhancement(unit.AssignedEnhancementId)).FirstOrDefault(e => e is not null) is { } enh
			&& seen.Add(enh.Name))
		{
			var summary = string.IsNullOrWhiteSpace(enh.EffectSummary) ? null : enh.EffectSummary;
			result.Add(new SchedAbility(
				AbilityScheduleKeys.ForEnhancement(enh.Id),
				enh.Name, enh.Text ?? "", summary, sheet.Name));
		}

		return result;
	}

	// All schedulable abilities of a unit's whole attachment group (bodyguard + attached leaders/support),
	// deduped by name (host wins) — the same merge Play Mode does, so the player configures the combined unit
	// from one scheduler. Each ability keeps its own datasheet's schedule key, so Play Mode reads them as-is.
	private List<SchedAbility> CombinedScheduleAbilities(RosterUnit unit)
	{
		var result = new List<SchedAbility>();
		var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
		foreach (var (memberUnit, memberSheet) in GroupMembers(unit))
			foreach (var ability in ScheduleAbilities(memberSheet, memberUnit))
				if (seen.Add(ability.Name))
					result.Add(ability);
		return result;
	}

	// The short summary of what an ability would apply to the unit (drives the "Apply [X]" checkbox), matching
	// the engine: a leader conferral, or a save granted by a conditional (non-own-rule) ability.
	private static string? ApplySummary(Datasheet sheet, Ability ability)
	{
		var conferral = sheet.LeaderConferrals.FirstOrDefault(c =>
			!c.IsEmpty && string.Equals(c.SourceAbility, ability.Name, StringComparison.OrdinalIgnoreCase));
		if (conferral is { IsEmpty: false } && !string.IsNullOrWhiteSpace(conferral.Summary))
			return conferral.Summary;
		if (PhaseClassifier.IsOwnSaveRule(ability))
			return null;
		if (PhaseClassifier.InvulnerableSaveScoped(ability) is { } inv)
			return $"Invulnerable {inv.Value}";
		if (PhaseClassifier.FeelNoPainScoped(ability) is { } fnp)
			return $"Feel No Pain {fnp.Value}";
		return null;
	}

	private bool IsScheduled(string key, BattlePhase phase, BattleTurn turn) =>
		_roster?.FindSchedule(key)?.Covers(phase, turn) ?? false;

	private void ToggleWindow(string key, BattlePhase phase, BattleTurn turn, bool on)
	{
		if (_roster is null)
			return;
		_roster.GetOrCreateSchedule(key).SetWindow(phase, turn, on);
		MarkChanged();
	}

	private bool IsApplied(string key) => _roster?.FindSchedule(key)?.ApplyToUnit ?? false;

	private void SetApplied(string key, bool on)
	{
		if (_roster is null)
			return;
		_roster.GetOrCreateSchedule(key).ApplyToUnit = on;
		MarkChanged();
	}

	private string? KeywordText(string key) => _roster?.FindSchedule(key)?.ManualKeyword;

	// The keyword box is shown when the user opened it, or when a keyword is already saved for this ability.
	private bool ShowKeyword(string key) =>
		_keywordEditing.Contains(key) || !string.IsNullOrWhiteSpace(KeywordText(key));

	private void ToggleKeyword(string key, bool on)
	{
		if (on)
		{
			_keywordEditing.Add(key);
			return;
		}
		_keywordEditing.Remove(key);
		var schedule = _roster?.FindSchedule(key);
		if (schedule is { ManualKeyword: not null })
		{
			schedule.ManualKeyword = null;
			MarkChanged();
		}
	}

	private void SetKeyword(string key, string? text)
	{
		if (_roster is null)
			return;
		_roster.GetOrCreateSchedule(key).ManualKeyword = TrimToWords(text, 3);
		MarkChanged();
	}

	// Keeps a manual keyword short by taking only the first few words; returns null when empty.
	private static string? TrimToWords(string? text, int maxWords)
	{
		if (string.IsNullOrWhiteSpace(text))
			return null;
		var words = text.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
		return words.Length == 0 ? null : string.Join(' ', words.Take(maxWords));
	}

	// A 5×2 grid: a row per phase, a "My turn" / "Opp turn" checkbox each.
	private RenderFragment ScheduleGrid(string key) => __builder =>
	{
		<div class="sched-grid">
			<span class="sg-corner"></span>
			<span class="sg-h">My turn</span>
			<span class="sg-h">Opp turn</span>
			@foreach (var phase in BattlePhases.Ordered)
			{
				<span class="sg-rl">@BattlePhases.Label(phase)</span>
				<label class="sg-cell" title="@($"{BattlePhases.Label(phase)} · my turn")">
					<input type="checkbox" checked="@IsScheduled(key, phase, BattleTurn.Player)"
						   @onchange="e => ToggleWindow(key, phase, BattleTurn.Player, (bool)e.Value!)" />
				</label>
				<label class="sg-cell" title="@($"{BattlePhases.Label(phase)} · opponent's turn")">
					<input type="checkbox" checked="@IsScheduled(key, phase, BattleTurn.Opponent)"
						   @onchange="e => ToggleWindow(key, phase, BattleTurn.Opponent, (bool)e.Value!)" />
				</label>
			}
		</div>
	};

	// The expandable reference shown when a stratagem name is tapped — its clauses formatted like Play Mode,
	// so the rules can be read straight from setup (mirrors the ability expander's reveal interaction).
	private RenderFragment StratRef(string? flavour, string when, string target, string effect, string? restrictions) => __builder =>
	{
		@if (!string.IsNullOrWhiteSpace(flavour))
		{
			<p class="strat-flavour">@CleanText(flavour)</p>
		}
		<dl class="strat-ref">
			@if (!string.IsNullOrWhiteSpace(when))
			{
				<dt>When</dt>
				<dd>@CleanText(when)</dd>
			}
			@if (!string.IsNullOrWhiteSpace(target))
			{
				<dt>Target</dt>
				<dd>@CleanText(target)</dd>
			}
			@if (!string.IsNullOrWhiteSpace(effect))
			{
				<dt>Effect</dt>
				<dd>@CleanText(effect)</dd>
			}
			@if (!string.IsNullOrWhiteSpace(restrictions))
			{
				<dt>Restrictions</dt>
				<dd>@CleanText(restrictions)</dd>
			}
		</dl>
	};

	// ---- View helpers ----
	private bool Over => _roster is not null && _validation.TotalPoints > _roster.PointsLimit;

	private int ErrorCount => _validation.Errors.Count();

	private int EnhancementCount =>
		_roster?.Units.Count(u => !string.IsNullOrEmpty(u.AssignedEnhancementId)) ?? 0;

	private Datasheet? SheetFor(RosterUnit unit) => _catalogue.FindById(unit.DatasheetId);

	private int UnitPoints(RosterUnit unit)
	{
		var rank = _roster is null ? 1 : RosterCalculator.CopyRank(_roster, unit);
		return RosterCalculator.UnitPoints(unit, SheetFor(unit), rank);
	}

	// Price for a specific size option at this unit's copy rank (so escalated copies show their real cost).
	private int OptionPoints(RosterUnit unit, Datasheet sheet, PointsOption option)
	{
		var rank = _roster is null ? 1 : RosterCalculator.CopyRank(_roster, unit);
		if (sheet.EscalationRank > 0 && rank >= sheet.EscalationRank && option.EscalatedPoints is { } escalated)
			return escalated;
		return option.Points;
	}

	private int Remaining(Datasheet sheet)
	{
		var used = _roster?.Units.Count(u => string.Equals(u.DatasheetId, sheet.Id, StringComparison.OrdinalIgnoreCase)) ?? 0;
		return sheet.MaxCopies - used;
	}

	private string? AttachedToName(RosterUnit unit)
	{
		if (string.IsNullOrEmpty(unit.AttachedToRosterUnitId) || _roster is null)
			return null;
		var target = _roster.FindUnit(unit.AttachedToRosterUnitId);
		return target is null ? null : SheetFor(target)?.Name;
	}

	// True when this unit is a leader/support attached to a host that still exists (a dangling attachment is
	// treated as standalone, mirroring Play Mode). Such units are nested under their host in the list.
	private bool IsAttachedLeader(RosterUnit unit) =>
		!string.IsNullOrEmpty(unit.AttachedToRosterUnitId)
		&& _roster is not null
		&& _roster.FindUnit(unit.AttachedToRosterUnitId) is not null;

	// The leaders/support attached to a host bodyguard, in roster order (each with its resolved datasheet).
	private List<(RosterUnit Unit, Datasheet Sheet)> AttachedLeaders(RosterUnit host)
	{
		var result = new List<(RosterUnit, Datasheet)>();
		if (_roster is null)
			return result;
		foreach (var other in _roster.Units)
			if (other.AttachedToRosterUnitId == host.Id && SheetFor(other) is { } sheet)
				result.Add((other, sheet));
		return result;
	}

	// The attachment group a unit belongs to: the host bodyguard first, then its attached leaders — exactly the
	// members Play Mode merges into one card. A standalone unit (or one whose host is gone) returns just itself.
	private List<(RosterUnit Unit, Datasheet Sheet)> GroupMembers(RosterUnit unit)
	{
		var result = new List<(RosterUnit, Datasheet)>();
		if (_roster is null)
			return result;
		var host = unit;
		if (!string.IsNullOrEmpty(unit.AttachedToRosterUnitId)
			&& _roster.FindUnit(unit.AttachedToRosterUnitId) is { } resolvedHost)
			host = resolvedHost;
		if (SheetFor(host) is { } hostSheet)
			result.Add((host, hostSheet));
		result.AddRange(AttachedLeaders(host));
		return result;
	}

	// One unit card (host or, when attached, a nested leader/support). Tapping it opens that unit's config.
	private RenderFragment UnitCard((RosterUnit Unit, Datasheet Sheet) entry, bool attached) => __builder =>
	{
		<button class="unit-card@(attached ? " attached" : "")" type="button" @onclick="() => OpenConfig(entry.Unit)">
			<span class="u-main">
				<span class="u-name">
					@entry.Sheet.Name
					@if (entry.Unit.ModelCount > 1)
					{
						<span class="u-size">×@entry.Unit.ModelCount</span>
					}
				</span>
				<span class="u-chips">
					@if (entry.Unit.IsWarlord)
					{
						<span class="chip warlord">Warlord</span>
					}
					@if (!attached && AttachedToName(entry.Unit) is { } target)
					{
						<span class="chip">→ @target</span>
					}
					@if (EnhancementName(entry.Unit) is { } enh)
					{
						<span class="chip enh">@enh</span>
					}
					@if (entry.Unit.AppliedBindingId is { } binding)
					{
						<span class="chip binding">@binding +@entry.Unit.BindingSurcharge</span>
					}
					@foreach (var wargear in WargearChips(entry.Unit))
					{
						<span class="chip wargear" title="@wargear.Title" @key="wargear.Name">
							<span class="wg-icon" aria-hidden="true">@wargear.Icon</span>
							<span class="wg-name">@wargear.Name</span>
							@if (!string.IsNullOrEmpty(wargear.Detail))
							{
								<span class="wg-detail">@wargear.Detail</span>
							}
						</span>
					}
				</span>
			</span>
			<span class="u-pts">@UnitPoints(entry.Unit) pts</span>
		</button>
	};

	private string? EnhancementName(RosterUnit unit)
	{
		if (string.IsNullOrEmpty(unit.AssignedEnhancementId))
			return null;
		return _detachments
			.Select(d => d.FindEnhancement(unit.AssignedEnhancementId))
			.FirstOrDefault(e => e is not null)?.Name ?? unit.AssignedEnhancementId;
	}

	// A wargear chip for the unit card: the chosen option's name plus a compact weapon summary when the option
	// maps to a weapon (range/attacks for ranged, S/AP/D so the loadout choice reads at a glance). Icon marks
	// ranged (◎) vs melee (⚔) vs non-weapon wargear (◆).
	private readonly record struct WargearChip(string Icon, string Name, string Detail, string Title);

	private IEnumerable<WargearChip> WargearChips(RosterUnit unit)
	{
		if (unit.Wargear.Count == 0 || SheetFor(unit) is not { } sheet)
			yield break;

		foreach (var selection in unit.Wargear)
		{
			var group = sheet.WargearGroups.FirstOrDefault(g => string.Equals(g.Id, selection.GroupId, StringComparison.OrdinalIgnoreCase));
			if (group is null)
				continue;
			foreach (var optionId in selection.OptionIds)
			{
				var option = group.Options.FirstOrDefault(o => string.Equals(o.Id, optionId, StringComparison.OrdinalIgnoreCase));
				if (option is null || string.IsNullOrWhiteSpace(option.Name))
					continue;
				yield return BuildWargearChip(sheet, option.Name);
			}
		}
	}

	private static WargearChip BuildWargearChip(Datasheet sheet, string optionName)
	{
		var weapon = sheet.Weapons.FirstOrDefault(w =>
			string.Equals(w.Name, optionName, StringComparison.OrdinalIgnoreCase)
			|| optionName.Contains(w.Name, StringComparison.OrdinalIgnoreCase)
			|| w.Name.Contains(optionName, StringComparison.OrdinalIgnoreCase));

		if (weapon is null)
			return new WargearChip("◆", optionName, "", optionName);

		var melee = string.Equals(weapon.Type, "Melee", StringComparison.OrdinalIgnoreCase);
		// Ranged: lead with range + attacks; melee: lead with attacks. Both show S / AP / D.
		var lead = melee
			? $"A{weapon.Attacks}"
			: $"{weapon.Range} · A{weapon.Attacks}";
		var detail = $"{lead} · S{weapon.Strength} AP{weapon.ArmourPenetration} D{weapon.Damage}";
		var title = $"{optionName} — {(melee ? "Melee" : "Ranged")}: {detail}"
			+ (weapon.Keywords.Count > 0 ? " [" + string.Join(", ", weapon.Keywords) + "]" : "");
		return new WargearChip(melee ? "⚔" : "◎", optionName, detail, title);
	}

	private IEnumerable<(string Id, string Name)> LeaderTargets(RosterUnit leader)
	{
		var sheet = SheetFor(leader);
		if (sheet is null || _roster is null)
			yield break;

		foreach (var other in _roster.Units)
		{
			if (ReferenceEquals(other, leader))
				continue;
			var otherSheet = SheetFor(other);
			if (otherSheet is not null && sheet.LeaderTargetIds.Contains(otherSheet.Id, StringComparer.OrdinalIgnoreCase))
				yield return (other.Id, otherSheet.Name);
		}
	}

	private IEnumerable<UnitEntry> PickerUnits()
	{
		var q = _pickQuery.Trim();
		return _catalogue.Datasheets
			.Where(d => Matches(d, q))
			.OrderBy(d => RoleRank(d.PrimaryRole))
			.ThenBy(d => d.Name, StringComparer.OrdinalIgnoreCase)
			.Select(d => new UnitEntry(d));
	}

	private IEnumerable<PickerGroup> PickerGroups() =>
		PickerUnits()
			.GroupBy(e => string.IsNullOrWhiteSpace(e.Sheet.PrimaryRole) ? "Other" : e.Sheet.PrimaryRole)
			.OrderBy(g => RoleRank(g.Key))
			.Select(g => new PickerGroup(g.Key, g.ToList()));

	private IEnumerable<UnitGroup> UnitGroups()
	{
		if (_roster is null)
			return Array.Empty<UnitGroup>();

		return _roster.Units
			.Select(u => new UnitEntryResolved(u, SheetFor(u)))
			.Where(e => e.Sheet is not null)
			.Where(e => !IsAttachedLeader(e.Unit)) // attached leaders are nested under their host instead
			.GroupBy(e => string.IsNullOrWhiteSpace(e.Sheet!.PrimaryRole) ? "Other" : e.Sheet!.PrimaryRole)
			.OrderBy(g => RoleRank(g.Key))
			.ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
			.Select(g => new UnitGroup(g.Key, g.Select(e => (e.Unit, e.Sheet!)).ToList()));
	}

	private IEnumerable<ValidationMessage> OrderedMessages() =>
		_validation.Messages
			.OrderByDescending(m => m.Severity)
			.ThenBy(m => m.RuleId, StringComparer.Ordinal);

	private static bool Matches(Datasheet d, string q)
	{
		if (q.Length == 0)
			return true;
		return d.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
			|| d.Keywords.Any(k => k.Contains(q, StringComparison.OrdinalIgnoreCase));
	}

	private static int RoleRank(string role)
	{
		var i = Array.FindIndex(RoleOrder, r => string.Equals(r, role, StringComparison.OrdinalIgnoreCase));
		return i < 0 ? RoleOrder.Length : i;
	}

	private static string PointsLabel(Datasheet d) =>
		d.PointsOptions.Count > 1
			? $"from {d.PointsOptions.Min(p => p.Points)} pts"
			: $"{d.Points} pts";

	private static string Sev(ValidationSeverity s) => s switch
	{
		ValidationSeverity.Error => "error",
		ValidationSeverity.Warning => "warn",
		_ => "info",
	};

	private sealed record UnitEntry(Datasheet Sheet);
	private sealed record PickerGroup(string Role, IReadOnlyList<UnitEntry> Units);
	private sealed record UnitEntryResolved(RosterUnit Unit, Datasheet? Sheet);
	private sealed record UnitGroup(string Role, IReadOnlyList<(RosterUnit Unit, Datasheet Sheet)> Units);

	public async ValueTask DisposeAsync()
	{
		Nav.LocationChanged -= OnLocationChanged;
		_autoSaveCts?.Cancel();
		_autoSaveCts?.Dispose();

		// Best-effort final flush + JS listener teardown (skipped if the circuit is already gone).
		if (_dirty)
		{
			try { await SaveAsync(); } catch { }
		}
		if (_flushHookInstalled)
		{
			try { await JS.InvokeVoidAsync("tombworld.cancelFlushOnHide"); }
			catch (JSException) { }
			catch (InvalidOperationException) { }
		}
		_selfRef?.Dispose();
	}
}
