@page "/armies"
@using Warhammer40k.Core
@inject IApiClient Api

<PageTitle>TombForge — Armies</PageTitle>

<div class="armies">
	<header class="head">
		<div>
			<p class="eyebrow">Your roster</p>
			<h1>My armies</h1>
		</div>
		@if (_authenticated && !_loading)
		{
			<span class="count">@_armies.Count @(_armies.Count == 1 ? "army" : "armies")</span>
		}
	</header>

	@if (_loading)
	{
		<div class="card pad">
			<p class="status"><span class="pulse" aria-hidden="true"></span> Loading&hellip;</p>
		</div>
	}
	else if (!_authenticated)
	{
		<div class="card pad signin">
			<p class="status">Sign in to forge and command your armies.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	}
	else
	{
		<div class="card form-card" id="army-form">
			<div class="form-head">
				<span class="form-mark" aria-hidden="true"></span>
				<h2>@(_editing.Id.Length == 0 ? "Forge new army" : "Edit army")</h2>
			</div>
			<EditForm Model="_editing" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<div class="grid">
					<label class="field">
						<span>Name</span>
						<InputText class="input" @bind-Value="_editing.Name" placeholder="e.g. Sautekh Dynasty" />
					</label>
					<label class="field">
						<span>Faction</span>
						<InputText class="input" @bind-Value="_editing.Faction" placeholder="e.g. Necrons" />
					</label>
					<label class="field points">
						<span>Points</span>
						<InputNumber class="input" @bind-Value="_editing.Points" />
					</label>
				</div>
				<ValidationSummary />
				<div class="actions">
					<button class="btn primary" type="submit" disabled="@_saving">
						@(_saving ? "Saving…" : (_editing.Id.Length == 0 ? "Forge army" : "Save changes"))
					</button>
					@if (_editing.Id.Length > 0)
					{
						<button class="btn ghost" type="button" @onclick="StartNew">Cancel</button>
					}
				</div>
			</EditForm>
			@if (_error is not null)
			{
				<p class="error">@_error</p>
			}
		</div>

		@if (_armies.Count == 0)
		{
			<div class="card empty">
				<span class="empty-mark" aria-hidden="true"></span>
				<p>No armies yet &mdash; forge your first one above.</p>
			</div>
		}
		else
		{
			<ul class="list">
				@foreach (var army in _armies)
				{
					<li class="army-card" @key="army.Id">
						<span class="army-glyph" aria-hidden="true"></span>
						<div class="info">
							<span class="name">@army.Name</span>
							<span class="meta">@army.Faction &middot; <strong>@army.Points</strong> pts</span>
						</div>
						<div class="row-actions">
							<button class="btn small ghost" @onclick="() => Edit(army)">Edit</button>
							<button class="btn small danger" @onclick="() => DeleteAsync(army)">Delete</button>
						</div>
					</li>
				}
			</ul>
		}

		<a class="fab" href="#army-form" aria-label="Jump to new army form">
			<span aria-hidden="true">+</span>
		</a>
	}
</div>

@code {
	private readonly List<Army> _armies = new();
	private Army _editing = new();
	private bool _loading = true;
	private bool _saving;
	private bool _authenticated;
	private string? _error;

	protected override async Task OnInitializedAsync()
	{
		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
			await ReloadAsync();
		_loading = false;
	}

	private async Task ReloadAsync()
	{
		var armies = await Api.GetArmiesAsync();
		_armies.Clear();
		_armies.AddRange(armies);
	}

	private void StartNew()
	{
		_editing = new Army();
		_error = null;
	}

	private void Edit(Army army)
	{
		// Edit a detached copy so cancelling never mutates the list item in place.
		_editing = new Army
		{
			Id = army.Id,
			Name = army.Name,
			Faction = army.Faction,
			Points = army.Points,
		};
		_error = null;
	}

	private async Task SaveAsync()
	{
		_saving = true;
		_error = null;
		try
		{
			await Api.SaveArmyAsync(_editing);
			StartNew();
			await ReloadAsync();
		}
		catch (Exception)
		{
			_error = "Could not save the army. Please try again.";
		}
		finally
		{
			_saving = false;
		}
	}

	private async Task DeleteAsync(Army army)
	{
		_error = null;
		try
		{
			await Api.DeleteArmyAsync(army.Id);
			if (_editing.Id == army.Id)
				StartNew();
			await ReloadAsync();
		}
		catch (Exception)
		{
			_error = "Could not delete the army. Please try again.";
		}
	}
}
