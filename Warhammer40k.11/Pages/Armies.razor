@page "/armies"
@using Warhammer40k.Core
@inject IApiClient Api

<PageTitle>TombForge — Armies</PageTitle>

<div class="armies">
	<header class="head">
		<h1>My armies</h1>
		<a class="link" href="/">&larr; Home</a>
	</header>

	@if (_loading)
	{
		<p class="status">Loading&hellip;</p>
	}
	else if (!_authenticated)
	{
		<div class="card">
			<p class="status">Sign in to create and manage your armies.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	}
	else
	{
		<div class="card form-card">
			<h2>@(_editing.Id.Length == 0 ? "New army" : "Edit army")</h2>
			<EditForm Model="_editing" OnValidSubmit="SaveAsync">
				<DataAnnotationsValidator />
				<label class="field">
					<span>Name</span>
					<InputText class="input" @bind-Value="_editing.Name" placeholder="e.g. Sautekh Dynasty" />
				</label>
				<label class="field">
					<span>Faction</span>
					<InputText class="input" @bind-Value="_editing.Faction" placeholder="e.g. Necrons" />
				</label>
				<label class="field">
					<span>Points</span>
					<InputNumber class="input" @bind-Value="_editing.Points" />
				</label>
				<ValidationSummary />
				<div class="actions">
					<button class="btn primary" type="submit" disabled="@_saving">
						@(_saving ? "Saving…" : "Save")
					</button>
					@if (_editing.Id.Length > 0)
					{
						<button class="btn" type="button" @onclick="StartNew">Cancel</button>
					}
				</div>
			</EditForm>
			@if (_error is not null)
			{
				<p class="error">@_error</p>
			}
		</div>

		@if (_armies.Count == 0)
		{
			<p class="status muted">No armies yet &mdash; create your first one above.</p>
		}
		else
		{
			<ul class="list">
				@foreach (var army in _armies)
				{
					<li class="row" @key="army.Id">
						<div class="info">
							<span class="name">@army.Name</span>
							<span class="meta">@army.Faction &middot; @army.Points pts</span>
						</div>
						<div class="row-actions">
							<button class="btn small" @onclick="() => Edit(army)">Edit</button>
							<button class="btn small danger" @onclick="() => DeleteAsync(army)">Delete</button>
						</div>
					</li>
				}
			</ul>
		}
	}
</div>

@code {
	private readonly List<Army> _armies = new();
	private Army _editing = new();
	private bool _loading = true;
	private bool _saving;
	private bool _authenticated;
	private string? _error;

	protected override async Task OnInitializedAsync()
	{
		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
			await ReloadAsync();
		_loading = false;
	}

	private async Task ReloadAsync()
	{
		var armies = await Api.GetArmiesAsync();
		_armies.Clear();
		_armies.AddRange(armies);
	}

	private void StartNew()
	{
		_editing = new Army();
		_error = null;
	}

	private void Edit(Army army)
	{
		// Edit a detached copy so cancelling never mutates the list item in place.
		_editing = new Army
		{
			Id = army.Id,
			Name = army.Name,
			Faction = army.Faction,
			Points = army.Points,
		};
		_error = null;
	}

	private async Task SaveAsync()
	{
		_saving = true;
		_error = null;
		try
		{
			await Api.SaveArmyAsync(_editing);
			StartNew();
			await ReloadAsync();
		}
		catch (Exception)
		{
			_error = "Could not save the army. Please try again.";
		}
		finally
		{
			_saving = false;
		}
	}

	private async Task DeleteAsync(Army army)
	{
		_error = null;
		try
		{
			await Api.DeleteArmyAsync(army.Id);
			if (_editing.Id == army.Id)
				StartNew();
			await ReloadAsync();
		}
		catch (Exception)
		{
			_error = "Could not delete the army. Please try again.";
		}
	}
}
