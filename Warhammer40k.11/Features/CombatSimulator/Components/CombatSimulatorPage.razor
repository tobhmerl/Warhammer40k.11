@page "/combat-sim"
@using Microsoft.AspNetCore.Components.Forms
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Play
@using Warhammer40k.Core.Rosters
@using Warhammer40k._11.Features.CombatSimulator.Adapters
@using Warhammer40k._11.Features.CombatSimulator.Domain
@using Warhammer40k._11.Features.CombatSimulator.Engine
@using Warhammer40k._11.Features.CombatSimulator.Import
@inject IApiClient Api
@inject MonteCarloRunner Runner
@inject ImportedUnitStore Imported
@inject CombatSimStateStore Store
@implements IAsyncDisposable

@* Combat Simulator (removable feature — see Features/CombatSimulator/DELETE.md).
   Monte-Carlo attack/save simulator: My army (native Necrons) vs Opponent (imported). *@
<div class="csim">
	<h1 class="csim-title">Combat Simulator</h1>

	@if (_loading)
	{
		<p class="csim-note">Loading your roster…</p>
	}
	else
	{
		@if (_rosters.Count > 0)
		{
			<div class="csim-army" role="group" aria-label="Choose your army">
				<label class="csim-army-label" for="csim-army-select">My army</label>
				<select id="csim-army-select" class="csim-select" value="@_selectedRosterId" @onchange="OnRosterChanged">
					@foreach (var roster in _rosters)
					{
						<option value="@roster.Id">@roster.Name</option>
					}
				</select>
			</div>
		}

		<div class="csim-direction" role="group" aria-label="Who is attacking">
			<button type="button" class="csim-dir @(_myArmyAttacks ? "on" : "")" @onclick="() => SetDirection(true)">My attacks ▸</button>
			<button type="button" class="csim-dir @(!_myArmyAttacks ? "on" : "")" @onclick="() => SetDirection(false)">Opp attacks ◂</button>
		</div>

		<div class="csim-direction" role="group" aria-label="Weapon type">
			<button type="button" class="csim-dir @(!_weaponSelection.ShowMelee ? "on" : "")" @onclick="() => SetWeaponClass(false)">Ranged</button>
			<button type="button" class="csim-dir @(_weaponSelection.ShowMelee ? "on" : "")" @onclick="() => SetWeaponClass(true)">Melee</button>
		</div>

		<section class="csim-col">
			<div class="csim-col-head">
				<h2 class="csim-h2">1 · Attacker <span class="csim-side">@(_myArmyAttacks ? "my army" : "opponent")</span></h2>
			</div>
			<UnitPicker Units="AttackerPool" Selected="_attacker" SelectedChanged="OnAttackerChanged" />
			@if (_attacker is not null)
			{
				<WeaponSelector Unit="_attacker" Selection="_weaponSelection" />
			}
			else if (AttackerPool.Count == 0)
			{
				<p class="csim-note">@EmptyPoolHint(attacker: true)</p>
			}
		</section>

		<section class="csim-col">
			<div class="csim-col-head">
				<h2 class="csim-h2">2 · Target <span class="csim-side">@(_myArmyAttacks ? "opponent" : "my army")</span></h2>
				@if (TargetIsOpponent)
				{
					<button type="button" class="csim-btn tiny" @onclick="OpenImport">Import opponent ↑</button>
				}
			</div>
			<UnitPicker Units="TargetPool" Selected="_target" SelectedChanged="OnTargetChanged" />
			@if (_target is not null)
			{
				<p class="csim-meta">@_target.TotalModels model(s) · T@(TargetToughness) · Sv @(TargetSave)+@(TargetInvulnText)</p>
			}
			else if (TargetPool.Count == 0)
			{
				<p class="csim-note">@EmptyPoolHint(attacker: false)</p>
			}
		</section>

		<section class="csim-col">
			<div class="csim-col-head">
				<h2 class="csim-h2">3 · Attacker modifiers</h2>
				<button type="button" class="csim-btn tiny" @onclick="ResetAttackerMods">Reset</button>
			</div>
			<ModifierPanel Attacker="_attackerMods" AttackerChanged="OnAttackerModsChanged" />
		</section>

		<section class="csim-col">
			<div class="csim-col-head">
				<h2 class="csim-h2">4 · Defender modifiers</h2>
				<button type="button" class="csim-btn tiny" @onclick="ResetDefenderMods">Reset</button>
			</div>
			<ModifierPanel Defender="_defenderMods" DefenderChanged="OnDefenderModsChanged" Abilities="TargetAbilities" />
		</section>

		<section class="csim-run">
			<label class="csim-field">Iterations
				<input type="number" min="100" max="100000" step="1000" @bind="_iterations" />
			</label>
			<label class="csim-field">Seed
				<input type="number" @bind="_seed" placeholder="random" />
			</label>
			<button class="csim-btn primary" type="button" @onclick="RunAsync" disabled="@(_running || !CanRun)">
				@(_running ? $"Running… {_progress:P0}" : "Run simulation")
			</button>
		</section>

		@if (_result is not null)
		{
			<ResultsView Result="_result" TargetModels="_target?.TotalModels ?? 0" />
		}
	}

	@if (_importOpen)
	{
		<div class="csim-modal-backdrop" @onclick="CloseImport">
			<div class="csim-modal" @onclick:stopPropagation="true">
				<div class="csim-modal-head">
					<h2 class="csim-h2">Import opponent army</h2>
					<button type="button" class="csim-modal-x" @onclick="CloseImport" aria-label="Close">×</button>
				</div>
				<p class="csim-note">New Recruit / BattleScribe 11th-edition JSON. Upload a file or paste the export.</p>

				<label class="csim-file">
					<InputFile OnChange="OnFileSelected" accept=".json,application/json" />
				</label>

				<textarea class="csim-paste" @bind="_importText" rows="6" placeholder="…or paste the JSON export here"></textarea>

				<div class="csim-import-row">
					<button class="csim-btn primary" type="button" @onclick="ImportJson" disabled="@string.IsNullOrWhiteSpace(_importText)">Import</button>
					<button class="csim-btn" type="button" @onclick="CloseImport">Cancel</button>
				</div>
				@if (_importWarnings.Count > 0)
				{
					<p class="csim-warn">@string.Join(" ", _importWarnings)</p>
				}
				@if (_importedCount > 0)
				{
					<p class="csim-ok">Imported @_importedCount unit(s).</p>
				}
			</div>
		</div>
	}
</div>

@code {
	private bool _loading = true;
	private bool _running;
	private double _progress;

	// My army = native Necrons; Opponent = imported. The direction toggle swaps which is attacker/target.
	private bool _myArmyAttacks = true;
	private bool _importOpen;

	private readonly List<CombatUnit> _native = [];
	private CombatUnit? _attacker;
	private CombatUnit? _target;
	private readonly WeaponSelectionState _weaponSelection = new();

	// The user's saved rosters (id + name), and the one whose units populate the "my army" pool. Selecting an
	// army means only that roster's units appear — mixing every roster's units made the same unit look duplicated.
	private readonly List<Roster> _rosters = [];
	private string? _selectedRosterId;
	private CatalogueData _catalogue = new();

	private AttackerModifiers _attackerMods = new();
	private DefenderModifiers _defenderMods = new();

	private string _importText = "";
	private readonly List<string> _importWarnings = [];
	private int _importedCount;

	private int _iterations = 10_000;
	private int? _seed;

	private SimulationResult? _result;

	private IReadOnlyList<CombatUnit> MyArmy => _native;
	private IReadOnlyList<CombatUnit> Opponent => Imported.Units;

	// The attacker pool is one army, the target pool the other — never both mixed.
	private IReadOnlyList<CombatUnit> AttackerPool => _myArmyAttacks ? MyArmy : Opponent;
	private IReadOnlyList<CombatUnit> TargetPool => _myArmyAttacks ? Opponent : MyArmy;
	private bool TargetIsOpponent => _myArmyAttacks;

	private int TargetToughness => _target?.BodyguardToughness ?? _target?.ModelGroups.FirstOrDefault()?.Profile.Toughness ?? 0;
	private int TargetSave => _target?.ModelGroups.FirstOrDefault()?.Profile.Save ?? 7;
	private string TargetInvulnText
	{
		get
		{
			var inv = _target?.ModelGroups.FirstOrDefault()?.Profile.InvulnSave;
			return inv is null ? "" : $" / {inv}++";
		}
	}

	private IReadOnlyList<UnitAbility> TargetAbilities => _target?.UnitAbilities ?? [];

	private bool CanRun => _attacker is not null && _target is not null && _weaponSelection.Any;

	private string EmptyPoolHint(bool attacker)
	{
		var isOpponentPool = attacker ? !_myArmyAttacks : _myArmyAttacks;
		if (isOpponentPool)
			return "No opponent units yet — import an enemy army (button above the Target box).";
		return _rosters.Count == 0
			? "No units in your army — add a roster in Rosters first."
			: "This army has no units — pick another army above or add units in Rosters.";
	}

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var rosters = await Api.GetRostersAsync();
			_catalogue = await Api.GetCatalogueAsync();
			_rosters.AddRange(rosters);
		}
		catch
		{
			// Offline / not signed in: the importer still works; native list stays empty.
		}

		await RestoreAsync();
		_loading = false;
	}

	// Rebuilds the "my army" unit pool from the selected roster only. Clears it when no roster is chosen.
	private void BuildNativeUnits()
	{
		_native.Clear();
		var roster = _rosters.FirstOrDefault(r => r.Id == _selectedRosterId);
		if (roster is null)
			return;
		try
		{
			var battle = BattleRoster.Build(roster, _catalogue);
			_native.AddRange(NativeNecronSource.FromBattleRoster(battle));
		}
		catch
		{
			// A roster that can't be built (missing datasheet, etc.) leaves the pool empty.
		}
	}

	// Rebuilds the whole page state from the persisted snapshot (imported army, selections, modifiers).
	private async Task RestoreAsync()
	{
		var snap = await Store.LoadAsync();

		// Pick the saved roster if it still exists, otherwise default to the first available one.
		_selectedRosterId = snap?.RosterId is { } id && _rosters.Any(r => r.Id == id)
			? id
			: _rosters.FirstOrDefault()?.Id;
		BuildNativeUnits();

		if (snap is null)
			return;

		// Re-import the saved opponent army (only if the store is empty, e.g. after a reload).
		if (Imported.Units.Count == 0)
			foreach (var json in snap.ImportedJson)
			{
				var result = NewRecruitImporter.Import(json);
				Imported.Add(json, result.Units);
			}

		_myArmyAttacks = snap.MyArmyAttacks;
		_attackerMods = snap.Attacker;
		_defenderMods = snap.Defender;
		_iterations = snap.Iterations;
		_seed = snap.Seed;

		_attacker = AttackerPool.FirstOrDefault(u => u.Name == snap.AttackerName);
		_target = TargetPool.FirstOrDefault(u => u.Name == snap.TargetName);

		_weaponSelection.Reset(_attacker);
		_weaponSelection.SetClass(snap.ShowMelee);
		_weaponSelection.Restore(snap.WeaponPicks.Select(p => (p.Name, p.Selected, p.Models, p.ModeIndex)));
	}

	// Captures the current page state and persists it (best-effort).
	private Task SaveAsync()
	{
		var snap = new CombatSimSnapshot
		{
			MyArmyAttacks = _myArmyAttacks,
			ShowMelee = _weaponSelection.ShowMelee,
			RosterId = _selectedRosterId,
			ImportedJson = [.. Imported.RawJson],
			AttackerName = _attacker?.Name,
			TargetName = _target?.Name,
			WeaponPicks = _weaponSelection.Snapshot()
				.Select(p => new WeaponPick { Name = p.Name, Selected = p.Selected, Models = p.Models, ModeIndex = p.ModeIndex })
				.ToList(),
			Attacker = _attackerMods,
			Defender = _defenderMods,
			Iterations = _iterations,
			Seed = _seed,
		};
		return Store.SaveAsync(snap);
	}

	private void SetDirection(bool myArmyAttacks)
	{
		if (_myArmyAttacks == myArmyAttacks)
			return;
		_myArmyAttacks = myArmyAttacks;
		// Pools swap — clear the now-invalid selections.
		_attacker = null;
		_target = null;
		_weaponSelection.Reset(null);
		_result = null;
		_ = SaveAsync();
	}

	// Switching army rebuilds the "my army" pool from that roster only, and clears any selection that belonged
	// to the previous army (attacker or target, whichever side is currently "my army").
	private void OnRosterChanged(ChangeEventArgs e)
	{
		_selectedRosterId = e.Value?.ToString() is { Length: > 0 } id ? id : null;
		BuildNativeUnits();

		if (_myArmyAttacks)
			_attacker = null;
		else
			_target = null;
		_weaponSelection.Reset(_myArmyAttacks ? _attacker : null);
		_result = null;
		_ = SaveAsync();
	}

	private void OnAttackerChanged(CombatUnit? unit)
	{
		_attacker = unit;
		_weaponSelection.Reset(unit);
		_ = SaveAsync();
	}

	private void SetWeaponClass(bool melee)
	{
		_weaponSelection.SetClass(melee);
		_ = SaveAsync();
	}

	private void OnAttackerModsChanged(AttackerModifiers m)
	{
		_attackerMods = m;
		_ = SaveAsync();
	}

	private void OnDefenderModsChanged(DefenderModifiers m)
	{
		_defenderMods = m;
		_ = SaveAsync();
	}

	private void ResetAttackerMods()
	{
		_attackerMods = new AttackerModifiers();
		_ = SaveAsync();
	}

	private void ResetDefenderMods()
	{
		// Keep the target's parsed invuln/FNP prefill; reset everything else to defaults.
		var profile = _target?.ModelGroups.FirstOrDefault()?.Profile;
		_defenderMods = new DefenderModifiers
		{
			InvulnSaveOverride = profile?.InvulnSave,
			FeelNoPainOverride = profile?.FeelNoPain,
		};
		_ = SaveAsync();
	}

	private void OnTargetChanged(CombatUnit? unit)
	{
		_target = unit;
		// Pre-fill defender modifiers from the unit's parsed defensive abilities (user can edit).
		var profile = unit?.ModelGroups.FirstOrDefault()?.Profile;
		_defenderMods = new DefenderModifiers
		{
			InvulnSaveOverride = profile?.InvulnSave,
			FeelNoPainOverride = profile?.FeelNoPain,
		};
		_ = SaveAsync();
	}

	private void OpenImport()
	{
		_importOpen = true;
		_importedCount = 0;
		_importWarnings.Clear();
	}

	private void CloseImport() => _importOpen = false;

	private async Task OnFileSelected(InputFileChangeEventArgs e)
	{
		try
		{
			using var stream = e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024);
			using var reader = new StreamReader(stream);
			_importText = await reader.ReadToEndAsync();
		}
		catch (Exception ex)
		{
			_importWarnings.Clear();
			_importWarnings.Add($"Could not read file: {ex.Message}");
		}
	}

	private void ImportJson()
	{
		_importWarnings.Clear();
		var json = _importText;
		var result = NewRecruitImporter.Import(json);
		Imported.Add(json, result.Units);
		_importedCount = result.Units.Count;
		_importWarnings.AddRange(result.Warnings);
		_importText = "";
		if (_importedCount > 0 && result.Warnings.Count == 0)
			_importOpen = false;
		_ = SaveAsync();
	}

	private async Task RunAsync()
	{
		if (_attacker is null || _target is null)
			return;

		_running = true;
		_progress = 0;
		_result = null;
		StateHasChanged();

		var config = new SimulationConfig
		{
			Weapons = _weaponSelection.ResolvedWeapons(),
			Target = _target,
			Attacker = _attackerMods,
			Defender = _defenderMods,
			TargetKeywords = TargetKeywordsFor(_target),
			Iterations = _iterations,
			Seed = _seed,
		};

		var progress = new Progress<double>(p =>
		{
			_progress = p;
			InvokeAsync(StateHasChanged);
		});

		_result = await Task.Run(() => Runner.Run(config, progress));
		_running = false;
		_progress = 1;
	}

	private static List<string> TargetKeywordsFor(CombatUnit unit)
	{
		// Use the model-group names + faction as keyword hints for Anti-X matching.
		var keywords = new List<string> { unit.Faction };
		foreach (var group in unit.ModelGroups)
			keywords.Add(group.Profile.Name);
		return keywords;
	}

	// Save once more when leaving the page (covers numeric inputs bound with @bind that don't call a handler).
	public async ValueTask DisposeAsync() => await SaveAsync();
}
