@using Warhammer40k._11.Features.CombatSimulator.Domain

@* Combat Simulator weapon selector (removable feature). Shows only weapons of the chosen class (ranged/melee). *@
<div class="csim-weapons">
	@foreach (var (index, weapon) in Selection.VisibleWeapons)
	{
		var i = index;
		<div class="csim-weapon @(Selection.IsSelected(i) ? "on" : "")">
			<label class="csim-weapon-head">
				<input type="checkbox" checked="@Selection.IsSelected(i)"
					   @onchange="e => Selection.SetSelected(i, (bool)e.Value!)" />
				<span class="csim-weapon-name">@DisplayName(weapon)</span>
				<span class="csim-weapon-stats">@StatLine(weapon)</span>
			</label>
			<div class="csim-weapon-row">
				<label class="csim-field small">models
					<input type="number" min="0" value="@Selection.Models(i)"
						   @onchange="e => Selection.SetModels(i, ParseInt(e.Value))" />
				</label>
				@if (weapon.HasFiringModes)
				{
					<label class="csim-field small">mode
						<select @onchange="e => Selection.SetMode(i, ParseInt(e.Value))">
							@for (var m = 0; m < weapon.FiringModes.Count; m++)
							{
								<option value="@m" selected="@(Selection.ModeIndex(i) == m)">@ModeName(weapon.FiringModes[m].Name)</option>
							}
						</select>
					</label>
				}
				@if (weapon.Abilities.Count > 0)
				{
					<span class="csim-weapon-kw">@string.Join(", ", weapon.Abilities.Select(a => a.Label))</span>
				}
			</div>
		</div>
	}
	@if (Selection.VisibleWeapons.Count == 0)
	{
		<p class="csim-note">No @(Selection.ShowMelee ? "melee" : "ranged") weapons on this unit.</p>
	}
</div>

@code {
	[Parameter] public CombatUnit Unit { get; set; } = new();
	[Parameter] public WeaponSelectionState Selection { get; set; } = new();

	private static string DisplayName(CombatWeapon w) => w.HasFiringModes ? w.Name.Split('-')[0].Trim() : w.Name;

	private static string ModeName(string full) => full.Contains('-') ? full[(full.IndexOf('-') + 1)..].Trim() : full;

	private static string StatLine(CombatWeapon w) =>
		$"A {w.Attacks} · {(w.IsMelee ? "WS" : "BS")} {w.Skill}+ · S {w.Strength} · AP {w.ArmourPenetration} · D {w.Damage}";

	private static int ParseInt(object? value) => int.TryParse(value?.ToString(), out var n) ? n : 0;
}
