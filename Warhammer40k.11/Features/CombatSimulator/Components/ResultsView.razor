@using Warhammer40k._11.Features.CombatSimulator.Domain
@using System.Globalization

@* Combat Simulator results (removable feature). Plain-language summary: the numbers that matter at a glance. *@
<div class="csim-results">
	<div class="csim-headline">
		<div class="csim-big">
			<span class="csim-big-num">@F1(Result.ModelsSlain.Mean)</span>
			<span class="csim-big-label">models destroyed</span>
			<span class="csim-big-sub">of @TargetModels · @Range(Result.ModelsSlain)</span>
		</div>
		<div class="csim-big">
			<span class="csim-big-num">@F1(Result.EffectiveDamage.Mean)</span>
			<span class="csim-big-label">wounds dealt</span>
			<span class="csim-big-sub">@Range(Result.EffectiveDamage)</span>
		</div>
	</div>

	<ul class="csim-steps">
		<li class="csim-step"><span class="csim-step-label">Hits landed</span><span class="csim-step-num">@F1(Result.Funnel.Hits)</span></li>
		<li class="csim-step"><span class="csim-step-label">Wounds caused</span><span class="csim-step-num">@F1(WoundsCaused)</span></li>
		<li class="csim-step"><span class="csim-step-label">Saves failed</span><span class="csim-step-num">@F1(FailedSaves)</span></li>
		<li class="csim-step"><span class="csim-step-label">Wounds dealt</span><span class="csim-step-num">@F1(Result.Funnel.EffectiveDamage)</span></li>
		<li class="csim-step strong"><span class="csim-step-label">Models destroyed</span><span class="csim-step-num">@F1(Result.Funnel.ModelsSlain)</span></li>
	</ul>

	<p class="csim-wipe">
		Chance to wipe the unit: <strong>@P0(Result.ProbabilityWiped)</strong>
		<span class="csim-runs">· @Result.Iterations.ToString("N0") simulated games</span>
	</p>

	@if (!string.IsNullOrEmpty(Result.ReanimationPreview))
	{
		<p class="csim-reanim">@Result.ReanimationPreview</p>
	}
</div>

@code {
	[Parameter] public SimulationResult Result { get; set; } = new();
	[Parameter] public int TargetModels { get; set; }

	// "Wounds caused" = successful wound rolls + lethal auto-wounds (everything that got past the to-wound step).
	private double WoundsCaused => Result.Funnel.Wounds + Result.Funnel.LethalAutoWounds;
	private double FailedSaves => Result.Funnel.FailedArmourSaves + Result.Funnel.FailedInvulnSaves;

	private static string F1(double v) => v.ToString("0.0", CultureInfo.InvariantCulture);
	private static string P0(double v) => v.ToString("P0", CultureInfo.InvariantCulture);

	private static string Range(Distribution d) => $"usually {d.P25}–{d.P75}, up to {d.Max}";
}
