@page "/tactical-map"
@using Microsoft.AspNetCore.Components.Forms
@using Warhammer40k.Core
@using Warhammer40k.Core.Catalogue
@using Warhammer40k.Core.Rosters
@using Warhammer40k.Core.Tactical
@using Warhammer40k._11.Features.CombatSimulator.Import
@inject IApiClient Api

@* Tactical Map — plan a deployment by dragging per-model tokens on a battlefield.
   Part of the removable Tactical Map feature — see ../DELETE.md. *@

<PageTitle>TombWorld — Tactical Map</PageTitle>

<div class="tmap">
	@if (_loading)
	{
		<div class="card pad"><p class="status"><span class="pulse" aria-hidden="true"></span> Loading&hellip;</p></div>
	}
	else if (!_authenticated)
	{
		<div class="card pad">
			<p class="status">Sign in to plan tactical setups with your rosters.</p>
			<a class="btn primary" href="/.auth/login/github">Sign in with GitHub</a>
		</div>
	}
	else if (_plan is null)
	{
		<div class="tmap-head">
			<h1>Tactical Map</h1>
			<p class="sub">Plan a deployment on <strong>@_map.Name</strong> by dragging your models around the board.</p>
		</div>

		<div class="card pad new-plan">
			<h2>New plan</h2>
			@if (_rosters.Count == 0)
			{
				<p class="status">You have no rosters yet. Build one first, then come back to plan its deployment.</p>
			}
			else
			{
				<label class="fld">
					<span>Roster</span>
					<select @bind="_newRosterId">
						<option value="">Choose a roster&hellip;</option>
						@foreach (var r in _rosters)
						{
							<option value="@r.Id">@r.Name (@r.PointsLimit pts)</option>
						}
					</select>
				</label>
				<button class="btn primary" type="button" disabled="@(string.IsNullOrEmpty(_newRosterId) || _busy)" @onclick="CreatePlanAsync">Create plan</button>
			}
			<div class="new-import">
				<span class="ni-or">or</span>
				<label class="btn ghost file" title="Create a plan from a New Recruit JSON export">
					Import from New Recruit
					<InputFile class="hidden-file" accept=".json" OnChange="CreateFromImportAsync" />
				</label>
			</div>
		</div>

		@if (_plans.Count > 0)
		{
			<div class="card pad">
				<h2>Saved plans</h2>
				<ul class="plan-list">
					@foreach (var p in _plans)
					{
						<li>
							<button class="plan-open" type="button" @onclick="() => OpenPlanAsync(p.Id)">
								<span class="pl-name">@p.Name</span>
								<span class="pl-meta">@p.Tokens.Count tokens · @TacticalMaps.Resolve(p.MapId).Name</span>
							</button>
							<button class="btn small ghost reset" type="button" @onclick="() => DeletePlanAsync(p.Id)" title="Delete plan">Delete</button>
						</li>
					}
				</ul>
			</div>
		}
	}
	else
	{
		<div class="tmap-bar">
			<button class="btn small ghost" type="button" @onclick="ClosePlan">&larr; Plans</button>
			<input class="plan-name" @bind="_plan.Name" @bind:event="oninput" @onchange="SavePlanAsync" aria-label="Plan name" />
			<span class="tmap-legend">
				<span class="lg player">You</span>
				<span class="lg opponent">Opponent</span>
			</span>
			<button class="btn small ghost" type="button" @onclick="AddOpponentMarker">+ Opponent marker</button>
			<label class="btn small ghost file" title="Add your units from a New Recruit JSON export">
				Import You
				<InputFile class="hidden-file" accept=".json" OnChange="e => ImportAsync(e, MapSide.Player)" />
			</label>
			<label class="btn small ghost file" title="Add the opponent's units from a New Recruit JSON export">
				Import Opp
				<InputFile class="hidden-file" accept=".json" OnChange="e => ImportAsync(e, MapSide.Opponent)" />
			</label>
			<button class="btn small ghost @(_measureMode ? "on" : "")" type="button" @onclick="ToggleMeasure" title="Measure distances in inches">@(_measureMode ? "Measuring…" : "Measure")</button>
			<button class="btn small primary" type="button" disabled="@_busy" @onclick="SavePlanAsync">@(_busy ? "Saving…" : "Save")</button>
		</div>

		<div class="tmap-tools">
			<span class="tool-group" role="group" aria-label="Drag mode">
				<button class="btn small ghost @(_unitDrag ? "on" : "")" type="button" @onclick="() => _unitDrag = true" title="Dragging any model moves its whole unit together (hold Shift for a single model)">Move unit</button>
				<button class="btn small ghost @(!_unitDrag ? "on" : "")" type="button" @onclick="() => _unitDrag = false" title="Drag single models to fine-tune a formation (hold Shift to move the whole unit)">Move model</button>
			</span>
			<span class="tool-label">Rings for selected unit:</span>
			<span class="tool-group" role="group" aria-label="Range rings">
				<button class="btn small ghost @(_showMove ? "on" : "")" type="button" @onclick="() => _showMove = !_showMove" title="Move range (M)">Move</button>
				<button class="btn small ghost @(_showCharge ? "on" : "")" type="button" @onclick="() => _showCharge = !_showCharge" title="Charge threat (M + 12″)">Charge</button>
				<button class="btn small ghost @(_showGuns ? "on" : "")" type="button" @onclick="() => _showGuns = !_showGuns" title="Longest gun range">Guns</button>
			</span>
		</div>

		<TacticalBoard Map="_map" Tokens="_plan.Tokens" MeasureMode="_measureMode" OnChanged="SavePlanAsync"
					   UnitDrag="_unitDrag" ShowMoveRange="_showMove" ShowChargeRange="_showCharge" ShowWeaponRange="_showGuns" />

		<p class="tmap-hint">Drag any model to move its whole unit together (<strong>Move model</strong> or holding <kbd>Shift</kbd> moves single models). Click a model to select its unit: drag the <strong>⟳ handle</strong> to rotate the formation, and toggle the ring buttons to see its move, charge-threat and gun ranges. Models out of coherency (within 2″ of a unit-mate, two mates for units of 7+) pulse amber. Use <strong>Measure</strong> to check any distance.</p>

		@if (UnitGroups() is { Count: > 0 } groups)
		{
			<div class="legend" aria-label="Units">
				@foreach (var g in groups)
				{
					<div class="legend-row">
						<span class="legend-swatch" style="background:@TokenStyle.Color(g.Side, g.ColorIndex)"></span>
						<input class="legend-abbrev @(g.Side == MapSide.Player ? "player" : "opponent")"
							   value="@g.Abbrev" maxlength="3"
							   @onchange="e => RenameUnitAsync(g.Key, (string?)e.Value)" aria-label="@($"Abbreviation for {g.Name}")" />
						<span class="legend-name">@g.Name</span>
						@if (g.MoveInches is not null || g.WeaponRangeInches is not null)
						{
							<span class="legend-stats">@LegendStats(g)</span>
						}
						<span class="legend-count">@g.Count @(g.Count == 1 ? "model" : "models")</span>
					</div>
				}
			</div>
		}

		@if (_error is not null)
		{
			<p class="tmap-error">@_error</p>
		}
	}
</div>

@code {
	private bool _loading = true;
	private bool _authenticated;
	private bool _busy;
	private string? _error;

	private CatalogueData _catalogue = new();
	private List<Roster> _rosters = [];
	private List<TacticalPlan> _plans = [];
	private TacticalPlan? _plan;
	private MapDefinition _map = TacticalMaps.Resolve(TacticalMaps.DefaultMapId);
	private string _newRosterId = "";
	private bool _measureMode;
	private bool _unitDrag = true;
	private bool _showMove;
	private bool _showCharge;
	private bool _showGuns;
	private bool _saveQueued;

	private void ToggleMeasure() => _measureMode = !_measureMode;

	protected override async Task OnInitializedAsync()
	{
		var user = await Api.GetCurrentUserAsync();
		_authenticated = user.IsAuthenticated;
		if (_authenticated)
		{
			_catalogue = await Api.GetCatalogueAsync();
			_rosters = (await Api.GetRostersAsync()).ToList();
			_plans = (await Api.GetTacticalPlansAsync()).ToList();
		}
		_loading = false;
	}

	private async Task CreatePlanAsync()
	{
		var roster = _rosters.FirstOrDefault(r => r.Id == _newRosterId);
		if (roster is null)
			return;

		_busy = true;
		_error = null;
		try
		{
			var plan = new TacticalPlan
			{
				Name = $"{roster.Name} — plan",
				RosterId = roster.Id,
				MapId = _map.Id,
				Tokens = SeedTokens(roster),
			};
			var saved = await Api.SaveTacticalPlanAsync(plan);
			_plan = saved;
			_plans.Insert(0, saved);
		}
		catch (Exception)
		{
			_error = "Could not create the plan. Please try again.";
		}
		finally
		{
			_busy = false;
		}
	}

	// One token per model, arranged in tidy rows along the player's (bottom) edge as a starting point.
	private List<MapToken> SeedTokens(Roster roster)
	{
		var tokens = new List<MapToken>();
		double cursorX = 2, cursorY = _map.HeightInches - 6, rowMaxY = cursorY;
		var colorIndex = 0;
		foreach (var unit in roster.Units)
		{
			var sheet = _catalogue.Datasheets.FirstOrDefault(d => d.Id == unit.DatasheetId);
			var name = sheet?.Name ?? "Unit";
			var abbrev = TokenStyle.Abbreviate(name);
			var baseMm = sheet is null ? BaseSizeDefaults.Default : BaseSizeDefaults.ForDatasheet(sheet);
			var move = TacticalStats.MoveInchesFor(sheet);
			var gunRange = TacticalStats.MaxRangedInchesFor(sheet);
			var diameter = baseMm / 25.4;
			var count = Math.Max(1, unit.ModelCount);
			for (var i = 0; i < count; i++)
			{
				if (cursorX + diameter > _map.WidthInches - 2)
				{
					cursorX = 2;
					cursorY = rowMaxY + diameter + 0.3;
					rowMaxY = cursorY;
				}
				tokens.Add(new MapToken
				{
					RosterUnitId = unit.Id,
					Label = name,
					Abbrev = abbrev,
					Side = MapSide.Player,
					ColorIndex = colorIndex,
					BaseMm = baseMm,
					XInches = cursorX + diameter / 2,
					YInches = cursorY,
					MoveInches = move,
					WeaponRangeInches = gunRange,
				});
				cursorX += diameter + 0.3;
				rowMaxY = Math.Max(rowMaxY, cursorY);
			}
			colorIndex++;
		}
		return tokens;
	}

	private void AddOpponentMarker()
	{
		if (_plan is null)
			return;
		var colorIndex = _plan.Tokens.Where(t => t.Side == MapSide.Opponent).Select(t => t.ColorIndex).DefaultIfEmpty(-1).Max() + 1;
		_plan.Tokens.Add(new MapToken
		{
			RosterUnitId = Guid.NewGuid().ToString("n"),
			Label = "Opponent unit",
			Abbrev = "OP",
			Side = MapSide.Opponent,
			ColorIndex = colorIndex,
			BaseMm = 40,
			XInches = _map.WidthInches / 2,
			YInches = 6,
		});
		_ = SavePlanAsync();
	}

	// A distinct unit on the board (its models share a RosterUnitId), for the legend.
	private sealed record UnitGroupView(string Key, string Name, string Abbrev, MapSide Side, int ColorIndex, int Count, double? MoveInches, double? WeaponRangeInches);

	private List<UnitGroupView> UnitGroups()
	{
		if (_plan is null)
			return [];
		return _plan.Tokens
			.Where(t => !string.IsNullOrEmpty(t.RosterUnitId))
			.GroupBy(t => t.RosterUnitId, StringComparer.Ordinal)
			.Select(grp =>
			{
				var first = grp.First();
				return new UnitGroupView(grp.Key, first.Label, first.Abbrev, first.Side, first.ColorIndex, grp.Count(),
					grp.Max(t => t.MoveInches), grp.Max(t => t.WeaponRangeInches));
			})
			.OrderBy(g => g.Side)
			.ThenBy(g => g.Name, StringComparer.OrdinalIgnoreCase)
			.ToList();
	}

	// e.g. "M 10″ · Guns 24″" — only the parts the unit actually has.
	private static string LegendStats(UnitGroupView g)
	{
		var parts = new List<string>(2);
		if (g.MoveInches is { } m)
			parts.Add($"M {m.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}″");
		if (g.WeaponRangeInches is { } r)
			parts.Add($"Guns {r.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}″");
		return string.Join(" · ", parts);
	}

	// Renames a whole unit's abbreviation (applies to every model of that unit), then persists.
	private async Task RenameUnitAsync(string rosterUnitId, string? abbrev)
	{
		if (_plan is null)
			return;
		var trimmed = (abbrev ?? string.Empty).Trim().ToUpperInvariant();
		if (trimmed.Length > 3)
			trimmed = trimmed[..3];
		foreach (var token in _plan.Tokens.Where(t => string.Equals(t.RosterUnitId, rosterUnitId, StringComparison.Ordinal)))
			token.Abbrev = trimmed;
		await SavePlanAsync();
	}

	// ---- New Recruit import ----

	// Creates a fresh plan from an uploaded New Recruit JSON (your units), then persists it.
	private async Task CreateFromImportAsync(InputFileChangeEventArgs e)
	{
		var json = await ReadFileAsync(e);
		if (json is null)
			return;
		var result = NewRecruitImporter.Import(json);
		if (result.Units.Count == 0)
		{
			_error = result.Warnings.FirstOrDefault() ?? "No units found in that file.";
			return;
		}

		_plan = new TacticalPlan
		{
			Name = $"{e.File.Name.Replace(".json", "", StringComparison.OrdinalIgnoreCase)} — plan",
			MapId = _map.Id,
		};
		AppendImported(result.Units, MapSide.Player);
		var saved = await Api.SaveTacticalPlanAsync(_plan);
		_plan = saved;
		_plans.Insert(0, saved);
	}

	// Adds the uploaded units to the open plan for the given side, then persists.
	private async Task ImportAsync(InputFileChangeEventArgs e, MapSide side)
	{
		if (_plan is null)
			return;
		var json = await ReadFileAsync(e);
		if (json is null)
			return;
		var result = NewRecruitImporter.Import(json);
		if (result.Units.Count == 0)
		{
			_error = result.Warnings.FirstOrDefault() ?? "No units found in that file.";
			return;
		}
		AppendImported(result.Units, side);
		await SavePlanAsync();
	}

	private async Task<string?> ReadFileAsync(InputFileChangeEventArgs e)
	{
		_error = null;
		try
		{
			using var reader = new StreamReader(e.File.OpenReadStream(maxAllowedSize: 8 * 1024 * 1024));
			return await reader.ReadToEndAsync();
		}
		catch (Exception)
		{
			_error = "Could not read that file.";
			return null;
		}
	}

	// Lays out imported units as per-model tokens along the given side's edge (player = bottom, opponent = top).
	private void AppendImported(IReadOnlyList<Warhammer40k._11.Features.CombatSimulator.Domain.CombatUnit> units, MapSide side)
	{
		if (_plan is null)
			return;

		var colorIndex = _plan.Tokens.Where(t => t.Side == side).Select(t => t.ColorIndex).DefaultIfEmpty(-1).Max() + 1;
		var downward = side == MapSide.Opponent;
		double cursorX = 2;
		double cursorY = side == MapSide.Player ? _map.HeightInches - 6 : 6;
		var rowMaxY = cursorY;

		foreach (var unit in units)
		{
			var models = Math.Max(1, unit.ModelGroups.Sum(g => g.Count));
			var baseMm = models == 1 ? 40 : 32; // heuristic: lone models are usually characters/monsters
			var diameter = baseMm / 25.4;
			var abbrev = TokenStyle.Abbreviate(unit.Name);
			var unitId = Guid.NewGuid().ToString("n");
			var move = unit.ModelGroups
				.Select(g => TacticalStats.ParseInches(g.Profile.Movement))
				.Max();
			var gunRange = unit.AllWeapons
				.SelectMany(w => w.HasFiringModes ? w.FiringModes : [w])
				.Where(w => !w.IsMelee)
				.Select(w => TacticalStats.ParseInches(w.Range))
				.Max();

			for (var i = 0; i < models; i++)
			{
				if (cursorX + diameter > _map.WidthInches - 2)
				{
					cursorX = 2;
					cursorY = downward ? rowMaxY + diameter + 0.3 : rowMaxY - diameter - 0.3;
					rowMaxY = cursorY;
				}
				_plan.Tokens.Add(new MapToken
				{
					RosterUnitId = unitId,
					Label = unit.Name,
					Abbrev = abbrev,
					Side = side,
					ColorIndex = colorIndex,
					BaseMm = baseMm,
					XInches = cursorX + diameter / 2,
					YInches = cursorY,
					MoveInches = move,
					WeaponRangeInches = gunRange,
				});
				cursorX += diameter + 0.3;
			}
			colorIndex++;
		}
	}

	private async Task OpenPlanAsync(string id)
	{
		_busy = true;
		var plan = await Api.GetTacticalPlanAsync(id);
		if (plan is not null)
		{
			BackfillStats(plan);
			_plan = plan;
			_map = TacticalMaps.Resolve(plan.MapId);
		}
		_busy = false;
	}

	// The roster build is the source of truth: refresh roster-backed tokens' Move/gun-range stats from the
	// catalogue on open, so plans saved before stats existed (or after a catalogue update) get range rings.
	private void BackfillStats(TacticalPlan plan)
	{
		var roster = _rosters.FirstOrDefault(r => r.Id == plan.RosterId);
		if (roster is null)
			return;
		foreach (var unit in roster.Units)
		{
			var sheet = _catalogue.Datasheets.FirstOrDefault(d => d.Id == unit.DatasheetId);
			if (sheet is null)
				continue;
			var move = TacticalStats.MoveInchesFor(sheet);
			var gunRange = TacticalStats.MaxRangedInchesFor(sheet);
			foreach (var token in plan.Tokens.Where(t => string.Equals(t.RosterUnitId, unit.Id, StringComparison.Ordinal)))
			{
				token.MoveInches = move;
				token.WeaponRangeInches = gunRange;
			}
		}
	}

	private void ClosePlan() => _plan = null;

	private async Task SavePlanAsync()
	{
		if (_plan is null)
			return;
		// A save requested while one is in flight is queued and runs right after, so a quick second drag
		// is never silently dropped.
		if (_busy)
		{
			_saveQueued = true;
			return;
		}
		_busy = true;
		_error = null;
		try
		{
			do
			{
				_saveQueued = false;
				var saved = await Api.SaveTacticalPlanAsync(_plan);
				_plan.Id = saved.Id;
				_plan.ModifiedUtc = saved.ModifiedUtc;
				var idx = _plans.FindIndex(p => p.Id == saved.Id);
				if (idx >= 0)
					_plans[idx] = saved;
			}
			while (_saveQueued && _plan is not null);
		}
		catch (Exception)
		{
			_error = "Could not save the plan. Your changes are still on screen — try Save again.";
		}
		finally
		{
			_busy = false;
			_saveQueued = false;
		}
	}

	private async Task DeletePlanAsync(string id)
	{
		await Api.DeleteTacticalPlanAsync(id);
		_plans.RemoveAll(p => p.Id == id);
		if (_plan?.Id == id)
			_plan = null;
	}
}
