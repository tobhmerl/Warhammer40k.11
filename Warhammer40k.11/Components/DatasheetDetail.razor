@namespace Warhammer40k._11.Components
@using Warhammer40k.Core.Catalogue

@if (Datasheet is { } d)
{
	<div class="detail">
		<div class="detail-meta">
			<span class="chip solid">@PointsLabel(d)</span>
			<span class="chip">Max @d.MaxCopies</span>
			@if (d.IsCharacter)
			{
				<span class="chip">Character</span>
			}
			@if (d.IsBattleline)
			{
				<span class="chip">Battleline</span>
			}
			@if (d.WarlordEligible)
			{
				<span class="chip">Warlord-eligible</span>
			}
			@if (d.CanTakeEnhancements)
			{
				<span class="chip">Enhancements</span>
			}
			@if (d.HasLeaderAbility)
			{
				<span class="chip">Leader@(d.AllowsCoLeader ? " · co-lead" : "")</span>
			}
		</div>

		@if (BindingFor(d) is { } binding)
		{
			<p class="binding">
				<span class="binding-mark" aria-hidden="true"></span>
				Pantheon of Woe — <strong>@binding.Name</strong> <span class="binding-pts">+@binding.Points pts</span>
			</p>
		}

		@if (d.StatProfiles.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Profile</h3>
				<div class="table-wrap">
					<table class="stats">
						<thead>
							<tr>
								@if (d.StatProfiles.Count > 1)
								{
									<th class="lcell">Model</th>
								}
								<th>M</th><th>T</th><th>SV</th><th>W</th><th>LD</th><th>OC</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var s in d.StatProfiles)
							{
								<tr @key="s.Name">
									@if (d.StatProfiles.Count > 1)
									{
										<td class="lcell">@s.Name</td>
									}
									<td>@s.Move</td><td>@s.Toughness</td><td>@s.Save</td>
									<td>@s.Wounds</td><td>@s.Leadership</td><td>@s.ObjectiveControl</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</section>
		}

		@if (d.Weapons.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Weapons</h3>
				<div class="table-wrap">
					<table class="weapons">
						<thead>
							<tr>
								<th class="lcell">Name</th>
								<th>Range</th><th>A</th><th>BS/WS</th><th>S</th><th>AP</th><th>D</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var w in d.Weapons)
							{
								<tr @key="w.Name">
									<td class="lcell">
										<span class="wname">@(w.Count > 1 ? $"{w.Count}× " : "")@w.Name</span>
										@if (w.Keywords.Count > 0)
										{
											<span class="wkw">@string.Join(", ", w.Keywords)</span>
										}
									</td>
									<td>@Dash(w.Range)</td><td>@Dash(w.Attacks)</td><td>@Dash(w.Skill)</td>
									<td>@Dash(w.Strength)</td><td>@Dash(w.ArmourPenetration)</td><td>@Dash(w.Damage)</td>
								</tr>
							}
						</tbody>
					</table>
				</div>
			</section>
		}

		@if (d.Abilities.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Abilities</h3>
				<ul class="abilities">
					@foreach (var a in d.Abilities)
					{
						<li @key="a.Name">
							<span class="ability-name">@a.Name</span>
							<span class="ability-text">@Clean(a.Text)</span>
						</li>
					}
				</ul>
			</section>
		}

		@if (LeaderTargets(d).Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Can lead</h3>
				<p class="lead-list">@string.Join(" · ", LeaderTargets(d))</p>
			</section>
		}

		@if (d.PointsOptions.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Unit sizes</h3>
				<ul class="sizes">
					@foreach (var o in d.PointsOptions)
					{
						<li @key="o.Models"><span>@o.Models @(o.Models == 1 ? "model" : "models")</span><strong>@o.Points pts</strong></li>
					}
				</ul>
			</section>
		}

		@if (d.FactionRules.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Faction rules</h3>
				<div class="chips">
					@foreach (var r in d.FactionRules)
					{
						<span class="chip" @key="r">@r</span>
					}
				</div>
			</section>
		}

		@if (d.Keywords.Count > 0)
		{
			<section class="block">
				<h3 class="block-title">Keywords</h3>
				<div class="chips">
					@foreach (var k in d.Keywords)
					{
						<span class="chip muted" @key="k">@k</span>
					}
				</div>
			</section>
		}
	</div>
}

@code {
	/// <summary>The datasheet to render. Nothing is shown when null.</summary>
	[Parameter, EditorRequired] public Datasheet? Datasheet { get; set; }

	/// <summary>Optional catalogue, used to resolve the Pantheon binding and leader-target names.</summary>
	[Parameter] public CatalogueData? Catalogue { get; set; }

	private static string PointsLabel(Datasheet d) =>
		d.PointsOptions.Count > 1
			? $"from {d.PointsOptions.Min(p => p.Points)} pts"
			: $"{d.Points} pts";

	private PantheonBinding? BindingFor(Datasheet d) =>
		d.IsMonster ? Catalogue?.FindBindingForUnit(d.Name) : null;

	private IReadOnlyList<string> LeaderTargets(Datasheet d)
	{
		if (Catalogue is null)
			return Array.Empty<string>();

		return d.LeaderTargetIds
			.Select(id => Catalogue.FindById(id)?.Name)
			.Where(name => name is not null)
			.Select(name => name!)
			.ToList();
	}

	private static string Dash(string value) => string.IsNullOrWhiteSpace(value) ? "–" : value;

	private static string Clean(string text) =>
		text.Replace("^^**", "", StringComparison.Ordinal)
			.Replace("**", "", StringComparison.Ordinal)
			.Replace("^^", "", StringComparison.Ordinal)
			.Replace("■", "•", StringComparison.Ordinal)
			.Trim();
}
